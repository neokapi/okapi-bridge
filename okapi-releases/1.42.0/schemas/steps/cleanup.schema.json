{
  "$id": "cleanup",
  "title": "Cleanup",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.cleanup.CleanupStep",
    "parameterMappings": [
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleTextUnit"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "cleanup",
    "type": "step",
    "displayName": "Cleanup",
    "description": "Cleans strings by normalizing quotes, punctuation, etc. ready for further processing. Expects: filter events. Sends back: filter events.",
    "category": "transform",
    "inputs": [
      "block"
    ],
    "requires": [
      "target-language",
      "source-language"
    ]
  },
  "properties": {
    "normalizeQuotes": {
      "type": "boolean",
      "default": true,
      "title": "Normalize quotation marks",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "checkCharacters": {
      "type": "boolean",
      "default": true,
      "title": "Check for corrupt or unexpected characters",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "matchRegexExpressions": {
      "type": "boolean",
      "default": true,
      "title": "Mark segments matching default regular expressions for removal",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "matchUserRegex": {
      "type": "boolean",
      "default": true,
      "title": "Mark segments matching user defined regular expressions for removal",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "userRegex": {
      "type": "string",
      "default": "",
      "title": "User defined regex string",
      "x-widget": "text",
      "x-allowEmpty": true,
      "x-vertical": true
    },
    "pruneTextUnit": {
      "type": "boolean",
      "default": true,
      "title": "Remove unnecessary segments from text unit",
      "x-widget": "checkbox",
      "x-vertical": true
    }
  }
}