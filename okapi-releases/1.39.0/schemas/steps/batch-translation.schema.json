{
  "$id": "batch-translation",
  "title": "Batch Translation",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.batchtranslation.BatchTranslationStep",
    "parameterMappings": [
      "BATCH_INPUT_COUNT",
      "FILTER_CONFIGURATION_MAPPER",
      "INPUT_ROOT_DIRECTORY",
      "ROOT_DIRECTORY"
    ],
    "eventHandlers": [
      "handleEndBatchItem",
      "handleRawDocument",
      "handleStartBatch",
      "handleStartBatchItem"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "batch-translation",
    "type": "step",
    "displayName": "Batch Translation",
    "description": "Creates translations from an external program for a given input document. Expects: raw document. Sends back: raw document.",
    "category": "translate",
    "tags": [
      "batch",
      "translation"
    ]
  },
  "properties": {
    "command": {
      "type": "string",
      "default": "",
      "title": "Command line",
      "description": "Command line to execute the batch translation",
      "x-widget": "text",
      "x-vertical": true
    },
    "origin": {
      "type": "string",
      "default": "",
      "title": "Origin identifier",
      "description": "String that identifies the origin of the translation",
      "x-widget": "text",
      "x-allowEmpty": true
    },
    "markAsMT": {
      "type": "boolean",
      "default": true,
      "title": "Mark the generated translation as machine translation results",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "makeTM": {
      "type": "boolean",
      "default": false,
      "title": "Import into the following Pensieve TM:",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "tmDirectory": {
      "type": "string",
      "default": "",
      "description": "Location of the TM to create or use",
      "x-widget": "folder",
      "x-enabledBy": {
        "parameter": "makeTM",
        "enabledWhenSelected": true
      },
      "x-browseTitle": "TM Directory",
      "x-withLabel": false,
      "x-vertical": true
    },
    "makeTMX": {
      "type": "boolean",
      "default": false,
      "title": "Create the following TMX document:",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "tmxPath": {
      "type": "string",
      "default": "",
      "description": "Full path of the new TMX document to create",
      "x-widget": "path",
      "x-enabledBy": {
        "parameter": "makeTMX",
        "enabledWhenSelected": true
      },
      "x-forSaveAs": true,
      "x-browseTitle": "TMX Path",
      "x-fileFilterNames": "TMX Documents (*.tmx)\tAll Files (*.*)",
      "x-fileFilterExtensions": "*.tmx\t*.*",
      "x-withLabel": false,
      "x-vertical": true
    },
    "sendTMX": {
      "type": "boolean",
      "default": false,
      "title": "Send the TMX document to the next step",
      "x-widget": "checkbox",
      "x-enabledBy": {
        "parameter": "makeTMX",
        "enabledWhenSelected": true
      },
      "x-vertical": true
    },
    "blockSize": {
      "type": "integer",
      "default": 1000,
      "title": "Block size",
      "description": "Maximum number of text units to process together",
      "minimum": 1,
      "x-widget": "spin"
    },
    "checkExistingTm": {
      "type": "boolean",
      "default": false,
      "title": "Check for existing entries in an existing Pensieve TM:",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "existingTm": {
      "type": "string",
      "default": "",
      "description": "Location of the TM to lookup",
      "x-widget": "folder",
      "x-enabledBy": {
        "parameter": "checkExistingTm",
        "enabledWhenSelected": true
      },
      "x-browseTitle": "TM Directory",
      "x-withLabel": false,
      "x-vertical": true
    },
    "segment": {
      "type": "boolean",
      "default": false,
      "title": "Segment the text units, using the following SRX rules:",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "srxPath": {
      "type": "string",
      "default": "",
      "description": "Full path of the segmentation rules file to use",
      "x-widget": "path",
      "x-enabledBy": {
        "parameter": "segment",
        "enabledWhenSelected": true
      },
      "x-browseTitle": "SRX Path",
      "x-fileFilterNames": "SRX Documents (*.srx)\tAll Files (*.*)",
      "x-fileFilterExtensions": "*.srx\t*.*",
      "x-withLabel": false,
      "x-vertical": true
    }
  }
}