{
  "$id": "g-t-t-batch-translation",
  "title": "GTT Batch Translation",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.gttbatchtranslation.GTTBatchTranslationStep",
    "parameterMappings": [
      "ROOT_DIRECTORY",
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleEndBatch",
      "handleEndDocument",
      "handleEndSubDocument",
      "handleStartBatch",
      "handleStartDocument",
      "handleStartSubDocument",
      "handleTextUnit"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "g-t-t-batch-translation",
    "type": "step",
    "displayName": "GTT Batch Translation",
    "description": "Creates a TM from the input documents using the Google Translator Toolkit. Expects: filter events. Sends back: filter events.",
    "category": "translate",
    "inputs": [
      "block"
    ],
    "tags": [
      "batch",
      "translation"
    ],
    "requires": [
      "target-language",
      "source-language"
    ]
  },
  "properties": {
    "email": {
      "type": "string",
      "default": "",
      "title": "Email address",
      "description": "Email address of the Google Translator Toolkit account",
      "x-widget": "text"
    },
    "password": {
      "type": "string",
      "default": "",
      "title": "Password",
      "description": "Password of the account",
      "x-widget": "text",
      "x-password": true
    },
    "tmxPath": {
      "type": "string",
      "default": "${rootDir}/tmFromGTT.tmx",
      "title": "TMX document to create",
      "description": "Full path of the new TMX document to create",
      "x-widget": "path",
      "x-forSaveAs": true,
      "x-browseTitle": "TMX Path",
      "x-fileFilterNames": "TMX Documents (*.tmx)\tAll Files (*.*)",
      "x-fileFilterExtensions": "*.tmx\t*.*",
      "x-vertical": true
    },
    "waitClass": {
      "type": "string",
      "default": "net.sf.okapi.common.ui.WaitDialog"
    },
    "markAsMT": {
      "type": "boolean",
      "default": true,
      "title": "Mark the generated translation as machine translation results",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "openGttPages": {
      "type": "boolean",
      "default": true,
      "title": "Open the GTT edit pages automatically after upload",
      "x-widget": "checkbox",
      "x-vertical": true
    }
  }
}