{
  "$id": "format-conversion",
  "title": "Format Conversion",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.formatconversion.FormatConversionStep",
    "parameterMappings": [
      "EXECUTION_CONTEXT",
      "INPUT_URI",
      "OUTPUT_URI",
      "ROOT_DIRECTORY",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "file"
  },
  "x-component": {
    "id": "format-conversion",
    "type": "step",
    "displayName": "Format Conversion",
    "description": "Converts the output of a filter into a specified file format. Expects: filter events. Sends back: filter events.",
    "category": "convert",
    "inputs": [
      "block"
    ],
    "outputs": [
      "data"
    ],
    "requires": [
      "target-language"
    ]
  },
  "properties": {
    "tmx": {
      "type": "boolean",
      "default": false
    },
    "po": {
      "type": "boolean",
      "default": false
    },
    "table": {
      "type": "boolean",
      "default": false
    },
    "pensieve": {
      "type": "boolean",
      "default": false
    },
    "corpus": {
      "type": "boolean",
      "default": false
    },
    "wordtable": {
      "type": "boolean",
      "default": false
    },
    "singleOutput": {
      "type": "boolean",
      "default": true,
      "title": "Create a single output document",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "autoExtensions": {
      "type": "boolean",
      "default": false,
      "title": "Output paths are the input paths plus the new format extension",
      "x-widget": "checkbox",
      "x-enabledBy": {
        "parameter": "singleOutput",
        "enabledWhenSelected": false
      },
      "x-vertical": true
    },
    "outputPath": {
      "type": "string",
      "default": "",
      "title": "Output path",
      "description": "Full path of the single output document to generate",
      "x-widget": "path",
      "x-enabledBy": {
        "parameter": "singleOutput",
        "enabledWhenSelected": true
      },
      "x-forSaveAs": true,
      "x-browseTitle": "Output File",
      "x-fileFilterNames": "All Files (*.*)",
      "x-fileFilterExtensions": "*.*",
      "x-vertical": true
    },
    "targetStyle": {
      "type": "integer",
      "default": 0,
      "title": "Target content",
      "description": "Type of content to put in the target"
    },
    "outputFormat": {
      "type": "string",
      "default": "tmx",
      "title": "Output format",
      "description": "Format to generate in output",
      "enum": [
        "po",
        "tmx",
        "table",
        "pensieve",
        "corpus",
        "wordtable"
      ],
      "x-enumLabels": [
        "PO File",
        "TMX Document",
        "Tab-Delimited Table",
        "Pensieve TM",
        "Parallel Corpus Files",
        "Word Table"
      ],
      "x-widget": "select",
      "x-vertical": true
    },
    "formatOptions": {
      "type": "string",
      "default": "",
      "title": "Format options"
    },
    "useGenericCodes": {
      "type": "boolean",
      "default": false,
      "title": "Output generic inline codes",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "skipEntriesWithoutText": {
      "type": "boolean",
      "default": true,
      "title": "Do not output entries without text",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "approvedEntriesOnly": {
      "type": "boolean",
      "default": false,
      "title": "Output only approved entries",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "overwriteSameSource": {
      "type": "boolean",
      "default": false,
      "title": "Overwrite if source is the same (for Pensieve TM)",
      "x-widget": "checkbox",
      "x-vertical": true
    }
  }
}