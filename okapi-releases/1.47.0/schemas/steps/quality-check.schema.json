{
  "$id": "quality-check",
  "title": "Quality Check",
  "type": "object",
  "x-component": {
    "id": "quality-check",
    "type": "step",
    "displayName": "Quality Check",
    "description": "Compare source and target for quality. Expects: filter events or raw documents. Sends back: filter events or raw document."
  },
  "x-step": {
    "class": "net.sf.okapi.steps.qualitycheck.QualityCheckStep",
    "parameterMappings": [
      "FILTER_CONFIGURATION_MAPPER",
      "ROOT_DIRECTORY",
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleEndBatch",
      "handleRawDocument",
      "handleStartBatch",
      "handleStartBatchItem",
      "handleStartDocument",
      "handleTextUnit"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "properties": {
    "includeTextContainers": {
      "type": "boolean",
      "default": false
    },
    "useGenericCodes": {
      "type": "boolean",
      "default": false
    },
    "outputPath": {
      "type": "string",
      "default": "${rootDir}/qa-report.html"
    },
    "outputType": {
      "type": "integer",
      "default": 0
    },
    "autoOpen": {
      "type": "boolean",
      "default": true
    },
    "leadingWS": {
      "type": "boolean",
      "default": true
    },
    "trailingWS": {
      "type": "boolean",
      "default": true
    },
    "emptyTarget": {
      "type": "boolean",
      "default": true
    },
    "emptySource": {
      "type": "boolean",
      "default": true
    },
    "targetSameAsSource": {
      "type": "boolean",
      "default": true
    },
    "targetSameAsSourceForSameLanguage": {
      "type": "boolean",
      "default": true
    },
    "targetSameAsSourceWithCodes": {
      "type": "boolean",
      "default": true
    },
    "targetSameAsSourceWithNumbers": {
      "type": "boolean",
      "default": true
    },
    "codeDifference": {
      "type": "boolean",
      "default": true
    },
    "guessOpenClose": {
      "type": "boolean",
      "default": true
    },
    "strictCodeOrder": {
      "type": "boolean",
      "default": false
    },
    "checkXliffSchema": {
      "type": "boolean",
      "default": true
    },
    "xliffSchemaType": {
      "type": "string",
      "default": "Transitional"
    },
    "checkPatterns": {
      "type": "boolean",
      "default": true
    },
    "checkWithLT": {
      "type": "boolean",
      "default": false
    },
    "serverURL": {
      "type": "string",
      "default": "http://localhost:8081/"
    },
    "ltBilingualMode": {
      "type": "boolean",
      "default": false
    },
    "saveSession": {
      "type": "boolean",
      "default": true
    },
    "sessionPath": {
      "type": "string",
      "default": "${rootDir}/qa-session.qcs"
    },
    "doubledWord": {
      "type": "boolean",
      "default": true
    },
    "doubledWordExceptions": {
      "type": "string",
      "default": "sie;vous;nous"
    },
    "corruptedCharacters": {
      "type": "boolean",
      "default": true
    },
    "scope": {
      "type": "integer",
      "default": 0
    },
    "checkMaxCharLength": {
      "type": "boolean",
      "default": true
    },
    "maxCharLengthBreak": {
      "type": "integer",
      "default": 20
    },
    "maxCharLengthAbove": {
      "type": "integer",
      "default": 200
    },
    "maxCharLengthBelow": {
      "type": "integer",
      "default": 350
    },
    "checkMinCharLength": {
      "type": "boolean",
      "default": true
    },
    "minCharLengthBreak": {
      "type": "integer",
      "default": 20
    },
    "minCharLengthAbove": {
      "type": "integer",
      "default": 45
    },
    "minCharLengthBelow": {
      "type": "integer",
      "default": 30
    },
    "checkStorageSize": {
      "type": "boolean",
      "default": true
    },
    "checkAbsoluteMaxCharLength": {
      "type": "boolean",
      "default": false
    },
    "absoluteMaxCharLength": {
      "type": "integer",
      "default": 255
    },
    "checkAllowedCharacters": {
      "type": "boolean",
      "default": true
    },
    "checkCharacters": {
      "type": "boolean",
      "default": false
    },
    "charset": {
      "type": "string",
      "default": "ISO-8859-1"
    },
    "extraCharsAllowed": {
      "type": "string",
      "default": ""
    },
    "checkTerms": {
      "type": "boolean",
      "default": false
    },
    "termsPath": {
      "type": "string",
      "default": ""
    },
    "stringMode": {
      "type": "boolean",
      "default": false
    },
    "betweenCodes": {
      "type": "boolean",
      "default": false
    },
    "showFullPath": {
      "type": "boolean",
      "default": true
    },
    "checkBlacklist": {
      "type": "boolean",
      "default": false
    },
    "allowBlacklistSub": {
      "type": "boolean",
      "default": false
    },
    "blacklistSrc": {
      "type": "boolean",
      "default": false
    },
    "blacklistPath": {
      "type": "string",
      "default": ""
    },
    "showOnlyPatternDescription": {
      "type": "boolean",
      "default": false
    },
    "typesToIgnore": {
      "type": "string",
      "default": "mrk;x-df-s;"
    },
    "patternCount": {
      "type": "integer",
      "default": 8
    },
    "usePattern0": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern0": {
      "type": "boolean",
      "default": true
    },
    "singlePattern0": {
      "type": "boolean",
      "default": false
    },
    "severityPattern0": {
      "type": "integer",
      "default": 0
    },
    "sourcePattern0": {
      "type": "string",
      "default": "[\\(\\uFF08]"
    },
    "targetPattern0": {
      "type": "string",
      "default": "[\\(\\uFF08]"
    },
    "descPattern0": {
      "type": "string",
      "default": "Opening parenthesis"
    },
    "usePattern1": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern1": {
      "type": "boolean",
      "default": true
    },
    "singlePattern1": {
      "type": "boolean",
      "default": false
    },
    "severityPattern1": {
      "type": "integer",
      "default": 0
    },
    "sourcePattern1": {
      "type": "string",
      "default": "[\\)\\uFF09]"
    },
    "targetPattern1": {
      "type": "string",
      "default": "[\\)\\uFF09]"
    },
    "descPattern1": {
      "type": "string",
      "default": "Closing parenthesis"
    },
    "usePattern2": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern2": {
      "type": "boolean",
      "default": true
    },
    "singlePattern2": {
      "type": "boolean",
      "default": false
    },
    "severityPattern2": {
      "type": "integer",
      "default": 0
    },
    "sourcePattern2": {
      "type": "string",
      "default": "[\\p{Ps}\\p{Pe}&&[^\\(\\)\\uFF08\\uFF09]]"
    },
    "targetPattern2": {
      "type": "string",
      "default": "<same>"
    },
    "descPattern2": {
      "type": "string",
      "default": "Bracketing characters (except parentheses)"
    },
    "usePattern3": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern3": {
      "type": "boolean",
      "default": true
    },
    "singlePattern3": {
      "type": "boolean",
      "default": false
    },
    "severityPattern3": {
      "type": "integer",
      "default": 1
    },
    "sourcePattern3": {
      "type": "string",
      "default": "[\\w\\.\\-]+@[\\w\\.\\-]+"
    },
    "targetPattern3": {
      "type": "string",
      "default": "<same>"
    },
    "descPattern3": {
      "type": "string",
      "default": "Email addresses"
    },
    "usePattern4": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern4": {
      "type": "boolean",
      "default": true
    },
    "singlePattern4": {
      "type": "boolean",
      "default": false
    },
    "severityPattern4": {
      "type": "integer",
      "default": 1
    },
    "sourcePattern4": {
      "type": "string",
      "default": "https?:[\\w/\\.:;+\\-~\\%#\\$?=&,()]+[\\w/:;+\\-~\\%#\\$?=&,()]+|www\\.[\\w/\\.:;+\\-~\\%#\\$?=&,()]+|ftp:[\\w/\\.:;+\\-~\\%#?=&,]+"
    },
    "targetPattern4": {
      "type": "string",
      "default": "<same>"
    },
    "descPattern4": {
      "type": "string",
      "default": "URLs"
    },
    "usePattern5": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern5": {
      "type": "boolean",
      "default": true
    },
    "singlePattern5": {
      "type": "boolean",
      "default": false
    },
    "severityPattern5": {
      "type": "integer",
      "default": 2
    },
    "sourcePattern5": {
      "type": "string",
      "default": "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b"
    },
    "targetPattern5": {
      "type": "string",
      "default": "<same>"
    },
    "descPattern5": {
      "type": "string",
      "default": "IP addresses"
    },
    "usePattern6": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern6": {
      "type": "boolean",
      "default": true
    },
    "singlePattern6": {
      "type": "boolean",
      "default": false
    },
    "severityPattern6": {
      "type": "integer",
      "default": 2
    },
    "sourcePattern6": {
      "type": "string",
      "default": "%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]"
    },
    "targetPattern6": {
      "type": "string",
      "default": "<same>"
    },
    "descPattern6": {
      "type": "string",
      "default": "C-style printf codes"
    },
    "usePattern7": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern7": {
      "type": "boolean",
      "default": false
    },
    "singlePattern7": {
      "type": "boolean",
      "default": false
    },
    "severityPattern7": {
      "type": "integer",
      "default": 1
    },
    "sourcePattern7": {
      "type": "string",
      "default": "<same>"
    },
    "targetPattern7": {
      "type": "string",
      "default": "([\\p{Ll}\\p{Lu}\\p{Lt}\\p{Lo}])\\1\\1"
    },
    "descPattern7": {
      "type": "string",
      "default": "Tripled letter"
    },
    "extraCodesAllowed": {
      "type": "integer",
      "default": 0
    },
    "missingCodesAllowed": {
      "type": "integer",
      "default": 0
    }
  }
}