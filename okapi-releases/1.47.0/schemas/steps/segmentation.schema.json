{
  "$id": "segmentation",
  "title": "Segmentation",
  "type": "object",
  "x-component": {
    "id": "segmentation",
    "type": "step",
    "displayName": "Segmentation",
    "description": "Apply SRX segmentation to the text units content of a document. Expects: filter events. Sends back: filter events."
  },
  "x-step": {
    "class": "net.sf.okapi.steps.segmentation.SegmentationStep",
    "parameterMappings": [
      "INPUT_ROOT_DIRECTORY",
      "ROOT_DIRECTORY",
      "SOURCE_LOCALE",
      "TARGET_LOCALE",
      "TARGET_LOCALES"
    ],
    "eventHandlers": [
      "handleCustom",
      "handleStartBatch",
      "handleStartBatchItem",
      "handleStartDocument",
      "handleTextUnit"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "properties": {
    "segmentSource": {
      "type": "boolean",
      "default": true
    },
    "segmentTarget": {
      "type": "boolean",
      "default": false
    },
    "renumberCodes": {
      "type": "boolean",
      "default": false
    },
    "checkSegments": {
      "type": "boolean",
      "default": true
    },
    "trimSrcLeadingWS": {
      "type": "integer",
      "default": -1
    },
    "trimSrcTrailingWS": {
      "type": "integer",
      "default": -1
    },
    "trimTrgLeadingWS": {
      "type": "integer",
      "default": -1
    },
    "trimTrgTrailingWS": {
      "type": "integer",
      "default": -1
    },
    "forceSegmentedOutput": {
      "type": "boolean",
      "default": true
    },
    "overwriteSegmentation": {
      "type": "boolean",
      "default": false
    },
    "deepenSegmentation": {
      "type": "boolean",
      "default": false
    },
    "treatIsolatedCodesAsWhitespace": {
      "type": "boolean",
      "default": false
    },
    "doNotSegmentIfHasTarget": {
      "type": "boolean",
      "default": false
    }
  }
}