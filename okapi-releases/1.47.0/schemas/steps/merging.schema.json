{
  "$id": "merging",
  "title": "Rainbow Translation Kit Merging",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.rainbowkit.postprocess.MergingStep",
    "parameterMappings": [
      "FILTER_CONFIGURATION_MAPPER",
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleStartDocument"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "merging",
    "type": "step",
    "displayName": "Rainbow Translation Kit Merging",
    "description": "Post-process a Rainbow translation kit. Expects: filter events. Sends back: filter events or raw documents.",
    "category": "translate",
    "inputs": [
      "block"
    ],
    "tags": [
      "translation"
    ],
    "requires": [
      "target-language",
      "source-language"
    ]
  },
  "properties": {
    "preserveSegmentation": {
      "type": "boolean",
      "default": false,
      "title": "Preserve the segmentation for the next steps",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "returnRawDocument": {
      "type": "boolean",
      "default": false,
      "title": "Return raw documents instead of filter events",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "forceTargetLocale": {
      "type": "boolean",
      "default": false,
      "title": "Specify the target locale from the tool instead of the manifest",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "overrideOutputPath": {
      "type": "string",
      "default": "",
      "title": "Override the output path (leave empty to use the path from the manifest)",
      "x-widget": "text",
      "x-allowEmpty": true,
      "x-vertical": true
    },
    "copyCodeMetadata": {
      "type": "boolean",
      "default": true,
      "title": "Copy the code metadata from the original file",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "skipOriginalTargetCodeMetadata": {
      "type": "boolean",
      "default": false,
      "title": "Skip the original target when copying code metadata",
      "x-widget": "checkbox",
      "x-vertical": true
    }
  }
}