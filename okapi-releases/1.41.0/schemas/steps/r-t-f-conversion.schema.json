        "Unix/Linux (Line-Feed, \\n, 0x0A)",
        "Macintosh (Carriage-Return, \\r, 0x0D)"
      ],
      "x-widget": "select",
      "x-vertical": true
    },
    "bomOnUTF8": {
      "type": "boolean",
      "default": true,
