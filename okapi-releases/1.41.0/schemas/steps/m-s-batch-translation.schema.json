{
  "$id": "m-s-batch-translation",
  "title": "Microsoft Batch Translation",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.msbatchtranslation.MSBatchTranslationStep",
    "parameterMappings": [
      "BATCH_INPUT_COUNT",
      "INPUT_ROOT_DIRECTORY",
      "ROOT_DIRECTORY",
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleStartBatch"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "m-s-batch-translation",
    "type": "step",
    "displayName": "Microsoft Batch Translation",
    "description": "Annotates text units with Microsoft Translator matches or/and creates a TM from them. Expects: filter events. Sends back: filter events.",
    "category": "translate",
    "inputs": [
      "block"
    ],
    "tags": [
      "batch",
      "translation",
      "text-processing"
    ],
    "requires": [
      "target-language",
      "source-language"
    ]
  },
  "properties": {
    "azureKey": {
      "type": "string",
      "default": "",
      "title": "Azure Key",
      "description": "Microsoft Azure subscription key",
      "x-widget": "text",
      "x-password": true
    },
    "category": {
      "type": "string",
      "default": "",
      "title": "Category",
      "description": "Category code if accessing a trained system",
      "x-widget": "text",
      "x-allowEmpty": true
    },
    "configPath": {
      "type": "string",
      "default": "",
      "title": "Engine mapping",
      "description": "Full path of the properties file listing the engines",
      "x-widget": "path",
      "x-browseTitle": "Config Path",
      "x-fileFilterNames": "MS HUB Config (*.properties)\tAll Files (*.*)",
      "x-fileFilterExtensions": "*.properties\t*.*",
      "x-allowEmpty": true
    },
    "annotate": {
      "type": "boolean",
      "default": true,
      "title": "Annotate the text units with the translations",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "makeTmx": {
      "type": "boolean",
      "default": false,
      "title": "Generate a TMX document",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "tmxPath": {
      "type": "string",
      "default": "${rootDir}/tmFromMS.tmx",
      "description": "Full path of the new TMX document to create",
      "x-widget": "path",
      "x-enabledBy": {
        "parameter": "makeTmx",
        "enabledWhenSelected": true
      },
      "x-forSaveAs": true,
      "x-browseTitle": "TMX Path",
      "x-fileFilterNames": "TMX Documents (*.tmx)\tAll Files (*.*)",
      "x-fileFilterExtensions": "*.tmx\t*.*",
      "x-withLabel": false,
      "x-vertical": true
    },
    "markAsMT": {
      "type": "boolean",
      "default": true,
      "title": "Mark the generated translation as machine translation results",
      "x-widget": "checkbox",
      "x-enabledBy": {
        "parameter": "makeTmx",
        "enabledWhenSelected": true
      },
      "x-vertical": true
    },
    "maxEvents": {
      "type": "integer",
      "default": 20,
      "title": "Events buffer",
      "description": "Number of events to store before sending a query",
      "minimum": 1,
      "maximum": 999,
      "x-widget": "spin"
    },
    "maxMatches": {
      "type": "integer",
      "default": 1,
      "title": "Maximum matches",
      "description": "Maximum number of matches allowed",
      "minimum": 1,
      "maximum": 100,
      "x-widget": "spin"
    },
    "threshold": {
      "type": "integer",
      "default": 80,
      "title": "Threshold",
      "description": "Score below which matches are not retained",
      "minimum": 1,
      "maximum": 100,
      "x-widget": "spin"
    },
    "fillTarget": {
      "type": "boolean",
      "default": true,
      "title": "Fill the target with the best translation candidate",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "fillTargetThreshold": {
      "type": "integer",
      "default": 95,
      "title": "Fill threshold",
      "description": "Fill the target when the best candidate is equal or above this score",
      "minimum": 1,
      "maximum": 100,
      "x-widget": "spin",
      "x-enabledBy": {
        "parameter": "fillTarget",
        "enabledWhenSelected": true
      }
    },
    "onlyWhenWithoutCandidate": {
      "type": "boolean",
      "default": true,
      "title": "Query only entries without existing candidate",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "sendTmx": {
      "type": "boolean",
      "default": false,
      "title": "Send the TMX document to the next step",
      "x-widget": "checkbox",
      "x-enabledBy": {
        "parameter": "makeTmx",
        "enabledWhenSelected": true
      },
      "x-vertical": true
    },
    "useTargetPrefix": {
      "type": "boolean",
      "default": false,
      "title": "Add a prefix to the translation candidate copied in the target",
      "x-widget": "checkbox",
      "x-enabledBy": {
        "parameter": "fillTarget",
        "enabledWhenSelected": true
      },
      "x-vertical": true
    },
    "targetPrefix": {
      "type": "string",
      "default": "!MT__",
      "title": "Target prefix",
      "description": "Text to use as the target prefix",
      "x-widget": "text",
      "x-enabledBy": {
        "parameter": "useTargetPrefix",
        "enabledWhenSelected": true
      }
    }
  }
}