{
  "$id": "x-m-l-analysis",
  "title": "XML Analysis",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.xmlanalysis.XMLAnalysisStep",
    "parameterMappings": [],
    "eventHandlers": [
      "handleEndBatch",
      "handleRawDocument",
      "handleStartBatch"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "x-m-l-analysis",
    "type": "step",
    "displayName": "XML Analysis",
    "description": "Generate an analysis report of a set of XML documents. Expects: raw document. Sends back: raw document.",
    "category": "pipeline",
    "tags": [
      "analysis"
    ]
  },
  "properties": {
    "outputPath": {
      "type": "string",
      "default": "analysis.html",
      "title": "Path of the result file",
      "description": "Full path of the result file.",
      "x-widget": "path",
      "x-forSaveAs": true,
      "x-browseTitle": "Result File",
      "x-fileFilterNames": "Text Files (*.txt)\tAll Files (*.*)",
      "x-fileFilterExtensions": "*.txt\t*.*",
      "x-vertical": true
    },
    "autoOpen": {
      "type": "boolean",
      "default": true,
      "title": "Open the result file after completion",
      "x-widget": "checkbox",
      "x-vertical": true
    }
  }
}