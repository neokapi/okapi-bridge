{
  "$id": "codes-removal",
  "title": "Inline Codes Removal",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.codesremoval.CodesRemovalStep",
    "parameterMappings": [
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleStartBatch",
      "handleTextUnit"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "codes-removal",
    "type": "step",
    "displayName": "Inline Codes Removal",
    "description": "Removes inline codes from the text units content of a document. Expects: filter events. Sends back: filter events.",
    "category": "transform",
    "inputs": [
      "block"
    ],
    "tags": [
      "text-processing"
    ],
    "requires": [
      "target-language",
      "source-language"
    ]
  },
  "properties": {
    "stripSource": {
      "type": "boolean",
      "default": true,
      "title": "Strip codes in the source text",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "stripTarget": {
      "type": "boolean",
      "default": true,
      "title": "Strip codes in the target text",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "mode": {
      "type": "integer",
      "default": 2,
      "title": "What to remove",
      "description": "Select what parts of the inline codes to remove",
      "enum": [
        "0",
        "1",
        "2"
      ],
      "x-enumLabels": [
        "Remove code marker, but keep code content  (\"<ph x='1'>[X]</ph>\" ==> \"[X]\")",
        "Remove code content, but keep code marker  (\"<ph x='1'>[X]</ph>\" ==> \"<ph x='1'/>\")",
        "Remove code marker and code content  (\"<ph x='1'>[X]</ph>\" ==> \"\")"
      ],
      "x-widget": "select",
      "x-vertical": true
    },
    "includeNonTranslatable": {
      "type": "boolean",
      "default": true,
      "title": "Apply to non-translatable text units",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "replaceWithSpace": {
      "type": "boolean",
      "default": false,
      "title": "Replace line break codes with spaces (When removing content AND marker)",
      "x-widget": "checkbox",
      "x-vertical": true
    }
  }
}