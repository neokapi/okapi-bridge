{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Markdown Filter Filter",
  "description": "Configuration for the Okapi Markdown Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_markdown",
    "class": "net.sf.okapi.filters.markdown.MarkdownFilter",
    "extensions": [
      ".md",
      ".markdown"
    ],
    "mimeTypes": [
      "text/markdown"
    ],
    "configurations": [
      {
        "configId": "okf_markdown",
        "name": "Markdown",
        "description": "Markdown files",
        "mimeType": "text/markdown",
        "extensions": ".md;.markdown;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.markdown.MarkdownFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "extraction": {
      "type": "object",
      "description": "Content extraction settings",
      "properties": {
        "translateImageAltText": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "translateImageAltText",
          "description": "Translate image alt text"
        },
        "translateUrls": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "translateUrls",
          "description": "Translate URLs"
        },
        "urlPattern": {
          "type": "string",
          "default": ".+",
          "x-flattenPath": "urlToTranslatePattern",
          "description": "Regex for URLs to translate"
        },
        "translateCodeBlocks": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "translateCodeBlocks",
          "description": "Translate fenced code blocks"
        },
        "translateIndentedCodeBlocks": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "translateIndentedCodeBlocks",
          "description": "Translate indented code blocks"
        },
        "translateInlineCodeBlocks": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "translateInlineCodeBlocks",
          "description": "Translate inline code"
        },
        "translateHeaderMetadata": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "translateHeaderMetadata",
          "description": "Translate YAML front matter"
        },
        "nonTranslateBlocks": {
          "type": "string",
          "default": "",
          "x-flattenPath": "nonTranslateBlocks",
          "description": "Regex for non-translatable blocks"
        }
      }
    },
    "output": {
      "type": "object",
      "description": "Output formatting",
      "properties": {
        "charactersToEscape": {
          "type": "string",
          "default": "*_`{}[]<>()#+\\-.!|",
          "x-flattenPath": "charactersToEscape",
          "description": "Characters to escape in output"
        },
        "htmlEntitiesToEscape": {
          "type": "string",
          "default": "",
          "x-flattenPath": "htmlEntitiesToEscape",
          "description": "HTML entities to escape"
        },
        "unescapeBackslashCharacters": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "unescapeBackslashCharacters",
          "description": "Unescape backslash characters"
        }
      }
    },
    "subfilters": {
      "type": "object",
      "description": "Sub-filter configuration",
      "properties": {
        "htmlSubfilter": {
          "type": "string",
          "default": "",
          "x-flattenPath": "htmlSubfilter",
          "description": "HTML sub-filter configuration"
        },
        "yamlSubfilter": {
          "type": "string",
          "default": "",
          "x-flattenPath": "yamlSubfilter",
          "description": "YAML front matter sub-filter"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}