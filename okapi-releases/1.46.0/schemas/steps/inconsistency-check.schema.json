{
  "$id": "inconsistency-check",
  "title": "Inconsistency Check",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.inconsistencycheck.InconsistencyCheckStep",
    "parameterMappings": [
      "INPUT_ROOT_DIRECTORY",
      "ROOT_DIRECTORY",
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleEndBatch",
      "handleEndDocument",
      "handleStartBatch",
      "handleStartDocument",
      "handleStartSubDocument",
      "handleTextUnit"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "inconsistency-check",
    "type": "step",
    "displayName": "Inconsistency Check",
    "description": "Checks for source entries that are the same but have different translations or target entries that are the same but have different sources. Expects: filter events. Sends back: filter events.",
    "category": "translate",
    "inputs": [
      "block"
    ],
    "tags": [
      "translation",
      "quality"
    ],
    "requires": [
      "target-language",
      "source-language"
    ]
  },
  "properties": {
    "checkInconststencies": {
      "type": "boolean",
      "default": true,
      "title": "Check inconsistencies",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "checkPerFile": {
      "type": "boolean",
      "default": false,
      "title": "Check for inconsistencies on a file-by-file basis",
      "x-widget": "checkbox",
      "x-enabledBy": {
        "parameter": "checkInconststencies",
        "enabledWhenSelected": true
      },
      "x-vertical": true
    },
    "outputPath": {
      "type": "string",
      "default": "${rootDir}/inconsistency-report.xml",
      "title": "Path of the report file:",
      "x-widget": "path",
      "x-enabledBy": {
        "parameter": "checkInconststencies",
        "enabledWhenSelected": true
      },
      "x-forSaveAs": true,
      "x-browseTitle": "Inconsistency Report File",
      "x-fileFilterNames": "All Files (*.*)",
      "x-fileFilterExtensions": "*.*",
      "x-vertical": true
    },
    "displayOption": {
      "type": "string",
      "default": "generic",
      "title": "Representation of the inline codes in the report",
      "enum": [
        "original",
        "generic",
        "plain"
      ],
      "x-enumLabels": [
        "Original codes",
        "Generic markers",
        "Plain text"
      ],
      "x-widget": "dropdown",
      "x-enabledBy": {
        "parameter": "checkInconststencies",
        "enabledWhenSelected": true
      },
      "x-vertical": true
    },
    "autoOpen": {
      "type": "boolean",
      "default": true,
      "title": "Open the report file after completion",
      "x-widget": "checkbox",
      "x-enabledBy": {
        "parameter": "checkInconststencies",
        "enabledWhenSelected": true
      },
      "x-vertical": true
    },
    "original": {
      "type": "boolean",
      "default": false
    },
    "generic": {
      "type": "boolean",
      "default": false
    },
    "plain": {
      "type": "boolean",
      "default": false
    }
  }
}