{
  "$id": "x-m-l-validation",
  "title": "XML Validation",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.xmlvalidation.XMLValidationStep",
    "parameterMappings": [
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleRawDocument",
      "handleStartBatch"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "x-m-l-validation",
    "type": "step",
    "displayName": "XML Validation",
    "description": "Validate XML documents. Expects: raw XML document. Sends back: raw XML document.",
    "category": "pipeline",
    "requires": [
      "target-language",
      "source-language"
    ]
  },
  "properties": {
    "validationType": {
      "type": "integer",
      "default": 0,
      "title": "Type of validation",
      "description": "Indicates which validation to use",
      "enum": [
        "0",
        "1",
        "2"
      ],
      "x-enumLabels": [
        "DTD",
        "XML Schema",
        "RelaxNG Schema"
      ],
      "x-widget": "select",
      "x-enabledBy": {
        "parameter": "validate",
        "enabledWhenSelected": true
      },
      "x-vertical": true
    },
    "useFoundDTD": {
      "type": "boolean",
      "default": true,
      "title": "Use DTD declarations found in the input documents",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "validate": {
      "type": "boolean",
      "default": false,
      "title": "Validate the documents structure [Well-formedness is always checked]",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "schemaPath": {
      "type": "string",
      "default": "",
      "title": "Path of the XML Schema",
      "description": "Full path of the XML Schema.",
      "x-widget": "path",
      "x-enabledBy": {
        "parameter": "validate",
        "enabledWhenSelected": true
      },
      "x-browseTitle": "Schema",
      "x-fileFilterNames": "Schema Files (*.xsd)\tAll Files (*.*)",
      "x-fileFilterExtensions": "*.xsd\t*.*",
      "x-allowEmpty": true,
      "x-vertical": true
    }
  }
}