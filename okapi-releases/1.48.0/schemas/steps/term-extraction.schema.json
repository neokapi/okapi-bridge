{
  "$id": "term-extraction",
  "title": "Term Extraction",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.termextraction.TermExtractionStep",
    "parameterMappings": [
      "INPUT_ROOT_DIRECTORY",
      "ROOT_DIRECTORY",
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleEndBatch",
      "handleStartBatch",
      "handleTextUnit"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "term-extraction",
    "type": "step",
    "displayName": "Term Extraction",
    "description": "Extract a list of possible terms found in the source content. Expects: filter events. Sends back: filter events.",
    "category": "pipeline",
    "inputs": [
      "block"
    ],
    "requires": [
      "target-language",
      "source-language"
    ]
  },
  "properties": {
    "outputPath": {
      "type": "string",
      "default": "${rootDir}/terms.txt",
      "title": "Output path",
      "description": "Full path of the output file",
      "x-widget": "path",
      "x-forSaveAs": true,
      "x-browseTitle": "Output File to Generate",
      "x-fileFilterNames": "Text Files (*.txt)\tAll Files (*.*)",
      "x-fileFilterExtensions": "*.txt\t*.*",
      "x-vertical": true
    },
    "autoOpen": {
      "type": "boolean",
      "default": false,
      "title": "Open the result file after completion",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "minWordsPerTerm": {
      "type": "integer",
      "default": 1,
      "title": "Minimum number of words per term",
      "description": "A term will be made up at least of that many words",
      "minimum": 1,
      "maximum": 999,
      "x-widget": "spin",
      "x-enabledBy": {
        "parameter": "useStatistics",
        "enabledWhenSelected": true
      }
    },
    "maxWordsPerTerm": {
      "type": "integer",
      "default": 3,
      "title": "Maximum number of words per term",
      "description": "A term will be made up at the most of that many words",
      "minimum": 1,
      "maximum": 999,
      "x-widget": "spin",
      "x-enabledBy": {
        "parameter": "useStatistics",
        "enabledWhenSelected": true
      }
    },
    "minOccurrences": {
      "type": "integer",
      "default": 2,
      "title": "Minimum number of occurrences per term",
      "description": "A term will have at least that many occurrences",
      "minimum": 1,
      "maximum": 999,
      "x-widget": "spin",
      "x-enabledBy": {
        "parameter": "useStatistics",
        "enabledWhenSelected": true
      }
    },
    "stopWordsPath": {
      "type": "string",
      "default": "",
      "title": "Path of the file with stop words (leave empty for default)",
      "description": "Full path of the file containing stop words",
      "x-widget": "path",
      "x-enabledBy": {
        "parameter": "useStatistics",
        "enabledWhenSelected": true
      },
      "x-browseTitle": "Stop Words File",
      "x-fileFilterNames": "Text Files (*.txt)\tAll Files (*.*)",
      "x-fileFilterExtensions": "*.txt\t*.*",
      "x-allowEmpty": true,
      "x-vertical": true
    },
    "notStartWordsPath": {
      "type": "string",
      "default": "",
      "title": "Path of the file with not-start words (leave empty for default)",
      "description": "Full path of the file containing not-start words",
      "x-widget": "path",
      "x-enabledBy": {
        "parameter": "useStatistics",
        "enabledWhenSelected": true
      },
      "x-browseTitle": "Not-Start Words File",
      "x-fileFilterNames": "Text Files (*.txt)\tAll Files (*.*)",
      "x-fileFilterExtensions": "*.txt\t*.*",
      "x-allowEmpty": true,
      "x-vertical": true
    },
    "notEndWordsPath": {
      "type": "string",
      "default": "",
      "title": "Path of the file with not-end words (leave empty for default)",
      "description": "Full path of the file containing not-end words",
      "x-widget": "path",
      "x-enabledBy": {
        "parameter": "useStatistics",
        "enabledWhenSelected": true
      },
      "x-browseTitle": "Not-End Words File",
      "x-fileFilterNames": "Text Files (*.txt)\tAll Files (*.*)",
      "x-fileFilterExtensions": "*.txt\t*.*",
      "x-allowEmpty": true,
      "x-vertical": true
    },
    "keepCase": {
      "type": "boolean",
      "default": false,
      "title": "Preserve case differences",
      "x-widget": "checkbox",
      "x-enabledBy": {
        "parameter": "useStatistics",
        "enabledWhenSelected": true
      },
      "x-vertical": true
    },
    "removeSubTerms": {
      "type": "boolean",
      "default": false,
      "title": "Remove entries that seem to be sub-strings of longer entries",
      "x-widget": "checkbox",
      "x-enabledBy": {
        "parameter": "useStatistics",
        "enabledWhenSelected": true
      },
      "x-vertical": true
    },
    "sortByOccurrence": {
      "type": "boolean",
      "default": false,
      "title": "Sort the results by the number of occurrences",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "useTerminologyAnnotations": {
      "type": "boolean",
      "default": true,
      "title": "Use Terminology annotations",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "useTextAnalysisAnnotations": {
      "type": "boolean",
      "default": true,
      "title": "Use Text Analysis annotations",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "useStatistics": {
      "type": "boolean",
      "default": true,
      "title": "Use tokens-grouping statistics",
      "x-widget": "checkbox",
      "x-vertical": true
    }
  }
}