{
  "$id": "extraction-verification",
  "title": "Extraction Verification",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.common.ExtractionVerificationStep",
    "parameterMappings": [
      "FILTER_CONFIGURATION_ID",
      "FILTER_CONFIGURATION_MAPPER",
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleRawDocument"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "extraction-verification",
    "type": "step",
    "displayName": "Extraction Verification",
    "description": "Verifies a raw document can be extracted, merged, then extracted again and produces the same set of events during both extractions. Expects: raw document. Sends back: unmodified raw document.",
    "category": "validate",
    "tags": [
      "quality"
    ],
    "requires": [
      "target-language",
      "source-language"
    ]
  },
  "properties": {
    "compareSkeleton": {
      "type": "boolean",
      "default": true,
      "title": "Compare skeleton",
      "x-widget": "checkbox",
      "x-enabledBy": {
        "parameter": "stepEnabled",
        "enabledWhenSelected": true
      },
      "x-vertical": true
    },
    "stepEnabled": {
      "type": "boolean",
      "default": true,
      "title": "Perform the extraction verification",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "allEvents": {
      "type": "boolean",
      "default": true,
      "title": "Verify all events (otherwise only text units are verified)",
      "x-widget": "checkbox",
      "x-enabledBy": {
        "parameter": "stepEnabled",
        "enabledWhenSelected": true
      },
      "x-vertical": true
    },
    "limit": {
      "type": "integer",
      "default": 10,
      "title": "Maximum number of warnings per document",
      "x-widget": "text",
      "x-enabledBy": {
        "parameter": "stepEnabled",
        "enabledWhenSelected": true
      },
      "x-vertical": true
    },
    "interrupt": {
      "type": "boolean",
      "default": false,
      "title": "Interrupt after reaching the maximum number of warnings",
      "x-widget": "checkbox",
      "x-enabledBy": {
        "parameter": "stepEnabled",
        "enabledWhenSelected": true
      },
      "x-vertical": true
    },
    "monolingual": {
      "type": "boolean",
      "default": false
    }
  }
}