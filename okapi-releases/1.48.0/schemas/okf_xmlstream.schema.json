{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "XML Stream Filter Filter",
  "description": "Configuration for the Okapi XML Stream Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_xmlstream",
    "class": "net.sf.okapi.filters.xmlstream.XmlStreamFilter",
    "extensions": [
      ".dita",
      ".ditamap"
    ],
    "mimeTypes": [
      "text/xml"
    ],
    "configurations": [
      {
        "configId": "okf_xmlstream",
        "name": "XML Stream",
        "description": "Large XML Documents",
        "mimeType": "text/xml",
        "parametersLocation": "default.yml",
        "parametersRaw": "assumeWellformed: true\npreserve_whitespace: false\n\nattributes:\n  # attributes that can appear anywhere\n  'xml:lang':\n    ruleTypes: [ATTRIBUTE_WRITABLE]\n  \n  # This rule will not apply unless TEXT_UNIT element rules are defined which may have an id\n  'xml:id':\n    ruleTypes: [ATTRIBUTE_ID]\n  'id':\n    ruleTypes: [ATTRIBUTE_ID]\n  \n  'xml:space':\n    ruleTypes: [ATTRIBUTE_PRESERVE_WHITESPACE]\n    preserve: ['xml:space', EQUALS, preserve]\n    default: ['xml:space', EQUALS, default]\n",
        "parameters": {
          "assumeWellformed": true,
          "preserve_whitespace": false,
          "attributes": {
            "xml:lang": {
              "ruleTypes": [
                "ATTRIBUTE_WRITABLE"
              ]
            },
            "xml:id": {
              "ruleTypes": [
                "ATTRIBUTE_ID"
              ]
            },
            "id": {
              "ruleTypes": [
                "ATTRIBUTE_ID"
              ]
            },
            "xml:space": {
              "ruleTypes": [
                "ATTRIBUTE_PRESERVE_WHITESPACE"
              ],
              "preserve": [
                "xml:space",
                "EQUALS",
                "preserve"
              ],
              "default": [
                "xml:space",
                "EQUALS",
                "default"
              ]
            }
          }
        },
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.xmlstream.XmlStreamFilter"
      },
      {
        "configId": "okf_xmlstream-dita",
        "name": "DITA",
        "description": "DITA XML",
        "mimeType": "text/xml",
        "extensions": ".dita;.ditamap;",
        "parametersLocation": "dita.yml",
        "parametersRaw": "assumeWellformed: true\npreserve_whitespace: false\n\nattributes:\n  # attributes that can appear anywhere\n  'xml:lang':\n    ruleTypes: [ATTRIBUTE_WRITABLE]\n  \n  # This rule will not apply unless TEXT_UNIT element rules are defined which may have an id\n  'xml:id':\n    ruleTypes: [ATTRIBUTE_ID]\n  'id':\n    ruleTypes: [ATTRIBUTE_ID]\n  \n  'xml:space':\n    ruleTypes: [ATTRIBUTE_PRESERVE_WHITESPACE]\n    preserve: ['xml:space', EQUALS, preserve]\n    default: ['xml:space', EQUALS, default]\n\nelements:\n  # translatable attributes\n  othermeta:\n    ruleTypes: [ATTRIBUTES_ONLY]\n    translatableAttributes: [content]\n  \n  topicref:\n    ruleTypes: [ATTRIBUTES_ONLY]\n    translatableAttributes: [navtitle]\n  \n  topicgroup:\n    ruleTypes: [ATTRIBUTES_ONLY]\n    translatableAttributes: [navtitle]\n  \n  topichead:\n    ruleTypes: [ATTRIBUTES_ONLY]\n    translatableAttributes: [navtitle]\n    \n  note:\n    ruleTypes: [ATTRIBUTES_ONLY]\n    translatableAttributes: [othertype]\n  \n  lq:\n    ruleTypes: [ATTRIBUTES_ONLY]\n    translatableAttributes: [reftitle]\n  \n  object:\n    ruleTypes: [ATTRIBUTES_ONLY]\n    translatableAttributes: [standby]\n  \n  map:\n    ruleTypes: [ATTRIBUTES_ONLY]\n    translatableAttributes: [title]\n   \n  state:\n    ruleTypes: [ATTRIBUTES_ONLY, INLINE]\n    translatableAttributes: [value]\n\n  data:\n    ruleTypes: [ATTRIBUTES_ONLY]\n    translatableAttributes: [label]\n  \n  vrm:\n    ruleTypes: [ATTRIBUTES_ONLY]\n    translatableAttributes: [version]\n    \n  # pre-formatted elements\n  pre:\n    ruleTypes: [PRESERVE_WHITESPACE]\n  lines:\n    ruleTypes: [PRESERVE_WHITESPACE]\n  screen:\n    ruleTypes: [PRESERVE_WHITESPACE]\n  msgblock:\n    ruleTypes: [PRESERVE_WHITESPACE]\n  codeblock:\n    ruleTypes: [PRESERVE_WHITESPACE]\n\n  # exclusion rules\n  '.*':\n    ruleTypes: [EXCLUDE]\n    conditions: [translate, EQUALS, 'no']\n\n  # '.+' is a trick to have same regex as above.\n  # hashmap doesn't allow duplicates\n  '.+':\n    ruleTypes: [INCLUDE]\n    conditions: [translate, EQUALS, 'yes']\n  \n  stylesheet:\n    ruleTypes: [EXCLUDE]\n  \n  coords:\n    ruleTypes: [EXCLUDE]\n    \n  draft-comment:\n    ruleTypes: [EXCLUDE]\n    \n  required-cleanup:\n    ruleTypes: [EXCLUDE]\n    \n  shape:\n    ruleTypes: [EXCLUDE]\n    \n  # inline elements\n  alt:\n    ruleTypes: [INLINE]\n  \n  apiname:\n    ruleTypes: [INLINE]\n  \n  b:\n    ruleTypes: [INLINE]\n  \n  boolean:\n    ruleTypes: [INLINE]\n  \n  cite:\n    ruleTypes: [INLINE]\n  \n  cmdname:\n    ruleTypes: [INLINE]\n  \n  codeph:\n    ruleTypes: [INLINE]\n  \n  delim:\n    ruleTypes: [INLINE]\n  \n  filepath:\n    ruleTypes: [INLINE]\n  \n  fragref:\n    ruleTypes: [INLINE]\n  \n  i:\n    ruleTypes: [INLINE]\n  \n  image:\n    ruleTypes: [INLINE]\n    translatableAttributes: [alt]\n    conditions: [placement, NOT_EQUALS, break]\n  \n  itemgroup:\n    ruleTypes: [INLINE]\n  \n  keyword:\n    ruleTypes: [INLINE]\n  \n  kwd:\n    ruleTypes: [INLINE]\n  \n  menucascade:\n    ruleTypes: [INLINE]\n  \n  msgnum:\n    ruleTypes: [INLINE]\n  \n  msgph:\n    ruleTypes: [INLINE]\n  \n  oper:\n    ruleTypes: [INLINE]\n  \n  option:\n    ruleTypes: [INLINE]\n  \n  parmname:\n    ruleTypes: [INLINE]\n  \n  ph:\n    ruleTypes: [INLINE]\n  \n  q:\n    ruleTypes: [INLINE]\n  \n  repsep:\n    ruleTypes: [INLINE]\n  \n  sep:\n    ruleTypes: [INLINE]\n  \n  shortcut:\n    ruleTypes: [INLINE]\n\n  sub:\n    ruleTypes: [INLINE]\n  \n  sup:\n    ruleTypes: [INLINE]\n  \n  synnoteref:\n    ruleTypes: [INLINE]\n  \n  synph:\n    ruleTypes: [INLINE]\n  \n  systemoutput:\n    ruleTypes: [INLINE]\n  \n  term:\n    ruleTypes: [INLINE]\n  \n  tm:\n    ruleTypes: [INLINE]\n  \n  tt:\n    ruleTypes: [INLINE]\n  \n  u:\n    ruleTypes: [INLINE]\n  \n  uicontrol:\n    ruleTypes: [INLINE]\n  \n  userinput:\n    ruleTypes: [INLINE]\n  \n  var:\n    ruleTypes: [INLINE]\n  \n  varname:\n    ruleTypes: [INLINE]\n  \n  wintitle:\n    ruleTypes: [INLINE]\n  \n  xref:\n    ruleTypes: [INLINE]                              \n",
        "parameters": {
          "assumeWellformed": true,
          "preserve_whitespace": false,
          "attributes": {
            "xml:lang": {
              "ruleTypes": [
                "ATTRIBUTE_WRITABLE"
              ]
