      {
        "configId": "okf_xmlstream-JavaPropertiesHTML",
        "name": "Java Properties XML + HTML",
        "description": "Java Properties XML with Embedded HTML",
        "mimeType": "text/xml",
        "parametersLocation": "javaPropertiesXml.yml",
        "parametersRaw": "assumeWellformed: true\nglobal_cdata_subfilter: okf_html\npreserve_whitespace: false\n\nelements:\n  entry:\n    ruleTypes: [TEXTUNIT]\n    idAttributes: [key]\n",
        "parameters": {
          "assumeWellformed": true,
          "global_cdata_subfilter": "okf_html",
          "preserve_whitespace": false,
          "elements": {
            "entry": {
              "ruleTypes": [
                "TEXTUNIT"
              ],
              "idAttributes": [
                "key"
              ]
            }
          }
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.xmlstream.XmlStreamFilter"
      }
    ],
    "serializationFormat": "yaml"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "parser": {
      "type": "object",
      "description": "Parser behavior",
      "properties": {
        "assumeWellformed": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "assumeWellformed",
          "description": "Assume well-formed XML"
        },
        "preserveWhitespace": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "preserve_whitespace",
          "description": "Preserve whitespace"
        }
      }
    },
    "taggedConfig": {
      "type": "object"
    },
    "editorTitle": {
      "type": "string",
      "default": "Parameters Editor"
    },
    "path": {
      "type": "string"
    },
    "attributes": {
      "type": "object",
      "description": "Global attribute extraction rules — maps attribute names to their rule configuration",
      "x-widget": "attributeRulesEditor",
      "additionalProperties": {
        "$ref": "#/$defs/attributeRule"
      },
      "default": {
        "xml:lang": {
          "ruleTypes": [
            "ATTRIBUTE_WRITABLE"
          ]
        },
        "xml:id": {
          "ruleTypes": [
            "ATTRIBUTE_ID"
          ]
        },
        "id": {
          "ruleTypes": [
            "ATTRIBUTE_ID"
          ]
        },
        "xml:space": {
          "ruleTypes": [
            "ATTRIBUTE_PRESERVE_WHITESPACE"
          ],
          "preserve": [
            "xml:space",
            "EQUALS",
            "preserve"
          ],
          "default": [
            "xml:space",
            "EQUALS",
            "default"
          ]
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "elementRule": {
      "type": "object",
      "description": "Extraction rule for an HTML/XML element",
      "properties": {
        "ruleTypes": {
          "type": "array",
          "description": "Extraction rule types for this element",
          "items": {
            "type": "string",
            "enum": [
              "INLINE",
              "INLINE_EXCLUDED",
              "INLINE_INCLUDED",
              "TEXTUNIT",
              "EXCLUDE",
              "INCLUDE",
              "GROUP",
              "ATTRIBUTES_ONLY",
              "PRESERVE_WHITESPACE",
              "SCRIPT",
              "SERVER"
            ],
            "x-enumDescriptions": {
              "INLINE": "Inline element — content flows within surrounding text (e.g. <b>, <span>, <a>)",
              "INLINE_EXCLUDED": "Inline element excluded by a conditional rule",
              "INLINE_INCLUDED": "Inline element included by a conditional rule (exception to EXCLUDE)",
              "TEXTUNIT": "Text unit — extracted as a translatable segment with skeleton before/after",
              "EXCLUDE": "Excluded — element and all children are skipped during extraction",
              "INCLUDE": "Included — exception to an EXCLUDE rule, re-enables extraction inside excluded block",
              "GROUP": "Group element — structural container (e.g. <table>, <ul>, <div>)",
              "ATTRIBUTES_ONLY": "Only attributes are translatable/localizable, not the element's text content",
              "PRESERVE_WHITESPACE": "Preserve whitespace inside this element (e.g. <pre>, <code>)",
              "SCRIPT": "Script element — embedded client-side code (e.g. <script>)",
              "SERVER": "Server element — embedded server-side content (e.g. JSP, PHP, Mason tags)"
            }
          }
        },
        "elementType": {
          "type": "string",
          "description": "Semantic type hint for UI display (e.g. bold, italic, link, image, paragraph, underlined)"
        },
        "translatableAttributes": {
          "description": "Attributes to extract as translatable content (e.g. alt, title, placeholder)",
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/conditionalAttributeValue"
              }
            }
          ]
        },
        "writableLocalizableAttributes": {
          "description": "Attributes to extract as writable localizable content (e.g. href, src — locale-specific, editable)",
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/conditionalAttributeValue"
              }
            }
          ]
        },
        "readOnlyLocalizableAttributes": {
          "description": "Attributes to extract as read-only localizable content (locale-specific but not user-editable)",
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/conditionalAttributeValue"
              }
            }
          ]
        },
        "idAttributes": {
          "type": "array",
          "description": "Attributes that contain segment IDs (sets the TextUnit name)",
          "items": {
            "type": "string"
          }
        },
        "conditions": {
          "$ref": "#/$defs/conditionTuple"
        }
      },
      "required": [
        "ruleTypes"
      ],
      "additionalProperties": false
    },
    "attributeRule": {
      "type": "object",
      "description": "Global extraction rule for an HTML/XML attribute",
      "properties": {
        "ruleTypes": {
          "type": "array",
          "description": "Attribute rule types",
          "items": {
            "type": "string",
            "enum": [
              "ATTRIBUTE_TRANS",
              "ATTRIBUTE_WRITABLE",
              "ATTRIBUTE_READONLY",
              "ATTRIBUTE_ID",
              "ATTRIBUTE_PRESERVE_WHITESPACE"
            ],
            "x-enumDescriptions": {
              "ATTRIBUTE_TRANS": "Translatable — attribute content is extracted for translation",
              "ATTRIBUTE_WRITABLE": "Writable localizable — attribute is locale-specific and editable (e.g. URLs, paths)",
              "ATTRIBUTE_READONLY": "Read-only localizable — attribute is locale-specific but not user-editable",
              "ATTRIBUTE_ID": "ID — attribute value is used as the segment identifier",
              "ATTRIBUTE_PRESERVE_WHITESPACE": "Preserve whitespace — attribute controls whitespace preservation state"
            }
          }
        },
        "allElementsExcept": {
          "type": "array",
          "description": "Apply this rule to all elements except the listed ones",
          "items": {
            "type": "string"
          }
        },
        "onlyTheseElements": {
          "type": "array",
          "description": "Apply this rule only to the listed elements",
          "items": {
            "type": "string"
          }
        },
        "conditions": {
          "$ref": "#/$defs/conditionTuple"
        },
        "preserve": {
          "$ref": "#/$defs/conditionTuple",
          "description": "Condition that activates whitespace preservation (e.g. [xml:space, EQUALS, preserve])"
        },
        "default": {
          "$ref": "#/$defs/conditionTuple",
          "description": "Condition that restores default whitespace handling (e.g. [xml:space, EQUALS, default])"
        }
      },
      "required": [
        "ruleTypes"
      ],
      "additionalProperties": false
    },
    "conditionTuple": {
      "type": "array",
      "description": "Condition: [attributeName, operator, value or values]",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        {
          "type": "string",
          "description": "Attribute name to test"
        },
        {
          "type": "string",
          "enum": [
            "EQUALS",
            "NOT_EQUALS",
            "MATCHES"
          ],
          "x-enumDescriptions": {
            "EQUALS": "Case-insensitive string equality",
            "NOT_EQUALS": "Case-insensitive string inequality",
            "MATCHES": "Java regex match (must match entire attribute value)"
          }
        },
        {
          "description": "Value to compare — a single string or array of strings (OR logic for EQUALS/MATCHES, AND logic for NOT_EQUALS)",
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        }
      ]
    },
    "conditionalAttributeValue": {
      "description": "Conditional attribute extraction — null (unconditional) or condition tuple(s)",
      "oneOf": [
        {
          "type": "null",
          "description": "Extract unconditionally"
        },
        {
          "$ref": "#/$defs/conditionTuple"
        },
        {
          "type": "array",
          "description": "Multiple conditions (OR logic — extract if any condition matches)",
          "items": {
            "$ref": "#/$defs/conditionTuple"
          }
        }
      ]
    },
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules"
        },
        "mergeAdjacent": {
          "type": "boolean",
