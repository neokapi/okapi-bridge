{
  "$id": "image-modification",
  "title": "Image Modification",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.imagemodification.ImageModificationStep",
    "parameterMappings": [
      "OUTPUT_URI"
    ],
    "eventHandlers": [
      "handleRawDocument",
      "handleStartBatchItem"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "file"
  },
  "x-component": {
    "id": "image-modification",
    "type": "step",
    "displayName": "Image Modification",
    "description": "Create a modified copy of image files. Expects: image raw document. Sends back: image raw document.",
    "category": "pipeline",
    "outputs": [
      "data"
    ]
  },
  "properties": {
    "scaleWidth": {
      "type": "integer",
      "default": 50,
      "title": "Percentage of the original width",
      "description": "Width percentage (must be greater than 0.",
      "minimum": 1,
      "maximum": 1000,
      "x-widget": "spin"
    },
    "scaleHeight": {
      "type": "integer",
      "default": 50,
      "title": "Percentage of the original height",
      "description": "Height percentage (must be greater than 0.",
      "minimum": 1,
      "maximum": 1000,
      "x-widget": "spin"
    },
    "format": {
      "type": "string",
      "default": "",
      "title": "Output format",
      "description": "Format of the output files.",
      "enum": [
        "",
        "png",
        "jpg",
        "bmp",
        "gif"
      ],
      "x-enumLabels": [
        "<Same format as the original>",
        "PNG (Portable Network Graphics)",
        "JPEG (Joint Photographic Experts Group)",
        "BMP Bitmap",
        "GIF (Graphics Interchange Format)"
      ],
      "x-widget": "select",
      "x-vertical": true
    },
    "makeGray": {
      "type": "boolean",
      "default": false,
      "title": "Convert to gray scale",
      "x-widget": "checkbox",
      "x-vertical": true
    }
  }
}