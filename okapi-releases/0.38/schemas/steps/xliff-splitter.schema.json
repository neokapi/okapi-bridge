{
  "$id": "xliff-splitter",
  "title": "XLIFF Splitter",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.xliffsplitter.XliffSplitterStep",
    "parameterMappings": [
      "OUTPUT_URI"
    ],
    "eventHandlers": [
      "handleRawDocument",
      "handleStartBatch",
      "handleStartBatchItem"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "file"
  },
  "x-component": {
    "id": "xliff-splitter",
    "type": "step",
    "displayName": "XLIFF Splitter",
    "description": "Split an XLIFF document into separate files for each <file> element. Expects: raw document. Sends back: raw document.",
    "category": "pipeline",
    "outputs": [
      "data"
    ]
  },
  "properties": {
    "translation_type": {
      "type": "boolean",
      "default": false
    },
    "translation_status": {
      "type": "boolean",
      "default": false
    },
    "bigFile": {
      "type": "boolean",
      "default": false,
      "title": "Process big file",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "fileMarker": {
      "type": "string",
      "default": "_PART",
      "title": "File marker",
      "x-widget": "text",
      "x-enabledBy": {
        "parameter": "bigFile",
        "enabledWhenSelected": true
      }
    },
    "updateSDLTranslationStatus": {
      "type": "boolean",
      "default": false,
      "title": "Update the <iws:status> translation status (WorldServer-specific)",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "translationTypeValue": {
      "type": "string",
      "default": "manual_translation",
      "title": "Value for 'translation_type'",
      "description": "Value to set for the translation_type attribute.",
      "x-widget": "text",
      "x-enabledBy": {
        "parameter": "updateSDLTranslationStatus",
        "enabledWhenSelected": true
      }
    },
    "translationStatusValue": {
      "type": "string",
      "default": "finished",
      "title": "Value for 'translation_status'",
      "description": "Value to set for the translation_status attribute.",
      "x-widget": "text",
      "x-enabledBy": {
        "parameter": "updateSDLTranslationStatus",
        "enabledWhenSelected": true
      }
    }
  }
}