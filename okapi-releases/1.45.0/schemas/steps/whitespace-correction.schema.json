{
  "$id": "whitespace-correction",
  "title": "Whitespace Correction",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.whitespacecorrection.WhitespaceCorrectionStep",
    "parameterMappings": [
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleTextUnit"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "whitespace-correction",
    "type": "step",
    "displayName": "Whitespace Correction",
    "description": "Correct whitespace following segment-ending punctuation when translating from  a space-delimited language (such as English) to a non-space-delimited language (Chinese or Japanese), or vice-versa. Expects: filter events. Sends back: filter events.",
    "category": "translate",
    "inputs": [
      "block"
    ],
    "tags": [
      "translation",
      "text-processing"
    ],
    "requires": [
      "target-language",
      "source-language"
    ]
  },
  "properties": {
    "punctuation": {
      "type": "array",
      "default": "FULL_STOP,COMMA,EXCLAMATION_MARK,QUESTION_MARK"
    },
    "whitespace": {
      "type": "array",
      "default": "LINE_FEED,LINE_TABULATION,FORM_FEED,CARRIAGE_RETURN,NEXT_LINE,LINE_SEPARATOR,PARAGRAPH_SEPARATOR,CHARACTER_TABULATION,SPACE,NO_BREAK_SPACE,EN_QUAD,EM_QUAD,EN_SPACE,EM_SPACE,THREE_PER_EM_SPACE,FOUR_PER_EM_SPACER,SIX_PER_EM_SPACE,FIGURE_SPACE,PUNCUATION_SPACE,THIS_SPACE,HAIR_SPACE,NAORROW_NO_BREAK_SPACE,MEDIUM_MATHEMATICAL_SPACE,IDEOGRAPHIC_SPACE,ZERO_WIDTH_SPACE,ZERO_WIDTH_NON_BREAKING_SPACE"
    },
    "fullStop": {
      "type": "boolean",
      "default": true,
      "title": "Full Stop",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "comma": {
      "type": "boolean",
      "default": true,
      "title": "Comma",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "exclamationPoint": {
      "type": "boolean",
      "default": true,
      "title": "Exclamation Point",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "questionMark": {
      "type": "boolean",
      "default": true,
      "title": "Question Mark",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "verticalWhitespace": {
      "type": "boolean",
      "default": true,
      "title": "Vertical White Space",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "nonbreakingWhitespace": {
      "type": "boolean",
      "default": true,
      "title": "Nonbreaking Whitespace",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "horizontalTabs": {
      "type": "boolean",
      "default": true,
      "title": "Horizontal Tabs",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "space": {
      "type": "boolean",
      "default": true,
      "title": "Standard White Space",
      "x-widget": "checkbox",
      "x-vertical": true
    },
    "other": {
      "type": "boolean",
      "default": true,
      "title": "All Other Whitespace",
      "x-widget": "checkbox",
      "x-vertical": true
    }
  }
}