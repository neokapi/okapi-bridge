{
  "$id": "x-s-l-transform",
  "title": "XSL Transformation",
  "type": "object",
  "x-component": {
    "id": "x-s-l-transform",
    "type": "step",
    "displayName": "XSL Transformation",
    "description": "Apply an XSLT template to an XML document. Expects: raw XML document. Sends back: raw document."
  },
  "x-step": {
    "class": "net.sf.okapi.steps.xsltransform.XSLTransformStep",
    "parameterMappings": [
      "INPUT_RAWDOC",
      "OUTPUT_URI",
      "SECOND_INPUT_RAWDOC",
      "SOURCE_LOCALE",
      "TARGET_LOCALE",
      "THIRD_INPUT_RAWDOC"
    ],
    "eventHandlers": [
      "handleEndBatch",
      "handleRawDocument",
      "handleStartBatch",
      "handleStartBatchItem"
    ],
    "interfaces": [],
    "inputType": "raw-document",
    "outputType": "file"
  },
  "properties": {
    "xsltPath": {
      "type": "string",
      "default": ""
    },
    "paramList": {
      "type": "string",
      "default": ""
    },
    "useCustomTransformer": {
      "type": "boolean",
      "default": false
    },
    "factoryClass": {
      "type": "string",
      "default": ""
    },
    "xpathClass": {
      "type": "string",
      "default": ""
    },
    "passOnOutput": {
      "type": "boolean",
      "default": true
    }
  }
}