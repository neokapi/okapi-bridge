{
  "$id": "x-m-l-validation",
  "title": "XML Validation",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.xmlvalidation.XMLValidationStep",
    "parameterMappings": [
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleRawDocument",
      "handleStartBatch"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "x-m-l-validation",
    "type": "step",
    "displayName": "XML Validation",
    "description": "Validate XML documents. Expects: raw XML document. Sends back: raw XML document.",
    "category": "pipeline",
    "requires": [
      "target-language",
      "source-language"
    ]
  },
  "properties": {
    "schemaPath": {
      "type": "string",
      "default": "",
      "description": "Full path of the XML Schema.",
      "title": "Path of the XML Schema",
      "x-path": {
        "type": "file",
        "role": "input",
        "accepts": [
          "xsd"
        ]
      }
    },
    "validate": {
      "type": "boolean",
      "default": false,
      "title": "Validate Document Structure",
      "description": "Perform DTD, W3C, or RelaxNG schema validation in addition to the well-formedness check."
    },
    "validationType": {
      "type": "integer",
      "default": 0,
      "description": "Indicates which validation to use",
      "title": "Type of validation"
    },
    "useFoundDTD": {
      "type": "boolean",
      "default": true,
      "title": "Use DTD From Input Documents",
      "description": "Use DTD declarations found in the input documents for validation."
    }
  }
}
