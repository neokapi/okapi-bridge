{
  "$id": "patterns-checker",
  "title": "Patterns Checker",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.patternschecker.PatternsCheckerStep",
    "parameterMappings": [
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleStartBatch",
      "handleStartDocument",
      "handleStartSubDocument",
      "handleTextUnit"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "patterns-checker",
    "type": "step",
    "displayName": "Pattern (regex) Quality Check",
    "description": "Compare source and target for pattern differences. Expects: filter events. Sends back: filter events.",
    "category": "validate",
    "inputs": [
      "block"
    ],
    "tags": [
      "regex",
      "quality"
    ],
    "requires": [
      "target-language",
      "source-language"
    ]
  },
  "properties": {
    "checkPatterns": {
      "type": "boolean",
      "default": true,
      "title": "Verify that the following source patterns are translated as expected"
    },
    "patternCount": {
      "type": "integer",
      "default": 8
    },
    "usePattern0": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern0": {
      "type": "boolean",
      "default": true,
      "title": "Search in the source then compare with the target (if single-pattern is not set)"
    },
    "severityPattern0": {
      "type": "integer",
      "default": 0,
      "title": "Severity"
    },
    "sourcePattern0": {
      "type": "string",
      "default": "[\\(\\uFF08]",
      "title": "Source Pattern"
    },
    "targetPattern0": {
      "type": "string",
      "default": "[\\(\\uFF08]",
      "title": "Target Pattern"
    },
    "descPattern0": {
      "type": "string",
      "default": "Opening parenthesis",
      "title": "Description"
    },
    "usePattern1": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern1": {
      "type": "boolean",
      "default": true,
      "title": "Search in the source then compare with the target (if single-pattern is not set)"
    },
    "severityPattern1": {
      "type": "integer",
      "default": 0,
      "title": "Severity"
    },
    "sourcePattern1": {
      "type": "string",
      "default": "[\\)\\uFF09]",
      "title": "Source Pattern"
    },
    "targetPattern1": {
      "type": "string",
      "default": "[\\)\\uFF09]",
      "title": "Target Pattern"
    },
    "descPattern1": {
      "type": "string",
      "default": "Closing parenthesis",
      "title": "Description"
    },
    "usePattern2": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern2": {
      "type": "boolean",
      "default": true,
      "title": "Search in the source then compare with the target (if single-pattern is not set)"
    },
    "severityPattern2": {
      "type": "integer",
      "default": 0,
      "title": "Severity"
    },
    "sourcePattern2": {
      "type": "string",
      "default": "[\\p{Ps}\\p{Pe}&&[^\\(\\)\\uFF08\\uFF09]]",
      "title": "Source Pattern"
    },
    "targetPattern2": {
      "type": "string",
      "default": "<same>",
      "title": "Target Pattern"
    },
    "descPattern2": {
      "type": "string",
      "default": "Bracketing characters (except parentheses)",
      "title": "Description"
    },
    "usePattern3": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern3": {
      "type": "boolean",
      "default": true,
      "title": "Search in the source then compare with the target (if single-pattern is not set)"
    },
    "severityPattern3": {
      "type": "integer",
      "default": 1,
      "title": "Severity"
    },
    "sourcePattern3": {
      "type": "string",
      "default": "[\\w\\.\\-]+@[\\w\\.\\-]+",
      "title": "Source Pattern"
    },
    "targetPattern3": {
      "type": "string",
      "default": "<same>",
      "title": "Target Pattern"
    },
    "descPattern3": {
      "type": "string",
      "default": "Email addresses",
      "title": "Description"
    },
    "usePattern4": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern4": {
      "type": "boolean",
      "default": true,
      "title": "Search in the source then compare with the target (if single-pattern is not set)"
    },
    "severityPattern4": {
      "type": "integer",
      "default": 1,
      "title": "Severity"
    },
    "sourcePattern4": {
      "type": "string",
      "default": "https?:[\\w/\\.:;+\\-~\\%#\\$?=&,()]+[\\w/:;+\\-~\\%#\\$?=&,()]+|www\\.[\\w/\\.:;+\\-~\\%#\\$?=&,()]+|ftp:[\\w/\\.:;+\\-~\\%#?=&,]+",
      "title": "Source Pattern"
    },
    "targetPattern4": {
      "type": "string",
      "default": "<same>",
      "title": "Target Pattern"
    },
    "descPattern4": {
      "type": "string",
      "default": "URLs",
      "title": "Description"
    },
    "usePattern5": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern5": {
      "type": "boolean",
      "default": true,
      "title": "Search in the source then compare with the target (if single-pattern is not set)"
    },
    "severityPattern5": {
      "type": "integer",
      "default": 2,
      "title": "Severity"
    },
    "sourcePattern5": {
      "type": "string",
      "default": "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b",
      "title": "Source Pattern"
    },
    "targetPattern5": {
      "type": "string",
      "default": "<same>",
      "title": "Target Pattern"
    },
    "descPattern5": {
      "type": "string",
      "default": "IP addresses",
      "title": "Description"
    },
    "usePattern6": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern6": {
      "type": "boolean",
      "default": true,
      "title": "Search in the source then compare with the target (if single-pattern is not set)"
    },
    "severityPattern6": {
      "type": "integer",
      "default": 2,
      "title": "Severity"
    },
    "sourcePattern6": {
      "type": "string",
      "default": "%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]",
      "title": "Source Pattern"
    },
    "targetPattern6": {
      "type": "string",
      "default": "<same>",
      "title": "Target Pattern"
    },
    "descPattern6": {
      "type": "string",
      "default": "C-style printf codes",
      "title": "Description"
    },
    "usePattern7": {
      "type": "boolean",
      "default": true
    },
    "fromSourcePattern7": {
      "type": "boolean",
      "default": false,
      "title": "Search in the source then compare with the target (if single-pattern is not set)"
    },
    "severityPattern7": {
      "type": "integer",
      "default": 1,
      "title": "Severity"
    },
    "sourcePattern7": {
      "type": "string",
      "default": "<same>",
      "title": "Source Pattern"
    },
    "targetPattern7": {
      "type": "string",
      "default": "([\\p{Ll}\\p{Lu}\\p{Lt}\\p{Lo}])\\1\\1",
      "title": "Target Pattern"
    },
    "descPattern7": {
      "type": "string",
      "default": "Tripled letter",
      "title": "Description"
    }
  }
}
