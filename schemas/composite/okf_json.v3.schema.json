{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gokapi.dev/schemas/filters/okf_json.schema.json",
  "$version": "3.0.0",
  "title": "Json Filter Filter",
  "description": "Configuration for the Okapi Json Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_json",
    "class": "net.sf.okapi.filters.json.JSONFilter",
    "extensions": [],
    "mimeTypes": [
      "application/json"
    ],
    "configurations": [
      {
        "configId": "okf_json",
        "name": "JSON (JavaScript Object Notation)",
        "description": "Configuration for JSON files",
        "mimeType": "application/json",
        "extensions": ".json;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.json.JSONFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "extractIsolatedStrings": {
      "type": "boolean",
      "default": false,
      "description": "Extract string values in arrays (without keys)."
    },
    "extractAllPairs": {
      "type": "boolean",
      "default": true,
      "description": "Extract all key-value pairs for translation. When false, use extractionRules to specify which paths to extract."
    },
    "exceptions": {
      "type": "string",
      "default": "",
      "x-widget": "tagList",
      "x-placeholder": "key1,key2,key3",
      "description": "Comma-separated list of keys to exclude from extraction."
    },
    "useKeyAsName": {
      "type": "boolean",
      "default": true,
      "description": "Use JSON key as the Block (TextUnit) name for reference."
    },
    "useCodeFinder": {
      "type": "boolean",
      "default": false,
      "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)"
    },
    "useFullKeyPath": {
      "type": "boolean",
      "default": false,
      "description": "Use full path (/key1/key2) instead of immediate key as name."
    },
    "useLeadingSlashOnKeyPath": {
      "type": "boolean",
      "default": true,
      "description": "Include leading slash in key path names."
    },
    "useIdStack": {
      "type": "boolean",
      "default": false,
      "description": "Build TextUnit IDs from nested key stack."
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Inline code detection configuration",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder",
      "x-widget": "codeFinderRules",
      "x-presets": {
        "html": {
          "rules": [
            {
              "pattern": "<[^>]+>"
            }
          ],
          "sample": "Click <b>here</b> to continue"
        },
        "printf": {
          "rules": [
            {
              "pattern": "%[\\d]*[sdioxXucsfeEgGpn]"
            }
          ],
          "sample": "Hello %s, you have %d messages"
        },
        "icu": {
          "rules": [
            {
              "pattern": "\\{[^}]+\\}"
            }
          ],
          "sample": "Hello {name}, you have {count} messages"
        }
      }
    },
    "escapeForwardSlashes": {
      "type": "boolean",
      "default": true,
      "description": "Escape forward slashes in output JSON (\\/)."
    },
    "noteRules": {
      "type": "string",
      "default": "",
      "x-widget": "regexBuilder",
      "x-placeholder": "/description|/comment",
      "description": "Regex for keys whose values become translator notes."
    },
    "subfilterRules": {
      "type": "string",
      "default": ""
    },
    "extractionRules": {
      "type": "string",
      "default": "",
      "x-widget": "regexBuilder",
      "x-placeholder": "/messages/.*|/labels/.*",
      "description": "Regex pattern for JSON paths to extract. Overrides extractAllPairs when specified."
    },
    "idRules": {
      "type": "string",
      "default": "",
      "x-widget": "regexBuilder",
      "x-placeholder": "/id|/key",
      "description": "Regex for keys whose values become Block IDs (overrides useKeyAsName)."
    },
    "genericMetaRules": {
      "type": "string",
      "default": "",
      "x-widget": "regexBuilder",
      "description": "Regex for keys whose values become generic metadata."
    },
    "maxwidthRules": {
      "type": "string",
      "default": "",
      "x-widget": "regexBuilder",
      "description": "Regex for keys whose values set max width constraints."
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "additionalProperties": false,
  "x-groups": [
    {
      "id": "extraction",
      "label": "Extraction Settings",
      "description": "Control what content is extracted for translation",
      "collapsed": false,
      "fields": [
        "extractAllPairs",
        "extractionRules",
        "extractIsolatedStrings",
        "exceptions"
      ]
    },
    {
      "id": "inlineCodes",
      "label": "Inline Code Handling",
      "description": "Configure detection and handling of inline codes (placeholders, tags, etc.)",
      "collapsed": true,
      "fields": [
        "useCodeFinder",
        "codeFinderRules",
        "mergeAdjacentCodes",
        "moveLeadingAndTrailingCodesToSkeleton",
        "simplifierRules"
      ]
    },
    {
      "id": "keys",
      "label": "Key Handling",
      "description": "Configure how JSON keys are used",
      "collapsed": true,
      "fields": [
        "useKeyAsName",
        "useFullKeyPath",
        "useLeadingSlashOnKeyPath",
        "useIdStack",
        "idRules"
      ]
    },
    {
      "id": "metadata",
      "label": "Metadata Rules",
      "description": "Configure metadata extraction",
      "collapsed": true,
      "fields": [
        "noteRules",
        "genericMetaRules",
        "maxwidthRules"
      ]
    },
    {
      "id": "output",
      "label": "Output Settings",
      "description": "Configure output formatting",
      "collapsed": true,
      "fields": [
        "escapeForwardSlashes"
      ]
    }
  ],
  "x-schemaVersion": 3,
  "x-baseVersion": 7,
  "x-baseHash": "43a6d151e7be",
  "x-compositeHash": "53949ad4b2d1",
  "x-introducedInOkapi": "1.46.0"
}
