{
  "$schema": "https://gokapi.dev/schemas/editorHints.schema.json",
  "$include": [
    "_fragments/inlineCodes.fragment.json"
  ],
  "fields": {
    "extractSource": {
      "description": "Extract source text from XLIFF file."
    },
    "extractTarget": {
      "description": "Extract target text from XLIFF file."
    },
    "extractNotes": {
      "description": "Extract translator notes from XLIFF file."
    },
    "includeNotTranslated": {
      "description": "Include segments with 'not translated' state."
    },
    "includeTranslated": {
      "description": "Include segments with 'translated' state."
    },
    "includeReviewNeeded": {
      "description": "Include segments that need review."
    },
    "includeFinal": {
      "description": "Include finalized segments."
    },
    "copySource": {
      "description": "Copy source to target if target is empty."
    },
    "useApprovedOnly": {
      "description": "Only use approved translations in output."
    }
  }
}
