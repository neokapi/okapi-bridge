{
  "$schema": "https://gokapi.dev/schemas/editorHints.schema.json",
  "$include": [
    "_fragments/inlineCodes.fragment.json",
    "_fragments/whitespace.fragment.json"
  ],
  "fields": {
    "assumeWellformed": {
      "description": "Assume input HTML is well-formed XML. Faster but may fail on non-conforming HTML."
    },
    "extractOuterStrings": {
      "description": "Extract text outside of HTML body tags."
    },
    "codeFinderRules": {
      "widget": "codeFinderRules",
      "presets": {
        "entities": {
          "rules": [
            {
              "pattern": "&[a-zA-Z]+;"
            }
          ],
          "sample": "Click &amp; drag"
        },
        "placeholders": {
          "rules": [
            {
              "pattern": "\\{\\{[^}]+\\}\\}"
            }
          ],
          "sample": "Hello {{name}}"
        }
      }
    },
    "extractMetaTitle": {
      "description": "Extract content from <title> tag."
    },
    "extractMetaDescription": {
      "description": "Extract content from meta description tag."
    },
    "extractComments": {
      "description": "Extract HTML comments as notes."
    },
    "excludeElements": {
      "widget": "tagList",
      "placeholder": "script,style,code",
      "description": "Comma-separated list of elements to exclude from extraction."
    },
    "translatableAttributes": {
      "widget": "tagList",
      "placeholder": "alt,title,placeholder",
      "description": "Comma-separated list of attributes to extract for translation."
    },
    "idAttributes": {
      "widget": "tagList",
      "placeholder": "id,name",
      "description": "Comma-separated list of attributes to use as IDs."
    }
  }
}
