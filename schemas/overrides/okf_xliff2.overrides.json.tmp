{
  "$schema": "https://gokapi.dev/schemas/editorHints.schema.json",
  "fields": {
    "extractSource": {
      "description": "Extract source text from XLIFF 2.x file."
    },
    "extractTarget": {
      "description": "Extract target text from XLIFF 2.x file."
    },
    "extractNotes": {
      "description": "Extract notes from XLIFF 2.x file."
    },
    "includeInitial": {
      "description": "Include segments with 'initial' state."
    },
    "includeTranslated": {
      "description": "Include segments with 'translated' state."
    },
    "includeReviewed": {
      "description": "Include segments with 'reviewed' state."
    },
    "includeFinal": {
      "description": "Include segments with 'final' state."
    },
    "extractMetadata": {
      "description": "Extract XLIFF 2.x metadata elements."
    },
    "extractChanges": {
      "description": "Extract change tracking information."
    },
    "copySource": {
      "description": "Copy source to target if target is empty."
    },
    "useApprovedOnly": {
      "description": "Only use approved translations in output."
    },
    "preserveSegmentation": {
      "description": "Preserve original segmentation in output."
    }
  }
}
