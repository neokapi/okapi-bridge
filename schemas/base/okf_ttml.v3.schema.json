{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TTML Filter Filter",
  "description": "Configuration for the Okapi TTML Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_ttml",
    "class": "net.sf.okapi.filters.ttml.TTMLFilter",
    "extensions": [
      ".ttml"
    ],
    "mimeTypes": [
      "application/ttml+xml"
    ],
    "configurations": [
      {
        "configId": "okf_ttml",
        "name": "TTML",
        "description": "TTML Documents",
        "mimeType": "application/ttml+xml",
        "extensions": ".ttml",
        "parametersLocation": "okf_ttml.fprm",
        "parametersRaw": "#v1\ntimeFormat=HH:mm:ss.SSS\nmaxLinesPerCaption.i=2\nmaxCharsPerLine.i=47\ncjkCharsPerLine.i=18\n",
        "parameters": {
          "timeFormat": "HH:mm:ss.SSS",
          "maxLinesPerCaption": 2,
          "maxCharsPerLine": 47,
          "cjkCharsPerLine": 18
        },
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.ttml.TTMLFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "output": {
      "type": "object",
      "description": "Output settings",
      "properties": {
        "keepTimecodes": {
          "type": "boolean",
          "default": false,
          "title": "Keep timecodes",
          "x-widget": "checkbox",
          "x-flattenPath": "keepTimecodes",
          "description": "Preserve timing information"
        },
        "timeFormat": {
          "type": "string",
          "default": "",
          "title": "Time format",
          "x-widget": "text",
          "x-flattenPath": "timeFormat",
          "description": "Time code format"
        },
        "maxCharsPerLine": {
          "type": "integer",
          "default": 0,
          "title": "Max characters per line",
          "minimum": 1,
          "maximum": 9999999,
          "x-widget": "spin",
          "x-flattenPath": "maxCharsPerLine",
          "description": "Maximum characters per line"
        },
        "maxLinesPerCaption": {
          "type": "integer",
          "default": 0,
          "title": "Max lines per caption",
          "minimum": 1,
          "maximum": 9999999,
          "x-widget": "spin",
          "x-flattenPath": "maxLinesPerCaption",
          "description": "Maximum lines per caption"
        },
        "cjkCharsPerLine": {
          "type": "integer",
          "default": 0,
          "title": "Max characters per line for CJK",
          "minimum": 1,
          "maximum": 9999999,
          "x-widget": "spin",
          "x-flattenPath": "cjkCharsPerLine",
          "description": "CJK characters per line"
        },
        "splitWords": {
          "type": "boolean",
          "default": false,
          "title": "Split words so that they don't go over the char limit",
          "x-widget": "checkbox",
          "x-flattenPath": "splitWords",
          "description": "Split words at line boundaries"
        }
      }
    }
  },
  "additionalProperties": false
}