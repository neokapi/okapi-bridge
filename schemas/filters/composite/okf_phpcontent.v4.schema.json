{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_phpcontent.v4.schema.json",
  "version": 4,
  "title": "PHP Content Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_phpcontent",
    "class": "net.sf.okapi.filters.php.PHPContentFilter",
    "extensions": [
      ".php"
    ],
    "mimeTypes": [
      "application/x-php"
    ],
    "configurations": [
      {
        "configId": "okf_phpcontent",
        "name": "PHP Content Default",
        "description": "Default PHP Content configuration.",
        "mimeType": "application/x-php",
        "extensions": ".php;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.php.PHPContentFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes",
      "title": "Inline Codes",
      "description": "Pattern-based detection of inline codes (placeholders, variables, tags) within translatable text."
    },
    "extraction": {
      "type": "object",
      "title": "Extraction settings",
      "properties": {
        "useDirectives": {
          "type": "boolean",
          "default": true,
          "title": "Use localization directives",
          "x-editor": {
            "widget": "checkbox",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "useDirectives"
        },
        "extractOutsideDirectives": {
          "type": "boolean",
          "default": true,
          "title": "Extract outside the scope of the directives",
          "x-editor": {
            "widget": "checkbox",
            "enabledBy": {
              "parameter": "useDirectives",
              "enabledWhenSelected": true
            },
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "extractOutsideDirectives"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "title": "Inline Codes",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "title": "Enable Inline Code Detection",
          "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "title": "Code Finder Rules",
          "x-flattenPath": "codeFinderRules",
          "description": "Regex patterns to identify inline codes in translatable text",
          "x-editor": {
            "widget": "codeFinderRules"
          }
        },
        "mergeAdjacent": {
          "type": "boolean",
          "title": "Merge Adjacent Codes",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "title": "Move Boundary Codes",
          "description": "Move inline codes at segment boundaries to the skeleton (non-translatable)",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "title": "Simplifier Rules",
          "x-flattenPath": "simplifierRules",
          "description": "Rules for simplifying inline code representation"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "title": "Code Finder Rules",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "title": "Patterns",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "title": "Pattern",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "title": "Sample Text",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "title": "Test All Rules Together",
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "title": "Simplifier Rules",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "x-kind": "OkfPhpcontentFilterConfig",
  "x-apiVersion": "v4",
  "x-baseVersion": 6,
  "x-introducedInOkapi": "1.47.0",
  "x-baseHash": "df27521a4fed",
  "x-compositeHash": "f95ab39c0f3a"
}
