{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_txml.v1.schema.json",
  "version": 1,
  "title": "TXML Filter Filter",
  "description": "Configuration for the Okapi TXML Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_txml",
    "class": "net.sf.okapi.filters.txml.TXMLFilter",
    "extensions": [
      ".txml"
    ],
    "mimeTypes": [
      "text/xml"
    ],
    "configurations": [
      {
        "configId": "okf_txml",
        "name": "TXML",
        "description": "Wordfast Pro TXML documents",
        "mimeType": "text/xml",
        "extensions": ".txml;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.txml.TXMLFilter"
      },
      {
        "configId": "okf_txml-fillEmptyTargets",
        "name": "TXML (Fill empty targets in output)",
        "description": "Wordfast Pro TXML documents with empty targets filled on output.",
        "mimeType": "text/xml",
        "extensions": ".txml;",
        "parametersLocation": "fillEmptyTargets.fprm",
        "parametersRaw": "#v1\nallowEmptyOutputTarget.b=false\n",
        "parameters": {
          "allowEmptyOutputTarget": false
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.txml.TXMLFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "output": {
      "type": "object",
      "description": "Output settings",
      "properties": {
        "allowEmptyOutputTarget": {
          "type": "boolean",
          "default": true,
          "title": "Allow empty target segments in output",
          "x-widget": "checkbox",
          "x-flattenPath": "allowEmptyOutputTarget",
          "description": "Allow empty target in output when no translation."
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules",
          "x-widget": "codeFinderRules",
          "description": "Regex patterns to identify inline codes in translatable text"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move inline codes at segment boundaries to the skeleton (non-translatable)",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules",
          "description": "Rules for simplifying inline code representation"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "x-kind": "OkfTxmlFilterConfig",
  "x-apiVersion": "v1",
  "x-baseVersion": 1,
  "x-introducedInOkapi": "0.38",
  "x-baseHash": "229da124b281",
  "x-compositeHash": "99b94e5a28c8"
}
