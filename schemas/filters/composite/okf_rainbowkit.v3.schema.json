{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_rainbowkit.v3.schema.json",
  "version": 3,
  "title": "Rainbow Translation Kit Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_rainbowkit",
    "class": "net.sf.okapi.filters.rainbowkit.RainbowKitFilter",
