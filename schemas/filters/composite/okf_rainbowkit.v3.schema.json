        "description": "Configuration for Rainbow translation kit.",
        "mimeType": "application/x-rainbowkit",
        "extensions": ".rkm;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.rainbowkit.RainbowKitFilter"
      },
      {
        "configId": "okf_rainbowkit-package",
        "name": "Rainbow Translation Kit Package",
        "description": "Configuration for Rainbow translation kit package.",
        "mimeType": "application/x-rainbowkit-package",
        "extensions": ".rkp;",
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.rainbowkit.RainbowKitFilter"
      },
      {
        "configId": "okf_rainbowkit-noprompt",
        "name": "Rainbow Translation Kit (No prompt)",
        "description": "Configuration for Rainbow translation kit (without prompt).",
        "mimeType": "application/x-rainbowkit",
        "extensions": ".rkm;",
        "parametersLocation": "noprompt.fprm",
        "parametersRaw": "#v1\nopenManifest.b=false\n",
        "parameters": {
          "openManifest": false
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.rainbowkit.RainbowKitFilter"
      }
    ],
    "serializationFormat": "stringParameters"
