            }
          },
          "x-flattenPath": "openManifest",
          "description": "Open manifest file"
        }
      }
    }
  },
  "additionalProperties": false,
  "x-kind": "OkfRainbowkitFilterConfig",
  "x-apiVersion": "v3",
