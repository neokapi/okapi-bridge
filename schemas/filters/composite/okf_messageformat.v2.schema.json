{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_messageformat.v2.schema.json",
  "version": 2,
  "title": "Message Format Filter Filter",
  "description": "Configuration for the Okapi Message Format Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_messageformat",
    "class": "net.sf.okapi.filters.messageformat.MessageFormatFilter",
    "extensions": [],
    "mimeTypes": [
      "text/x-messageformat"
    ],
    "configurations": [
      {
        "configId": "okf_messageformat",
        "name": "ICU Message Format",
        "description": "ICU Message Format Text",
        "mimeType": "text/x-messageformat",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.messageformat.MessageFormatFilter"
      },
      {
        "configId": "okf_messageformat-json",
        "name": "ICU Message Format",
        "description": "ICU Message Format From JSON",
        "mimeType": "text/x-messageformat",
        "parametersLocation": "okf_messageformat@json.fprm",
        "parametersRaw": "#v1\naddPluralForms.b=true\nnormalize.b=true\nprettyPrint.b=false\n",
        "parameters": {
          "addPluralForms": true,
          "normalize": true,
          "prettyPrint": false,
          "useCodeFinder": false,
          "codeFinderRules.count": 0,
          "codeFinderRules.sample": "",
          "codeFinderRules.useAllRulesWhenTesting": false
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.messageformat.MessageFormatFilter"
      },
      {
        "configId": "okf_messageformat-yaml",
        "name": "ICU Message Format",
        "description": "ICU Message Format From YAML",
        "mimeType": "text/x-messageformat",
        "parametersLocation": "okf_messageformat@yaml.fprm",
        "parametersRaw": "#v1\naddPluralForms.b=true\nnormalize.b=true\nprettyPrint.b=true\n",
        "parameters": {
          "addPluralForms": true,
          "normalize": true,
          "prettyPrint": true,
          "useCodeFinder": false,
          "codeFinderRules.count": 0,
          "codeFinderRules.sample": "",
          "codeFinderRules.useAllRulesWhenTesting": false
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.messageformat.MessageFormatFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "general": {
      "type": "object",
      "description": "General settings",
      "properties": {
        "addPluralForms": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "addPluralForms",
          "description": "Add plural form variants"
        },
        "normalize": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "normalize",
          "description": "Normalize message format"
        },
        "prettyPrint": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "prettyPrint",
          "description": "Pretty-print output"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules",
          "x-widget": "codeFinderRules",
          "description": "Regex patterns to identify inline codes in translatable text"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move inline codes at segment boundaries to the skeleton (non-translatable)",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules",
          "description": "Rules for simplifying inline code representation"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "x-kind": "OkfMessageformatFilterConfig",
  "x-apiVersion": "v2",
  "x-baseVersion": 2,
  "x-introducedInOkapi": "1.47.0",
  "x-baseHash": "95e6c44e22c1",
  "x-compositeHash": "00c1917b311e"
}
