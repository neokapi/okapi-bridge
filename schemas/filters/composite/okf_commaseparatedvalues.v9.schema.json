      "type": "integer",
      "default": 1,
      "title": "Exclude leading/trailing white spaces from extracted text"
    },
    "sendColumnsMode": {
      "type": "integer",
      "default": 1,
      "title": "Extract table data"
    },
    "recordIdColumn": {
      "type": "integer",
      "default": 0,
      "title": "Record ID"
    },
