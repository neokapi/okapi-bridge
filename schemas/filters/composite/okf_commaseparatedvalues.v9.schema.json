  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes",
      "title": "Inline codes"
    },
    "format": {
      "type": "object",
      "title": "Table type",
      "properties": {
        "fieldDelimiter": {
          "type": "string",
          "default": ",",
          "x-flattenPath": "fieldDelimiter",
          "title": "Field delimiter character"
        },
        "textQualifier": {
          "type": "string",
          "default": "\"",
          "x-flattenPath": "textQualifier",
          "title": "Text qualifier character"
        },
        "escapingMode": {
          "type": "integer",
          "default": 1,
          "x-flattenPath": "escapingMode",
          "title": "Escaping mode"
        },
        "addQualifiers": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "addQualifiers",
          "title": "Add text qualifiers to output"
        },
        "removeQualifiers": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "removeQualifiers",
          "title": "Remove text qualifiers from input"
        }
      }
    },
    "columnNamesLineNum": {
      "type": "integer",
      "default": 0,
      "title": "Line with column names (0 if none)"
    },
    "valuesStartLineNum": {
      "type": "integer",
      "default": 1,
      "title": "Values start at line"
    },
    "detectColumnsMode": {
      "type": "integer",
      "default": 0,
      "title": "Number of columns"
    },
    "numColumns": {
      "type": "integer",
      "default": 2,
      "title": "Number of Columns",
      "description": "Fixed number of columns when column detection mode is set to fixed."
    },
