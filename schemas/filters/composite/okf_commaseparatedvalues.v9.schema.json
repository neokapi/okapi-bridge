        "parametersRaw": "#v1\nunescapeSource.b=false\ntrimLeading.b=false\ntrimTrailing.b=false\npreserveWS.b=true\nuseCodeFinder.b=true\ncodeFinderRules=#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false\nwrapMode.i=0\ncolumnNamesLineNum.i=0\nvaluesStartLineNum.i=2\ndetectColumnsMode.i=2\nnumColumns.i=4\nsendHeaderMode.i=0\ntrimMode.i=0\nsendColumnsMode.i=1\nsourceIdColumns=\nsourceColumns=1\ntargetColumns=4\ncommentColumns=3\ncommentSourceRefs=1\nrecordIdColumn.i=0\nsourceIdSourceRefs=\nsourceIdSuffixes=\ntargetLanguages=\ntargetSourceRefs=1\nfieldDelimiter=\t\ntextQualifier=%%%^^^$$$nonenonenone$$$^^^%%%\nremoveQualifiers.b=false\nparametersClass=net.sf.okapi.filters.table.csv.Parameters\n",
        "parameters": {
          "unescapeSource": false,
