    },
    "sourceIdSuffixes": {
      "type": "string",
      "default": "",
      "title": "ID suffix"
    },
    "sourceIdSourceRefs": {
      "type": "string",
      "default": "",
      "title": "Source column"
    },
    "targetColumns": {
      "type": "string",
      "default": "2",
      "title": "Target"
    },
    "targetSourceRefs": {
      "type": "string",
      "default": "1",
      "title": "Source column"
    },
    "targetLanguages": {
      "type": "string",
      "default": "",
      "title": "Language"
    },
    "commentColumns": {
      "type": "string",
      "default": "",
      "title": "Comment"
    },
    "commentSourceRefs": {
      "type": "string",
      "default": "",
      "title": "Source column"
    },
    "unescapeSource": {
      "type": "boolean",
      "default": true,
      "title": "Convert \\t, \\n, \\\\, \\uXXXX into characters"
    },
    "trimLeading": {
      "type": "boolean",
      "default": true,
      "title": "Trim leading spaces and tabs"
    },
    "trimTrailing": {
      "type": "boolean",
      "default": true,
      "title": "Trim trailing spaces and tabs"
