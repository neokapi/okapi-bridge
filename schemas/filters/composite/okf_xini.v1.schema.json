{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_xini.v1.schema.json",
  "version": 1,
  "title": "XINI Filter Filter",
  "description": "Configuration for the Okapi XINI Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_xini",
    "class": "net.sf.okapi.filters.xini.XINIFilter",
    "extensions": [
      ".xini"
    ],
    "mimeTypes": [
      "text/x-xini"
    ],
    "configurations": [
      {
        "configId": "okf_xini",
        "name": "XINI",
        "description": "Configuration for XINI documents from ONTRAM",
        "mimeType": "text/x-xini",
        "extensions": ".xini;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.xini.XINIFilter"
      },
      {
        "configId": "okf_xini-noOutputSegmentation",
        "name": "XINI (no output segmentation)",
        "description": "Configuration for XINI documents from ONTRAM (fields in the output are not segmented)",
        "mimeType": "text/x-xini",
        "parametersLocation": "noOutputSegmentation.fprm",
        "parametersRaw": "#v1\nuseOkapiSegmentation.b=false\n",
        "parameters": {
          "useOkapiSegmentation": false
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.xini.XINIFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "segmentation": {
      "type": "object",
      "description": "Segmentation settings",
      "properties": {
        "useOkapiSegmentation": {
          "type": "boolean",
          "default": true,
          "title": "Use Okapi segmentation for output",
          "description": "Use Okapi segmentation",
          "x-flattenPath": "useOkapiSegmentation"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules",
          "x-widget": "codeFinderRules",
          "description": "Regex patterns to identify inline codes in translatable text"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move inline codes at segment boundaries to the skeleton (non-translatable)",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules",
          "description": "Rules for simplifying inline code representation"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "x-kind": "OkfXiniFilterConfig",
  "x-apiVersion": "v1",
  "x-baseVersion": 1,
  "x-introducedInOkapi": "0.38",
  "x-baseHash": "517131e0f7be",
  "x-compositeHash": "2aa91b940e05"
}
