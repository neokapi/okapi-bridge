{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_epub.v1.schema.json",
  "version": 1,
  "title": "EPUB Filter Filter",
  "description": "Configuration for the Okapi EPUB Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_epub",
    "class": "net.sf.okapi.filters.epub.EpubFilter",
    "extensions": [
      ".epub"
    ],
    "mimeTypes": [
      "application/epub+zip"
    ],
    "configurations": [
      {
        "configId": "okf_epub",
        "name": "EPUB Files",
        "description": "Electronic Publication Files (EPUB)",
        "mimeType": "application/epub+zip",
        "extensions": ".epub;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.epub.EpubFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "identification": {
      "type": "object",
      "description": "File identification",
      "properties": {
        "fileNames": {
          "type": "string",
          "default": "*.tmx,*.xlf,*.xlff",
          "title": "File names",
          "description": "File name patterns",
          "x-widget": "text",
          "x-flattenPath": "fileNames"
        },
        "mimeType": {
          "type": "string",
          "default": "application/x-archive",
          "title": "MIME type of the filter's container format",
          "x-widget": "text",
          "x-flattenPath": "mimeType",
          "description": "MIME type for content"
        },
        "configIds": {
          "type": "string",
          "default": "okf_tmx,okf_xliff,okf_xliff",
          "title": "Filter configuration ids",
          "description": "Filter configuration IDs",
          "x-widget": "text",
          "x-flattenPath": "configIds"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules",
          "x-widget": "codeFinderRules",
          "description": "Regex patterns to identify inline codes in translatable text"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move inline codes at segment boundaries to the skeleton (non-translatable)",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules",
          "description": "Rules for simplifying inline code representation"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "x-kind": "OkfEpubFilterConfig",
  "x-apiVersion": "v1",
  "x-baseVersion": 1,
  "x-introducedInOkapi": "1.46.0",
  "x-baseHash": "24300957421b",
  "x-compositeHash": "93cd9cfd45d9"
}
