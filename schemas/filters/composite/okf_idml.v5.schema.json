{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_idml.v5.schema.json",
  "version": 5,
  "title": "IDML Filter Filter",
  "description": "Configuration for the Okapi IDML Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_idml",
    "class": "net.sf.okapi.filters.idml.IDMLFilter",
    "extensions": [
      ".idml"
    ],
    "mimeTypes": [
      "application/vnd.adobe.indesign-idml-package"
    ],
    "configurations": [
      {
        "configId": "okf_idml",
        "name": "IDML",
        "description": "Adobe InDesign IDML documents",
        "mimeType": "application/vnd.adobe.indesign-idml-package",
        "extensions": ".idml;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.idml.IDMLFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "extraction": {
      "type": "object",
      "description": "Extraction settings",
      "properties": {
        "extractNotes": {
          "type": "boolean",
          "default": false,
          "title": "Extract notes",
          "x-widget": "checkbox",
          "x-vertical": true,
          "x-flattenPath": "extractNotes",
          "description": "Extract notes/comments as translator notes"
        },
        "extractMasterSpreads": {
          "type": "boolean",
          "default": true,
          "title": "Extract master spreads",
          "x-widget": "checkbox",
          "x-vertical": true,
          "x-flattenPath": "extractMasterSpreads",
          "description": "Extract master spreads"
        },
        "extractHiddenLayers": {
          "type": "boolean",
          "default": false,
          "title": "Extract hidden layers",
          "x-widget": "checkbox",
          "x-vertical": true,
          "x-flattenPath": "extractHiddenLayers",
          "description": "Extract hidden layers"
        },
        "untagXmlStructures": {
          "type": "boolean",
          "default": true,
          "title": "Untag XML structures",
          "x-widget": "checkbox",
          "x-vertical": true,
          "x-flattenPath": "untagXmlStructures",
          "description": "Untag XML structures"
        },
        "skipDiscretionaryHyphens": {
          "type": "boolean",
          "default": false,
          "title": "Skip discretionary hyphens",
          "x-widget": "checkbox",
          "x-vertical": true,
          "x-flattenPath": "skipDiscretionaryHyphens",
          "description": "Skip discretionary hyphens"
        },
        "maxAttributeSize": {
          "type": "integer",
          "default": 4194304,
          "x-flattenPath": "maxAttributeSize",
          "description": "Maximum attribute size"
        }
      }
    },
    "formatting": {
      "type": "object",
      "description": "Formatting tolerance thresholds",
      "properties": {
        "ignoreCharacterKerning": {
          "type": "boolean",
          "default": false,
          "title": "Ignore character kerning",
          "x-widget": "checkbox",
          "x-vertical": true,
          "x-flattenPath": "ignoreCharacterKerning",
          "description": "Ignore kerning differences"
        },
        "kerningMin": {
          "type": "string",
          "default": "",
          "title": "Character kerning minimum ignorance threshold",
          "x-widget": "text",
          "x-allowEmpty": true,
          "x-vertical": true,
          "x-flattenPath": "characterKerningMinIgnoranceThreshold",
          "description": "Kerning min threshold"
        },
        "kerningMax": {
          "type": "string",
          "default": "",
          "title": "Character kerning maximum ignorance threshold",
          "x-widget": "text",
          "x-allowEmpty": true,
          "x-vertical": true,
          "x-flattenPath": "characterKerningMaxIgnoranceThreshold",
          "description": "Kerning max threshold"
        },
        "ignoreCharacterTracking": {
          "type": "boolean",
          "default": false,
          "title": "Ignore character tracking",
          "x-widget": "checkbox",
          "x-vertical": true,
          "x-flattenPath": "ignoreCharacterTracking",
          "description": "Ignore tracking differences"
        },
        "trackingMin": {
          "type": "string",
          "default": "",
          "title": "Character tracking minimum ignorance threshold",
          "x-widget": "text",
          "x-allowEmpty": true,
          "x-vertical": true,
          "x-flattenPath": "characterTrackingMinIgnoranceThreshold",
          "description": "Tracking min threshold"
        },
        "trackingMax": {
          "type": "string",
          "default": "",
          "title": "Character tracking maximum ignorance threshold",
          "x-widget": "text",
          "x-allowEmpty": true,
          "x-vertical": true,
          "x-flattenPath": "characterTrackingMaxIgnoranceThreshold",
          "description": "Tracking max threshold"
        },
        "ignoreCharacterLeading": {
          "type": "boolean",
          "default": false,
          "title": "Ignore character leading",
          "x-widget": "checkbox",
          "x-vertical": true,
          "x-flattenPath": "ignoreCharacterLeading",
          "description": "Ignore leading differences"
        },
        "leadingMin": {
          "type": "string",
          "default": "",
          "title": "Character leading minimum ignorance threshold",
          "x-widget": "text",
          "x-allowEmpty": true,
          "x-vertical": true,
          "x-flattenPath": "characterLeadingMinIgnoranceThreshold",
          "description": "Leading min threshold"
        },
        "leadingMax": {
          "type": "string",
          "default": "",
          "title": "Character leading maximum ignorance threshold",
          "x-widget": "text",
          "x-allowEmpty": true,
          "x-vertical": true,
          "x-flattenPath": "characterLeadingMaxIgnoranceThreshold",
          "description": "Leading max threshold"
        },
        "ignoreCharacterBaselineShift": {
          "type": "boolean",
          "default": false,
          "title": "Ignore character baseline shift",
          "x-widget": "checkbox",
          "x-vertical": true,
          "x-flattenPath": "ignoreCharacterBaselineShift",
          "description": "Ignore baseline shift"
        },
        "baselineShiftMin": {
          "type": "string",
          "default": "",
          "title": "Character baseline shift minimum ignorance threshold",
          "x-widget": "text",
          "x-allowEmpty": true,
          "x-vertical": true,
          "x-flattenPath": "characterBaselineShiftMinIgnoranceThreshold",
          "description": "Baseline shift min"
        },
        "baselineShiftMax": {
          "type": "string",
          "default": "",
          "title": "Character baseline shift maximum ignorance threshold",
          "x-widget": "text",
          "x-allowEmpty": true,
          "x-vertical": true,
          "x-flattenPath": "characterBaselineShiftMaxIgnoranceThreshold",
          "description": "Baseline shift max"
        }
      }
    }
  },
  "additionalProperties": false,
  "x-kind": "OkfIdmlFilterConfig",
  "x-apiVersion": "v5",
  "x-baseVersion": 8,
  "x-introducedInOkapi": "0.38",
  "x-baseHash": "1db9d0471b2a",
  "x-compositeHash": "5277789cdb6e"
}
