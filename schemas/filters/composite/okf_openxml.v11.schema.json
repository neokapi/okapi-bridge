{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_openxml.v11.schema.json",
  "version": 11,
  "title": "OpenXML Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_openxml",
    "class": "net.sf.okapi.filters.openxml.OpenXMLFilter",
    "extensions": [
      ".docx",
      ".docm",
      ".dotx",
      ".dotm",
      ".pptx",
      ".pptm",
      ".ppsx",
      ".ppsm",
      ".potx",
      ".potm",
      ".xlsx",
      ".xlsm",
      ".xltx",
      ".xltm",
      ".vsdx",
      ".vsdm"
    ],
    "mimeTypes": [
      "text/xml"
    ],
    "configurations": [
      {
        "configId": "okf_openxml",
        "name": "Microsoft Office Document",
        "description": "Microsoft Office documents (DOCX, DOCM, DOTX, DOTM, PPTX, PPTM, PPSX, PPSM, POTX, POTM, XLSX, XLSM, XLTX, XLTM, VSDX, VSDM).",
        "mimeType": "text/xml",
        "extensions": ".docx;.docm;.dotx;.dotm;.pptx;.pptm;.ppsx;.ppsm;.potx;.potm;.xlsx;.xlsm;.xltx;.xltm;.vsdx;.vsdm;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.openxml.OpenXMLFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes",
      "title": "Inline codes"
    },
    "word": {
      "type": "object",
      "title": "Word Options",
      "properties": {
        "translateHeadersFooters": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "bPreferenceTranslateWordHeadersFooters",
          "title": "Translate headers and footers",
          "description": "Extract text from headers and footers in Word documents."
        },
        "translateHidden": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceTranslateWordHidden",
          "title": "Translate hidden text"
        },
        "translateComments": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "bPreferenceTranslateComments",
          "title": "Translate comments"
        },
        "translateDocProperties": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "bPreferenceTranslateDocProperties",
          "title": "Translate document properties"
        },
        "excludeGraphicMetaData": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceTranslateWordExcludeGraphicMetaData",
          "title": "Exclude graphic metadata"
        },
        "excludeColors": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceTranslateWordExcludeColors",
          "title": "Exclude specific font colors"
        },
        "allowStyleOptimisation": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "allowWordStyleOptimisation",
          "title": "Allow style optimization"
        },
        "translateNumberingLevelText": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "translateWordNumberingLevelText",
          "title": "Translate numbering level text"
        },
        "ignoreFontColors": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "ignoreWordFontColors",
          "title": "Ignore font colors"
        },
        "fontColorsMin": {
          "type": "string",
          "default": "",
          "x-flattenPath": "wordFontColorsMinIgnoranceThreshold",
          "title": "Font color min threshold"
        },
        "fontColorsMax": {
          "type": "string",
          "default": "",
          "x-flattenPath": "wordFontColorsMaxIgnoranceThreshold",
          "title": "Font color max threshold"
        },
        "automaticallyAcceptRevisions": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "bPreferenceAutomaticallyAcceptRevisions",
          "title": "Accept revisions automatically"
        }
      }
    },
    "excel": {
      "type": "object",
      "title": "Excel Options",
      "properties": {
        "translateHidden": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceTranslateExcelHidden",
          "title": "Translate hidden cells",
          "description": "Extract text from hidden cells in Excel."
        },
        "translateSheetNames": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceTranslateExcelSheetNames",
          "title": "Translate sheet names",
          "description": "Extract sheet names in Excel workbooks."
        },
        "translateDrawings": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceTranslateExcelDrawings",
          "title": "Translate drawings",
          "description": "Extract text from shapes and drawings in Excel."
        },
        "translateDiagramData": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceTranslateExcelDiagramData",
          "title": "Translate diagram data"
        },
        "excludeColors": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceTranslateExcelExcludeColors",
          "title": "Exclude specific cell colors"
        },
        "preserveStylesInTargetColumns": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "preserveExcelStylesInTargetColumns",
          "title": "Preserve styles in target columns"
        },
        "translateCellsCopied": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "translateExcelCellsCopied",
          "title": "Translate copied cells"
        }
      }
    },
    "powerpoint": {
      "type": "object",
      "title": "PowerPoint Options",
      "properties": {
        "translateHidden": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceTranslatePowerpointHidden",
          "title": "Translate hidden slides"
        },
        "translateMasters": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "bPreferenceTranslatePowerpointMasters",
          "title": "Translate master slides",
          "description": "Extract text from slide masters in PowerPoint."
        },
        "translateNotes": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "bPreferenceTranslatePowerpointNotes",
          "title": "Translate slide notes",
          "description": "Extract speaker notes in PowerPoint presentations."
        },
        "includedSlideNumbersOnly": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferencePowerpointIncludedSlideNumbersOnly",
          "title": "Only translate specific slides"
        },
        "ignorePlaceholdersInMasters": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceIgnorePlaceholdersInPowerpointMasters",
          "title": "Ignore placeholders in masters"
        },
        "reorderNotes": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceReorderPowerpointNotes",
          "title": "Reorder notes"
        },
        "reorderCharts": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "reorderPowerpointCharts",
          "title": "Reorder charts"
        },
        "reorderComments": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "reorderPowerpointComments",
          "title": "Reorder comments"
        },
        "reorderDiagramData": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "reorderPowerpointDiagramData",
          "title": "Reorder diagram data"
        },
        "reorderDocProperties": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "reorderPowerpointDocProperties",
          "title": "Reorder doc properties"
        },
        "reorderRelationships": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "reorderPowerpointRelationships",
          "title": "Reorder relationships"
        },
        "reorderNotesAndComments": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bReorderPowerpointNotesAndComments",
          "title": "Reorder notes and comments"
        },
        "translateCharts": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "translatePowerpointCharts",
          "title": "Translate chart text"
        },
        "translateComments": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "translatePowerpointComments",
          "title": "Translate comments"
        },
        "translateDiagramData": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "translatePowerpointDiagramData",
          "title": "Translate diagram data"
        },
        "translateDocProperties": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "translatePowerpointDocProperties",
          "title": "Translate doc properties"
        }
      }
    },
    "general": {
      "type": "object",
      "title": "General Options",
      "properties": {
        "extractExternalHyperlinks": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bExtractExternalHyperlinks",
          "title": "Extract external hyperlinks"
        },
        "inExcludeMode": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "bInExcludeMode",
          "title": "Use include/exclude mode"
        },
        "inExcludeHighlightMode": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "bInExcludeHighlightMode",
          "title": "Use highlight include/exclude mode"
        },
        "addLineSeparator": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceAddLineSeparatorAsCharacter",
          "title": "Add line separator as character"
        },
        "addTabAsCharacter": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceAddTabAsCharacter",
          "title": "Add tab as character"
        },
        "aggressiveCleanup": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceAggressiveCleanup",
          "title": "Aggressive code cleanup"
        },
        "allowEmptyTargets": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceAllowEmptyTargets",
          "title": "Allow empty targets"
        },
        "ignoreSoftHyphenTag": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceIgnoreSoftHyphenTag",
          "title": "Ignore soft hyphen tags"
        },
        "replaceNoBreakHyphenTag": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "bPreferenceReplaceNoBreakHyphenTag",
          "title": "Replace no-break hyphen tags"
        },
        "lineSeparatorReplacement": {
          "type": "string",
          "default": "\n",
          "x-flattenPath": "sPreferenceLineSeparatorReplacement",
          "title": "Line separator replacement string"
        },
        "maxAttributeSize": {
          "type": "integer",
          "default": 4194304,
          "x-flattenPath": "maxAttributeSize",
          "title": "Max attribute size"
        },
        "fileType": {
          "type": "string",
          "default": "MSWORD",
          "enum": [
            "MSWORD",
            "MSEXCEL",
            "MSWORDDOCPROPERTIES",
            "MSPOWERPOINTCOMMENTS"
          ],
          "x-flattenPath": "nFileType",
          "title": "File type identifier"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "title": "Inline Codes",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "title": "Enable Inline Code Detection",
          "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "title": "Code Finder Rules",
          "x-flattenPath": "codeFinderRules",
          "x-presets": {
            "mergeFields": {
              "rules": [
                {
                  "pattern": "«[^»]+»"
                }
              ],
              "sample": "Dear «FirstName» «LastName»"
            },
            "placeholders": {
              "rules": [
                {
                  "pattern": "\\{[^}]+\\}"
                }
              ],
              "sample": "Hello {name}"
            }
          },
          "x-editor": {
            "widget": "codeFinderRules"
          }
        },
        "mergeAdjacent": {
          "type": "boolean",
          "title": "Merge Adjacent Codes",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "title": "Move Boundary Codes",
          "description": "Move inline codes at segment boundaries to the skeleton (non-translatable)",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "title": "Simplifier Rules",
          "x-flattenPath": "simplifierRules",
          "description": "Rules for simplifying inline code representation"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "title": "Code Finder Rules",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "title": "Patterns",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "title": "Pattern",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "title": "Sample Text",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "title": "Test All Rules Together",
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "title": "Simplifier Rules",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "x-kind": "OkfOpenxmlFilterConfig",
  "x-apiVersion": "v11",
  "x-baseVersion": 11,
  "x-introducedInOkapi": "1.47.0",
  "x-baseHash": "a19fddf8d21e",
  "x-compositeHash": "194608ebb952"
}
