{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_ts.v2.schema.json",
  "version": 2,
  "title": "TS Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_ts",
    "class": "net.sf.okapi.filters.ts.TsFilter",
    "extensions": [
      ".ts"
    ],
    "mimeTypes": [
      "application/x-ts"
    ],
    "configurations": [
      {
        "configId": "okf_ts",
        "name": "TS",
        "description": "Configuration for Qt TS files.",
        "mimeType": "application/x-ts",
        "extensions": ".ts;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.ts.TsFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes",
      "title": "Inline Codes",
      "description": "Pattern-based detection of inline codes (placeholders, variables, tags) within translatable text."
    },
    "output": {
      "type": "object",
      "description": "Output settings",
      "properties": {
        "escapeGT": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "escapeGT",
          "description": "Escape greater-than in output"
        },
        "decodeByteValues": {
          "type": "boolean",
          "default": false,
          "title": "Convert byte values to raw characters",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "decodeByteValues",
          "description": "Decode byte values"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based inline code detection using the defined regular expressions.",
          "x-flattenPath": "useCodeFinder",
          "title": "Has Inline Codes"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules",
          "description": "Regex patterns to identify inline codes in translatable text",
          "x-editor": {
            "widget": "codeFinderRules"
          }
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move inline codes at segment boundaries to the skeleton (non-translatable)",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules",
          "description": "Rules for simplifying inline code representation"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "x-kind": "OkfTsFilterConfig",
  "x-apiVersion": "v2",
  "x-baseVersion": 2,
  "x-introducedInOkapi": "1.47.0",
  "x-baseHash": "47a7296d0a20",
  "x-compositeHash": "8a19820971d6"
}
