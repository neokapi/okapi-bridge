{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_xliff2.v2.schema.json",
  "version": 2,
  "title": "XLIFF-2 Filter Filter",
  "description": "Configuration for the Okapi XLIFF-2 Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_xliff2",
    "class": "net.sf.okapi.filters.xliff2.XLIFF2Filter",
    "extensions": [
      ".xlf"
    ],
    "mimeTypes": [
      "application/xliff+xml"
    ],
    "configurations": [
      {
        "configId": "okf_xliff2",
        "name": "XLIFF-2",
        "description": "Configuration for XLIFF-2 documents.",
        "mimeType": "application/xliff+xml",
        "extensions": ".xlf",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.xliff2.XLIFF2Filter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "extraction": {
      "type": "object",
      "description": "Control what content is extracted",
      "properties": {
        "needsSegmentation": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "needsSegmentation",
          "description": "Apply segmentation to content"
        },
        "simplifyTags": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "simplifyTags",
          "description": "Simplify inline tags"
        }
      }
    },
    "output": {
      "type": "object",
      "description": "Output settings",
      "properties": {
        "maxValidation": {
          "type": "boolean",
          "default": true,
          "title": "Perform maximum validation when parsing",
          "x-widget": "checkbox",
          "x-flattenPath": "maxValidation",
          "description": "Maximum validation level"
        }
      }
    },
    "mergeAsParagraph": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "x-kind": "OkfXliff2FilterConfig",
  "x-apiVersion": "v2",
  "x-baseVersion": 2,
  "x-introducedInOkapi": "1.41.0",
  "x-baseHash": "c805120b5307",
  "x-compositeHash": "c805120b5307"
}
