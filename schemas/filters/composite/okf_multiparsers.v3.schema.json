{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_multiparsers.v3.schema.json",
  "version": 3,
  "title": "Multi-Parsers Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_multiparsers",
    "class": "net.sf.okapi.filters.multiparsers.MultiParsersFilter",
    "extensions": [
      ".csv"
    ],
    "mimeTypes": [
      "text/csv"
    ],
    "configurations": [
      {
        "configId": "okf_multiparsers",
        "name": "Multi-Parsers: CSV with Plain-Text",
        "description": "Configuration for CSV files with plain-text on all columns",
        "mimeType": "text/csv",
        "extensions": ".csv;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.multiparsers.MultiParsersFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "extraction": {
      "type": "object",
      "title": "CSV extraction settings",
      "properties": {
        "csvAutoDetectColumnTypes": {
          "type": "boolean",
          "default": false,
          "title": "Use auto-detection (a special row in each input file)",
          "x-editor": {
            "widget": "checkbox",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "csvAutoDetectColumnTypes"
        },
        "csvAutoDetectColumnTypesRow": {
          "type": "integer",
          "default": 2,
          "title": "Row at which the special configuration information is (first=1)",
          "minimum": 1,
          "maximum": 9999999,
          "x-editor": {
            "widget": "spin",
            "enabledBy": {
              "parameter": "csvAutoDetectColumnTypes",
              "enabledWhenSelected": true
            },
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "csvAutoDetectColumnTypesRow"
        },
        "csvFormatCols": {
          "type": "string",
          "default": "",
          "title": "Comma-separated list of the colums with non-plain-text content (e.g. '3:okf_markdown', first=0)",
          "x-editor": {
            "widget": "text",
            "enabledBy": {
              "parameter": "csvAutoDetectColumnTypes",
              "enabledWhenSelected": false
            },
            "layout": {
              "vertical": true
            },
            "text": {
              "allowEmpty": true
            }
          },
          "x-flattenPath": "csvFormatCols"
        },
        "csvNoExtractCols": {
          "type": "string",
          "default": "",
          "title": "Comma-separated list of the colums not to extract (first=0)",
          "x-editor": {
            "widget": "text",
            "enabledBy": {
              "parameter": "csvAutoDetectColumnTypes",
              "enabledWhenSelected": false
            },
            "layout": {
              "vertical": true
            },
            "text": {
              "allowEmpty": true
            }
          },
          "x-flattenPath": "csvNoExtractCols"
        },
        "csvStartingRow": {
          "type": "integer",
          "default": 1,
          "title": "Row at which the extraction starts (first=1)",
          "minimum": 1,
          "maximum": 9999999,
          "x-editor": {
            "widget": "spin",
            "enabledBy": {
              "parameter": "csvAutoDetectColumnTypes",
              "enabledWhenSelected": false
            },
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "csvStartingRow"
        }
      }
    }
  },
  "additionalProperties": false,
  "x-kind": "OkfMultiparsersFilterConfig",
  "x-apiVersion": "v3",
  "x-baseVersion": 5,
  "x-introducedInOkapi": "1.47.0",
  "x-baseHash": "68574149fa9d",
  "x-compositeHash": "68574149fa9d"
}
