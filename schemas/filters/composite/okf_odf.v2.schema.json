{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_odf.v2.schema.json",
  "version": 2,
  "title": "ODF-Content Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_odf",
    "class": "net.sf.okapi.filters.openoffice.ODFFilter",
    "extensions": [],
    "mimeTypes": [
      "text/x-odf"
    ],
    "configurations": [
      {
        "configId": "okf_odf",
        "name": "OpenDocument",
        "description": "XML OpenDocument files (e.g. use inside OpenOffice.org documents).",
        "mimeType": "text/x-odf",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.openoffice.ODFFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes",
      "title": "Inline Codes",
      "description": "Pattern-based detection of inline codes (placeholders, variables, tags) within translatable text."
    },
    "extraction": {
      "type": "object",
      "description": "Extraction settings",
      "properties": {
        "extractNotes": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "extractNotes",
          "description": "Extract the content of annotation elements as translatable text",
          "title": "Extract Notes"
        },
        "extractMetadata": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "extractMetadata",
          "description": "Extract translatable metadata from meta.xml",
          "title": "Extract Metadata"
        },
        "extractReferences": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "extractReferences",
          "description": "Extract the content of bookmark reference elements as translatable text",
          "title": "Extract References"
        },
        "encodeCharacterEntityReferenceGlyphs": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "encodeCharacterEntityReferenceGlyphs",
          "description": "Encode character entity glyphs"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules",
          "description": "Regex patterns to identify inline codes in translatable text",
          "x-editor": {
            "widget": "codeFinderRules"
          }
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move inline codes at segment boundaries to the skeleton (non-translatable)",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules",
          "description": "Rules for simplifying inline code representation"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "x-kind": "OkfOdfFilterConfig",
  "x-apiVersion": "v2",
  "x-baseVersion": 2,
  "x-introducedInOkapi": "1.46.0",
  "x-baseHash": "e2513ea212be",
  "x-compositeHash": "bcd238edff99"
}
