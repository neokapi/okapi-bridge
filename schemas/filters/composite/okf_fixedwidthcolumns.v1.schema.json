{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_fixedwidthcolumns.v1.schema.json",
  "version": 1,
  "title": "Plain Text Filter (BETA) Filter",
  "description": "Configuration for the Okapi Plain Text Filter (BETA) Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_fixedwidthcolumns",
    "class": "net.sf.okapi.filters.table.fwc.FixedWidthColumnsFilter",
    "extensions": [],
    "mimeTypes": [
      "text/csv"
    ],
    "configurations": [
      {
        "configId": "okf_table_fwc",
        "name": "Table (Fixed-Width Columns)",
        "description": "Fixed-width columns table padded with white-spaces.",
        "mimeType": "text/csv",
        "parametersLocation": "okf_table_fwc.fprm",
        "parametersRaw": "#v1\nunescapeSource.b=true\ntrimLeading.b=false\ntrimTrailing.b=false\npreserveWS.b=true\nuseCodeFinder.b=false\ncodeFinderRules=#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false\nwrapMode.i=0\ncolumnNamesLineNum.i=1\nvaluesStartLineNum.i=2\ndetectColumnsMode.i=0\nnumColumns.i=1\nsendHeaderMode.i=0\ntrimMode.i=2\nsendColumnsMode.i=2\nsourceIdColumns=\nsourceColumns=\ntargetColumns=\ncommentColumns=\ncommentSourceRefs=\nrecordIdColumn.i=0\nsourceIdSourceRefs=\nsourceIdSuffixes=\ntargetLanguages=\ntargetSourceRefs=\ncolumnStartPositions=\ncolumnEndPositions=\nparametersClass=net.sf.okapi.filters.table.fwc.Parameters\n",
        "parameters": {
          "unescapeSource": true,
          "trimLeading": true,
          "trimTrailing": true,
          "preserveWS": true,
          "useCodeFinder": false,
          "codeFinderRules": "#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false",
          "wrapMode": 0,
          "columnNamesLineNum": 1,
          "valuesStartLineNum": 2,
          "detectColumnsMode": 0,
          "numColumns": 1,
          "sendHeaderMode": 0,
          "trimMode": 2,
          "sendColumnsMode": 2,
          "sourceIdColumns": "",
          "sourceColumns": "",
          "targetColumns": "",
          "commentColumns": "",
          "commentSourceRefs": "",
          "recordIdColumn": 0,
          "sourceIdSourceRefs": "",
          "sourceIdSuffixes": "",
          "targetLanguages": "",
          "targetSourceRefs": "",
          "columnStartPositions": "",
          "columnEndPositions": ""
        },
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.table.fwc.FixedWidthColumnsFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "columns": {
      "type": "object",
      "description": "Column position settings",
      "properties": {
        "columnStartPositions": {
          "type": "string",
          "default": "",
          "x-flattenPath": "columnStartPositions",
          "description": "Column start positions"
        },
        "columnEndPositions": {
          "type": "string",
          "default": "",
          "x-flattenPath": "columnEndPositions",
          "description": "Column end positions"
        }
      }
    },
    "columnNamesLineNum": {
      "type": "integer",
      "default": 0
    },
    "valuesStartLineNum": {
      "type": "integer",
      "default": 1
    },
    "detectColumnsMode": {
      "type": "integer",
      "default": 0
    },
    "numColumns": {
      "type": "integer",
      "default": 2
    },
    "sendHeaderMode": {
      "type": "integer",
      "default": 0
    },
    "trimMode": {
      "type": "integer",
      "default": 2
    },
    "sendColumnsMode": {
      "type": "integer",
      "default": 1
    },
    "recordIdColumn": {
      "type": "integer",
      "default": 0
    },
    "sourceColumns": {
      "type": "string",
      "default": "1"
    },
    "sourceIdColumns": {
      "type": "string",
      "default": ""
    },
    "sourceIdSuffixes": {
      "type": "string",
      "default": ""
    },
    "sourceIdSourceRefs": {
      "type": "string",
      "default": ""
    },
    "targetColumns": {
      "type": "string",
      "default": "2"
    },
    "targetSourceRefs": {
      "type": "string",
      "default": "1"
    },
    "targetLanguages": {
      "type": "string",
      "default": ""
    },
    "commentColumns": {
      "type": "string",
      "default": ""
    },
    "commentSourceRefs": {
      "type": "string",
      "default": ""
    },
    "unescapeSource": {
      "type": "boolean",
      "default": true
    },
    "trimLeading": {
      "type": "boolean",
      "default": true
    },
    "trimTrailing": {
      "type": "boolean",
      "default": true
    },
    "preserveWS": {
      "type": "boolean",
      "default": true
    },
    "wrapMode": {
      "type": "string",
      "default": "NONE",
      "enum": [
        "NONE",
        "SPACES",
        "PLACEHOLDERS"
      ]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules",
          "x-widget": "codeFinderRules",
          "description": "Regex patterns to identify inline codes in translatable text"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move inline codes at segment boundaries to the skeleton (non-translatable)",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules",
          "description": "Rules for simplifying inline code representation"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "x-kind": "OkfFixedwidthcolumnsFilterConfig",
  "x-apiVersion": "v1",
  "x-baseVersion": 1,
  "x-introducedInOkapi": "0.38",
  "x-baseHash": "08353001cc9f",
  "x-compositeHash": "576c5bfea689"
}
