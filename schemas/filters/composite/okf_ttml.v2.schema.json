{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_ttml.v2.schema.json",
  "version": 2,
  "title": "TTML Filter Filter",
  "description": "Configuration for the Okapi TTML Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_ttml",
    "class": "net.sf.okapi.filters.ttml.TTMLFilter",
    "extensions": [
      ".ttml"
    ],
    "mimeTypes": [
      "application/ttml+xml"
    ],
    "configurations": [
      {
        "configId": "okf_ttml",
        "name": "TTML",
        "description": "TTML Documents",
        "mimeType": "application/ttml+xml",
        "extensions": ".ttml",
        "parametersLocation": "okf_ttml.fprm",
        "parametersRaw": "#v1\ntimeFormat=HH:mm:ss.SSS\nmaxLinesPerCaption.i=2\nmaxCharsPerLine.i=47\ncjkCharsPerLine.i=18\n",
        "parameters": {
          "timeFormat": "HH:mm:ss.SSS",
          "maxLinesPerCaption": 2,
          "maxCharsPerLine": 47,
          "cjkCharsPerLine": 18,
          "keepTimecodes": false,
          "splitWords": true,
          "writeCharAnnotations": false,
          "mergeCaptions": true,
          "useCodeFinder": true,
          "escapeBrMode": true,
          "codeFinderRules.count": 0,
          "codeFinderRules.sample": "",
          "codeFinderRules.useAllRulesWhenTesting": false
        },
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.ttml.TTMLFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "output": {
      "type": "object",
      "description": "Output settings",
      "properties": {
        "keepTimecodes": {
          "type": "boolean",
          "default": false,
          "title": "Keep timecodes",
          "x-widget": "checkbox",
          "x-flattenPath": "keepTimecodes",
          "description": "Preserve timing information"
        },
        "timeFormat": {
          "type": "string",
          "default": "HH:mm:ss.SSS",
          "title": "Time format",
          "x-widget": "text",
          "x-flattenPath": "timeFormat",
          "description": "Time code format"
        },
        "maxCharsPerLine": {
          "type": "integer",
          "default": 0,
          "title": "Max characters per line",
          "minimum": 1,
          "maximum": 9999999,
          "x-widget": "spin",
          "x-flattenPath": "maxCharsPerLine",
          "description": "Maximum characters per line"
        },
        "maxLinesPerCaption": {
          "type": "integer",
          "default": 0,
          "title": "Max lines per caption",
          "minimum": 1,
          "maximum": 9999999,
          "x-widget": "spin",
          "x-flattenPath": "maxLinesPerCaption",
          "description": "Maximum lines per caption"
        },
        "cjkCharsPerLine": {
          "type": "integer",
          "default": 0,
          "title": "Max characters per line for CJK",
          "minimum": 1,
          "maximum": 9999999,
          "x-widget": "spin",
          "x-flattenPath": "cjkCharsPerLine",
          "description": "CJK characters per line"
        },
        "splitWords": {
          "type": "boolean",
          "default": true,
          "title": "Split words so that they don't go over the char limit",
          "x-widget": "checkbox",
          "x-flattenPath": "splitWords",
          "description": "Split words at line boundaries"
        }
      }
    },
    "writeCharAnnotations": {
      "type": "boolean",
      "default": false,
      "title": "Write character limit info as annotations to xliff",
      "x-widget": "checkbox"
    },
    "mergeCaptions": {
      "type": "boolean",
      "default": true,
      "title": "Merge captions by sentence",
      "x-widget": "checkbox"
    },
    "ESCAPEBRMODE": {
      "type": "string",
      "default": "escapeBrMode"
    },
    "escapeBrMode": {
      "type": "boolean",
      "default": true,
      "title": "Automatically remove line breaks and re-add them later",
      "x-widget": "checkbox"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules",
          "x-widget": "codeFinderRules",
          "description": "Regex patterns to identify inline codes in translatable text"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move inline codes at segment boundaries to the skeleton (non-translatable)",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules",
          "description": "Rules for simplifying inline code representation"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "x-kind": "OkfTtmlFilterConfig",
  "x-apiVersion": "v2",
  "x-baseVersion": 2,
  "x-introducedInOkapi": "1.48.0",
  "x-baseHash": "e600f35c9ac5",
  "x-compositeHash": "047267256c3a"
}
