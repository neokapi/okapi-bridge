{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_fixedwidthcolumns.v10.schema.json",
  "version": 10,
  "title": "Fixed-Width Columns",
  "type": "object",
  "x-filter": {
    "id": "okf_fixedwidthcolumns",
    "class": "net.sf.okapi.filters.table.fwc.FixedWidthColumnsFilter",
    "extensions": [],
    "mimeTypes": [
      "text/csv"
    ],
    "configurations": [
      {
        "configId": "okf_table_fwc",
        "name": "Table (Fixed-Width Columns)",
        "description": "Fixed-width columns table padded with white-spaces.",
        "mimeType": "text/csv",
        "parametersLocation": "okf_table_fwc.fprm",
        "parametersRaw": "#v1\nunescapeSource.b=true\ntrimLeading.b=false\ntrimTrailing.b=false\npreserveWS.b=true\nuseCodeFinder.b=false\ncodeFinderRules=#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false\nwrapMode.i=0\ncolumnNamesLineNum.i=1\nvaluesStartLineNum.i=2\ndetectColumnsMode.i=0\nnumColumns.i=1\nsendHeaderMode.i=0\ntrimMode.i=2\nsendColumnsMode.i=2\nsourceIdColumns=\nsourceColumns=\ntargetColumns=\ncommentColumns=\ncommentSourceRefs=\nrecordIdColumn.i=0\nsourceIdSourceRefs=\nsourceIdSuffixes=\ntargetLanguages=\ntargetSourceRefs=\ncolumnStartPositions=\ncolumnEndPositions=\nparametersClass=net.sf.okapi.filters.table.fwc.Parameters\n",
        "parameters": {
          "unescapeSource": true,
          "trimLeading": true,
          "trimTrailing": true,
          "preserveWS": true,
          "useCodeFinder": false,
          "codeFinderRules": "#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false",
          "wrapMode": 0,
          "columnNamesLineNum": 1,
          "valuesStartLineNum": 2,
          "detectColumnsMode": 0,
          "numColumns": 1,
          "sendHeaderMode": 0,
          "trimMode": 2,
          "sendColumnsMode": 2,
          "sourceIdColumns": "",
          "sourceColumns": "",
          "targetColumns": "",
          "commentColumns": "",
          "commentSourceRefs": "",
          "exposeCommentsAsMetadata": false,
          "recordIdColumn": 0,
          "sourceIdSourceRefs": "",
          "sourceIdSuffixes": "",
          "targetLanguages": "",
          "targetSourceRefs": "",
          "columnStartPositions": "",
          "columnEndPositions": ""
        },
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.table.fwc.FixedWidthColumnsFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes",
      "title": "Inline codes"
    },
    "columns": {
      "type": "object",
      "title": "Column definitions",
      "properties": {
        "columnStartPositions": {
          "type": "string",
          "default": "",
          "x-flattenPath": "columnStartPositions",
          "title": "Column start positions"
        },
        "columnEndPositions": {
          "type": "string",
          "default": "",
          "x-flattenPath": "columnEndPositions",
          "title": "Column end positions"
        }
      }
    },
    "columnNamesLineNum": {
      "type": "integer",
      "default": 0,
      "title": "Line with column names (0 if none)"
    },
    "valuesStartLineNum": {
      "type": "integer",
      "default": 1,
      "title": "Values start at line"
    },
    "detectColumnsMode": {
      "type": "integer",
      "default": 0,
      "title": "Number of columns"
    },
    "numColumns": {
      "type": "integer",
      "default": 2,
      "title": "Number of Columns",
      "description": "Fixed number of columns when column detection mode is set to fixed."
    },
    "sendHeaderMode": {
      "type": "integer",
      "default": 0,
      "title": "Extract header lines"
    },
    "trimMode": {
      "type": "integer",
      "default": 2,
      "title": "Exclude leading/trailing white spaces from extracted text"
    },
    "sendColumnsMode": {
      "type": "integer",
      "default": 1,
      "title": "Extract table data"
    },
    "recordIdColumn": {
      "type": "integer",
      "default": 0,
      "title": "Record ID"
    },
    "exposeCommentsAsMetadata": {
      "type": "boolean",
      "default": false,
      "title": "Expose comments as metadata"
    },
    "sourceColumns": {
      "type": "string",
      "default": "1",
      "title": "Source"
    },
    "sourceIdColumns": {
      "type": "string",
      "default": "",
      "title": "Source ID"
    },
    "sourceIdSuffixes": {
      "type": "string",
      "default": "",
      "title": "ID suffix"
    },
    "sourceIdSourceRefs": {
      "type": "string",
      "default": "",
      "title": "Source column"
    },
    "targetColumns": {
      "type": "string",
      "default": "2",
      "title": "Target"
    },
    "targetSourceRefs": {
      "type": "string",
      "default": "1",
      "title": "Source column"
    },
    "targetLanguages": {
      "type": "string",
      "default": "",
      "title": "Language"
    },
    "commentColumns": {
      "type": "string",
      "default": "",
      "title": "Comment"
    },
    "commentSourceRefs": {
      "type": "string",
      "default": "",
      "title": "Source column"
    },
    "unescapeSource": {
      "type": "boolean",
      "default": true,
      "title": "Convert \\t, \\n, \\\\, \\uXXXX into characters"
    },
    "trimLeading": {
      "type": "boolean",
      "default": true,
      "title": "Trim leading spaces and tabs"
    },
    "trimTrailing": {
      "type": "boolean",
      "default": true,
      "title": "Trim trailing spaces and tabs"
    },
    "preserveWS": {
      "type": "boolean",
      "default": true,
      "title": "Allow trimming"
    },
    "wrapMode": {
      "type": "string",
      "default": "NONE",
      "enum": [
        "NONE",
        "SPACES",
        "PLACEHOLDERS"
      ],
      "title": "Multi-line text units"
    }
  },
  "additionalProperties": false,
  "x-groups": [
    {
      "id": "inlineCodes",
      "label": "Inline Codes",
      "fields": [
        "inlineCodes"
      ]
    },
    {
      "id": "columns",
      "label": "Column position settings",
      "fields": [
        "columns"
      ]
    }
  ],
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "title": "Inline Codes",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "title": "Enable Inline Code Detection",
          "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)",
          "x-flattenPath": "useCodeFinder",
          "x-enables": [
            "rules",
            "mergeAdjacent",
            "moveBoundaryCodes",
            "simplifierRules"
          ]
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "title": "Code Finder Rules",
          "x-flattenPath": "codeFinderRules",
          "x-enabledBy": "enabled",
          "x-widget": "codeFinder",
          "description": "Regex patterns to identify inline codes in translatable text",
          "x-editor": {
            "widget": "codeFinderRules"
          }
        },
        "mergeAdjacent": {
          "type": "boolean",
          "title": "Merge Adjacent Codes",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "title": "Move Boundary Codes",
          "description": "Move inline codes at segment boundaries to the skeleton (non-translatable)",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "title": "Simplifier Rules",
          "x-flattenPath": "simplifierRules",
          "description": "Rules for simplifying inline code representation"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "title": "Code Finder Rules",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "title": "Patterns",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "title": "Pattern",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "title": "Sample Text",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "title": "Test All Rules Together",
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "title": "Simplifier Rules",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "x-kind": "OkfFixedwidthcolumnsFilterConfig",
  "x-apiVersion": "v10",
  "x-baseVersion": 10,
  "x-introducedInOkapi": "1.47.0",
  "x-baseHash": "fd5cad7e50e4",
  "x-compositeHash": "82a65a64eb41"
}
