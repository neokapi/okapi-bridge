{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_xliff.v17.schema.json",
  "version": 17,
  "title": "XLIFF Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_xliff",
    "class": "net.sf.okapi.filters.xliff.XLIFFFilter",
    "extensions": [
      ".xlf",
      ".xlif",
      ".xliff",
      ".mxliff",
      ".mqxliff",
      ".sdlxliff"
    ],
    "mimeTypes": [
      "application/x-xliff+xml"
    ],
    "configurations": [
      {
        "configId": "okf_xliff",
        "name": "XLIFF",
        "description": "Configuration for XML Localisation Interchange File Format (XLIFF) documents.",
        "mimeType": "application/x-xliff+xml",
        "extensions": ".xlf;.xlif;.xliff;.mxliff;.mqxliff;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.xliff.XLIFFFilter"
      },
      {
        "configId": "okf_xliff-sdl",
        "name": "SDLXLIFF",
        "description": "Configuration for SDL XLIFF documents. Supports SDL specific metadata",
        "mimeType": "application/x-xliff+xml",
        "extensions": ".sdlxliff;",
        "parametersLocation": "sdl.fprm",
        "parametersRaw": "#v1\nuseCustomParser.b=true\nfactoryClass=com.ctc.wstx.stax.WstxInputFactory\nfallbackToID.b=false\nescapeGT.b=false\naddTargetLanguage.b=true\noverrideTargetLanguage.b=false\noutputSegmentationType.i=0\nignoreInputSegmentation.b=false\naddAltTrans.b=false\naddAltTransGMode.b=true\neditAltTrans.b=false\nincludeExtensions.b=true\nincludeIts.b=true\nbalanceCodes.b=true\nallowEmptyTargets.b=false\ntargetStateMode.i=0\ntargetStateValue=needs-translation\nalwaysUseSegSource.b=false\nquoteModeDefined.b=true\nquoteMode.i=0\nuseSdlXliffWriter.b=true\nsdlSegConfValue=Translated\npreserveSpaceByDefault.b=true\nskipNoMrkSegSource.b=true\nuseTranslationTargetState.b=false\n",
        "parameters": {
          "useCustomParser": true,
          "factoryClass": "com.ctc.wstx.stax.WstxInputFactory",
          "fallbackToID": false,
          "escapeGT": false,
          "addTargetLanguage": true,
          "overrideTargetLanguage": false,
          "outputSegmentationType": 0,
          "ignoreInputSegmentation": false,
          "addAltTrans": false,
          "addAltTransGMode": true,
          "editAltTrans": false,
          "includeExtensions": true,
          "includeIts": true,
          "allowEmptyTargets": false,
          "targetStateMode": 0,
          "targetStateValue": "needs-translation",
          "useTranslationTargetState": false,
          "alwaysUseSegSource": false,
          "quoteModeDefined": true,
          "quoteMode": 0,
          "useSdlXliffWriter": true,
          "preserveSpaceByDefault": true,
          "useSegsForSdlProps": false,
          "useIwsXliffWriter": false,
          "iwsBlockFinished": true,
          "iwsTransStatusValue": "finished",
          "iwsTransTypeValue": "manual_translation",
          "iwsRemoveTmOrigin": false,
          "iwsBlockLockStatus": false,
          "iwsBlockTmScore": false,
          "iwsBlockTmScoreValue": 100,
          "iwsIncludeMultipleExact": false,
          "iwsBlockMultipleExact": false,
          "inlineCdata": false,
          "skipNoMrkSegSource": true,
          "useCodeFinder": false,
          "subAsTextUnit": false,
          "alwaysAddTargets": false,
          "forceUniqueIds": false,
          "balanceCodes": true,
          "sdlSegConfValue": "Translated",
          "codeFinderRules.count": 0,
          "codeFinderRules.sample": "",
          "codeFinderRules.useAllRulesWhenTesting": false
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.xliff.XLIFFFilter"
      },
      {
        "configId": "okf_xliff-iws",
        "name": "IWSXLIFF",
        "description": "Configuration for IWS XLIFF documents. Supports IWS specific metadata",
        "mimeType": "application/x-xliff+xml",
        "extensions": ".xlf;",
        "parametersLocation": "iws.fprm",
        "parametersRaw": "#v1\nuseCustomParser.b=true\nfactoryClass=com.ctc.wstx.stax.WstxInputFactory\nfallbackToID.b=false\nescapeGT.b=false\naddTargetLanguage.b=true\noverrideTargetLanguage.b=false\noutputSegmentationType.i=0\nignoreInputSegmentation.b=false\naddAltTrans.b=false\naddAltTransGMode.b=true\neditAltTrans.b=false\nincludeExtensions.b=true\nincludeIts.b=true\nbalanceCodes.b=true\nallowEmptyTargets.b=false\ntargetStateMode.i=0\ntargetStateValue=needs-translation\nalwaysUseSegSource.b=false\nquoteModeDefined.b=true\nquoteMode.i=0\nuseSdlXliffWriter.b=false\npreserveSpaceByDefault.b=true\nuseSegsForSdlProps.b=false\nuseIwsXliffWriter.b=true\niwsBlockFinished.b=true\niwsTransStatusValue=pending\niwsTransTypeValue=manual_translation\niwsRemoveTmOrigin.b=false\niwsBlockLockStatus.b=false\niwsBlockTmScore.b=false\niwsBlockTmScoreValue=100.00\niwsIncludeMultipleExact.b=false\niwsBlockMultipleExact.b=false\ninlineCdata.b=false\nskipNoMrkSegSource.b=true\nuseCodeFinder.b=false\nsdlSegConfValue=Translated\ncodeFinderRules.count.i=0\ncodeFinderRules.sample=\ncodeFinderRules.useAllRulesWhenTesting.b=false\n",
        "parameters": {
          "useCustomParser": true,
          "factoryClass": "com.ctc.wstx.stax.WstxInputFactory",
          "fallbackToID": false,
          "escapeGT": false,
          "addTargetLanguage": true,
          "overrideTargetLanguage": false,
          "outputSegmentationType": 0,
          "ignoreInputSegmentation": false,
          "addAltTrans": false,
          "addAltTransGMode": true,
          "editAltTrans": false,
          "includeExtensions": true,
          "includeIts": true,
          "allowEmptyTargets": false,
          "targetStateMode": 0,
          "targetStateValue": "needs-translation",
          "useTranslationTargetState": true,
          "alwaysUseSegSource": false,
          "quoteModeDefined": true,
          "quoteMode": 0,
          "useSdlXliffWriter": false,
          "preserveSpaceByDefault": true,
          "useSegsForSdlProps": false,
          "useIwsXliffWriter": true,
          "iwsBlockFinished": true,
          "iwsTransStatusValue": "pending",
          "iwsTransTypeValue": "manual_translation",
          "iwsRemoveTmOrigin": false,
          "iwsBlockLockStatus": false,
          "iwsBlockTmScore": false,
          "iwsBlockTmScoreValue": 100,
          "iwsIncludeMultipleExact": false,
          "iwsBlockMultipleExact": false,
          "inlineCdata": false,
          "skipNoMrkSegSource": true,
          "useCodeFinder": false,
          "subAsTextUnit": false,
          "alwaysAddTargets": false,
          "forceUniqueIds": false,
          "balanceCodes": true,
          "sdlSegConfValue": "Translated",
          "codeFinderRules.count": 0,
          "codeFinderRules.sample": "",
          "codeFinderRules.useAllRulesWhenTesting": false
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.xliff.XLIFFFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes",
      "title": "Inline Codes",
      "description": "Pattern-based detection of inline codes (placeholders, variables, tags) within translatable text."
    },
    "extraction": {
      "type": "object",
      "title": "Control what content is extracted",
      "properties": {
        "preserveSpaceByDefault": {
          "type": "boolean",
          "default": false,
          "title": "Preserve whitespace by default",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "preserveSpaceByDefault"
        },
        "includeExtensions": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "includeExtensions",
          "title": "Include XLIFF extension elements"
        },
        "includeIts": {
          "type": "boolean",
          "default": true,
          "title": "Include ITS markup",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "includeIts"
        },
        "inlineCdata": {
          "type": "boolean",
          "default": false,
          "title": "Preserve CDATA sections",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "inlineCdata"
        },
        "subAsTextUnit": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "subAsTextUnit",
          "title": "Process sub elements as text units"
        },
        "ignoreInputSegmentation": {
          "type": "boolean",
          "default": false,
          "title": "Ignore segmentation information in input",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "ignoreInputSegmentation"
        },
        "skipNoMrkSegSource": {
          "type": "boolean",
          "default": false,
          "title": "Skip seg-sources with no marked segments",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "skipNoMrkSegSource"
        },
        "fallbackToID": {
          "type": "boolean",
          "default": false,
          "title": "Use trans-unit id for text unit name if no resname",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "fallbackToID"
        },
        "forceUniqueIds": {
          "type": "boolean",
          "default": false,
          "title": "Rewrite TU IDs to enforce uniqueness",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "forceUniqueIds"
        }
      }
    },
    "states": {
      "type": "object",
      "title": "Translation state handling",
      "properties": {
        "targetStateMode": {
          "type": "integer",
          "default": 0,
          "x-flattenPath": "targetStateMode",
          "title": "How to handle target state attribute"
        },
        "targetStateValue": {
          "type": "string",
          "default": "needs-translation",
          "x-flattenPath": "targetStateValue",
          "title": "State value to set on targets"
        },
        "useTranslationTargetState": {
          "type": "boolean",
          "default": true,
          "title": "Update state attribute of translated XLIFF",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "useTranslationTargetState"
        },
        "editAltTrans": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "editAltTrans",
          "title": "Edit alt-trans elements"
        },
        "addAltTrans": {
          "type": "boolean",
          "default": false,
          "title": "Allow addition of new <alt-trans> elements",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "addAltTrans"
        },
        "addAltTransGMode": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "addAltTransGMode",
          "title": "Alt-trans mode for group-level"
        }
      }
    },
    "output": {
      "type": "object",
      "title": "Output formatting and behavior",
      "properties": {
        "addTargetLanguage": {
          "type": "boolean",
          "default": true,
          "title": "Add target-language attribute if not present",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "addTargetLanguage"
        },
        "overrideTargetLanguage": {
          "type": "boolean",
          "default": false,
          "title": "Override target language of XLIFF document",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "overrideTargetLanguage"
        },
        "allowEmptyTargets": {
          "type": "boolean",
          "default": false,
          "title": "Allow empty <target> elements",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "allowEmptyTargets"
        },
        "alwaysAddTargets": {
          "type": "boolean",
          "default": false,
          "title": "Add <target> elements for monolingual XLIFF",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "alwaysAddTargets"
        },
        "alwaysUseSegSource": {
          "type": "boolean",
          "default": false,
          "title": "Always use seg-source content",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "alwaysUseSegSource"
        },
        "outputSegmentationType": {
          "type": "string",
          "title": "Type of output segmentation",
          "x-editor": {
            "widget": "select"
          },
          "x-options": [
            {
              "value": 0,
              "label": "Segment only if input is segmented"
            },
            {
              "value": 1,
              "label": "Always segment"
            },
            {
              "value": 2,
              "label": "Never segment"
            },
            {
              "value": 3,
              "label": "Segment regardless of input"
            }
          ],
          "x-flattenPath": "outputSegmentationType"
        }
      }
    },
    "subfilters": {
      "type": "object",
      "title": "Sub-filter configuration",
      "properties": {
        "cdataSubfilter": {
          "type": "string",
          "default": "",
          "title": "Sub-filter for CDATA content",
          "x-editor": {
            "widget": "text"
          },
          "x-flattenPath": "cdataSubfilter"
        },
        "pcdataSubfilter": {
          "type": "string",
          "default": "",
          "title": "Sub-filter for PCDATA content",
          "x-editor": {
            "widget": "text"
          },
          "x-flattenPath": "pcdataSubfilter"
        }
      }
    },
    "parser": {
      "type": "object",
      "title": "Parser settings",
      "properties": {
        "useCustomParser": {
          "type": "boolean",
          "default": true,
          "title": "Use a custom XML stream parser",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-enables": [
            "factoryClass"
          ],
          "x-flattenPath": "useCustomParser"
        },
        "factoryClass": {
          "type": "string",
          "default": "com.ctc.wstx.stax.WstxInputFactory",
          "title": "Factory class for custom XML stream parser",
          "x-editor": {
            "widget": "text"
          },
          "x-flattenPath": "factoryClass"
        }
      }
    },
    "sdl": {
      "type": "object",
      "title": "SDL XLIFF extensions",
      "properties": {
        "useSdlXliffWriter": {
          "type": "boolean",
          "default": false,
          "title": "Use SDLXLIFF Writer",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "useSdlXliffWriter"
        },
        "useSegsForSdlProps": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "useSegsForSdlProps",
          "title": "Use segments for SDL properties"
        },
        "sdlSegConfValue": {
          "type": "string",
          "default": "",
          "x-flattenPath": "sdlSegConfValue",
          "title": "SDL segment confidence value"
        },
        "sdlSegLockedValue": {
          "type": "string",
          "default": "",
          "x-flattenPath": "sdlSegLockedValue",
          "title": "SDL segment locked value"
        },
        "sdlSegOriginValue": {
          "type": "string",
          "default": "",
          "x-flattenPath": "sdlSegOriginValue",
          "title": "SDL segment origin value"
        }
      }
    },
    "iws": {
      "type": "object",
      "title": "Idiom WorldServer extensions",
      "properties": {
        "useIwsXliffWriter": {
          "type": "boolean",
          "default": false,
          "title": "Use IWSXLIFF Writer",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-enables": [
            "iwsBlockFinished",
            "iwsTransStatusValue",
            "iwsTransTypeValue",
            "iwsRemoveTmOrigin",
            "iwsBlockLockStatus",
            "iwsBlockTmScore",
            "iwsBlockTmScoreValue",
            "iwsIncludeMultipleExact",
            "iwsBlockMultipleExact"
          ],
          "x-flattenPath": "useIwsXliffWriter"
        },
        "iwsBlockFinished": {
          "type": "boolean",
          "default": true,
          "title": "Set Finished Segments as translate=\"no\"",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "iwsBlockFinished"
        },
        "iwsBlockLockStatus": {
          "type": "boolean",
          "default": false,
          "title": "Set locked Finished Segments as translate=\"no\"",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "iwsBlockLockStatus"
        },
        "iwsBlockMultipleExact": {
          "type": "boolean",
          "default": false,
          "title": "Set Finished multiple_exact segments as translate=\"no\"",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "iwsBlockMultipleExact"
        },
        "iwsBlockTmScore": {
          "type": "boolean",
          "default": false,
          "title": "Set segments with matching tm_score as translate=\"no\"",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-enables": [
            "iwsBlockTmScoreValue",
            "iwsIncludeMultipleExact"
          ],
          "x-flattenPath": "iwsBlockTmScore"
        },
        "iwsBlockTmScoreValue": {
          "type": "string",
          "default": "100.00",
          "title": "Value of tm_score to match",
          "x-editor": {
            "widget": "text"
          },
          "x-flattenPath": "iwsBlockTmScoreValue"
        },
        "iwsIncludeMultipleExact": {
          "type": "boolean",
          "default": false,
          "title": "Include segments with multiple_exact regardless of tm_score",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "iwsIncludeMultipleExact"
        },
        "iwsRemoveTmOrigin": {
          "type": "boolean",
          "default": false,
          "title": "Remove tm_origin attribute",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "iwsRemoveTmOrigin"
        },
        "iwsTransStatusValue": {
          "type": "string",
          "default": "finished",
          "title": "Default translation_status value",
          "x-editor": {
            "widget": "text"
          },
          "x-flattenPath": "iwsTransStatusValue"
        },
        "iwsTransTypeValue": {
          "type": "string",
          "default": "manual_translation",
          "title": "Default translation_type value",
          "x-editor": {
            "widget": "text"
          },
          "x-flattenPath": "iwsTransTypeValue"
        }
      }
    }
  },
  "additionalProperties": false,
  "x-groups": [
    {
      "id": "inlineCodes",
      "label": "Inline Codes",
      "fields": [
