{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_pdf.v1.schema.json",
  "version": 1,
  "title": "PDF Filter Filter",
  "description": "Configuration for the Okapi PDF Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_pdf",
    "class": "net.sf.okapi.filters.pdf.PdfFilter",
    "extensions": [
      ".pdf"
    ],
    "mimeTypes": [
      "application/pdf"
    ],
    "configurations": [
      {
        "configId": "okf_pdf",
        "name": "PDF (Portable Document Format)",
        "description": "Configuration for PDF documents",
        "mimeType": "application/pdf",
        "extensions": ".pdf;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.pdf.PdfFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "whitespace": {
      "$ref": "#/$defs/whitespace"
    },
    "parser": {
      "type": "object",
      "description": "Parser settings",
      "properties": {
        "preserveWhitespace": {
          "type": "boolean",
          "default": false,
          "title": "Preserve whitespace",
          "x-widget": "checkbox",
          "x-flattenPath": "preserveWhitespace",
          "description": "Preserve original whitespace in extracted text"
        },
        "indentThreshold": {
          "type": "string",
          "default": "2.0",
          "title": "Amount of indent needed to define a new paragraph (Default=2.0)",
          "x-widget": "text",
          "x-flattenPath": "indentThreshold",
          "description": "Indent detection threshold"
        },
        "spacingTolerance": {
          "type": "string",
          "default": "0.5",
          "title": "Amount of spacing needed to define a white space character (Default=0.5)",
          "x-widget": "text",
          "x-flattenPath": "spacingTolerance",
          "description": "Spacing tolerance"
        }
      }
    },
    "output": {
      "type": "object",
      "description": "Output formatting",
      "properties": {
        "lineSeparator": {
          "type": "string",
          "default": "\n",
          "title": "Character to use as line separator",
          "x-widget": "text",
          "x-flattenPath": "lineSeparator",
          "description": "Line separator character"
        },
        "paragraphSeparator": {
          "type": "string",
          "default": "\n",
          "title": "Character to use as paragraph separator",
          "x-widget": "text",
          "x-flattenPath": "paragraphSeparator",
          "description": "Paragraph separator"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules",
          "x-widget": "codeFinderRules",
          "description": "Regex patterns to identify inline codes in translatable text"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move inline codes at segment boundaries to the skeleton (non-translatable)",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules",
          "description": "Rules for simplifying inline code representation"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    },
    "whitespace": {
      "type": "object",
      "description": "Whitespace handling",
      "properties": {
        "preserve": {
          "type": "boolean",
          "description": "Preserve original whitespace in extracted text",
          "x-flattenPath": "preserveWhitespace"
        },
        "collapse": {
          "type": "boolean",
          "description": "Collapse multiple whitespace characters into single spaces",
          "x-flattenPath": "collapseWhitespace"
        },
        "trimLeading": {
          "type": "boolean",
          "description": "Remove leading whitespace from text segments",
          "x-flattenPath": "trimLeadingWS"
        },
        "trimTrailing": {
          "type": "boolean",
          "description": "Remove trailing whitespace from text segments",
          "x-flattenPath": "trimTrailingWS"
        }
      }
    }
  },
  "x-kind": "OkfPdfFilterConfig",
  "x-apiVersion": "v1",
  "x-baseVersion": 1,
  "x-introducedInOkapi": "0.38",
  "x-baseHash": "eb43f4796445",
  "x-compositeHash": "79eef6877c73"
}
