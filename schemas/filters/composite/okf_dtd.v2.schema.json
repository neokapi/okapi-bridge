{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_dtd.v2.schema.json",
  "version": 2,
  "title": "DTD Filter Filter",
  "description": "Configuration for the Okapi DTD Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_dtd",
    "class": "net.sf.okapi.filters.dtd.DTDFilter",
    "extensions": [
      ".dtd",
      ".ent"
    ],
    "mimeTypes": [
      "application/xml+dtd"
    ],
    "configurations": [
      {
        "configId": "okf_dtd",
        "name": "DTD (Document Type Definition)",
        "description": "Configuration for XML DTD documents (entities content)",
        "mimeType": "application/xml+dtd",
        "extensions": ".dtd;.ent;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.dtd.DTDFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "useCodeFinder": {
      "type": "boolean",
      "default": true,
      "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "additionalProperties": false,
  "x-kind": "OkfDtdFilterConfig",
  "x-apiVersion": "v2",
  "x-baseVersion": 2,
  "x-introducedInOkapi": "1.46.0",
  "x-baseHash": "62477613e4ba",
  "x-compositeHash": "4374bcef0633"
}
