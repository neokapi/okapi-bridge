{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_idml.v6.schema.json",
  "version": 6,
  "title": "IDML Filter Filter",
  "description": "Configuration for the Okapi IDML Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_idml",
    "class": "net.sf.okapi.filters.idml.IDMLFilter",
    "extensions": [
      ".idml"
    ],
    "mimeTypes": [
      "application/vnd.adobe.indesign-idml-package"
    ],
    "configurations": [
      {
        "configId": "okf_idml",
        "name": "IDML",
        "description": "Adobe InDesign IDML documents",
        "mimeType": "application/vnd.adobe.indesign-idml-package",
        "extensions": ".idml;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.idml.IDMLFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "extraction": {
      "type": "object",
      "description": "Extraction settings",
      "properties": {
        "extractNotes": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "extractNotes",
          "description": "Extract notes/comments as translator notes"
        },
        "extractMasterSpreads": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "extractMasterSpreads",
          "description": "Extract master spreads"
        },
        "extractCustomTextVariables": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "extractCustomTextVariables",
          "description": "Extract custom text variables"
        },
        "extractExternalHyperlinks": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "extractExternalHyperlinks",
          "description": "Extract external hyperlinks"
        },
        "extractHiddenLayers": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "extractHiddenLayers",
          "description": "Extract hidden layers"
        },
        "extractHiddenPasteboardItems": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "extractHiddenPasteboardItems",
          "description": "Extract hidden pasteboard items"
        },
        "extractHyperlinkTextSourcesInline": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "extractHyperlinkTextSourcesInline",
          "description": "Extract hyperlink text inline"
        },
        "extractIndexTopics": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "extractIndexTopics",
          "description": "Extract index topics"
        },
        "extractBreaksInline": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "extractBreaksInline",
          "description": "Extract breaks inline"
        },
        "untagXmlStructures": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "untagXmlStructures",
          "description": "Untag XML structures"
        },
        "skipDiscretionaryHyphens": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "skipDiscretionaryHyphens",
          "description": "Skip discretionary hyphens"
        },
        "specialCharacterPattern": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "specialCharacterPattern",
          "description": "Special character pattern"
        },
        "maxAttributeSize": {
          "type": "integer",
          "default": 4194304,
          "x-flattenPath": "maxAttributeSize",
          "description": "Maximum attribute size"
        }
      }
    },
    "formatting": {
      "type": "object",
      "description": "Formatting tolerance thresholds",
      "properties": {
        "ignoreCharacterKerning": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "ignoreCharacterKerning",
          "description": "Ignore kerning differences"
        },
        "kerningMin": {
          "type": "string",
          "default": "",
          "x-flattenPath": "characterKerningMinIgnoranceThreshold",
          "description": "Kerning min threshold"
        },
        "kerningMax": {
          "type": "string",
          "default": "",
          "x-flattenPath": "characterKerningMaxIgnoranceThreshold",
          "description": "Kerning max threshold"
        },
        "ignoreCharacterTracking": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "ignoreCharacterTracking",
          "description": "Ignore tracking differences"
        },
        "trackingMin": {
          "type": "string",
          "default": "",
          "x-flattenPath": "characterTrackingMinIgnoranceThreshold",
          "description": "Tracking min threshold"
        },
        "trackingMax": {
          "type": "string",
          "default": "",
          "x-flattenPath": "characterTrackingMaxIgnoranceThreshold",
          "description": "Tracking max threshold"
        },
        "ignoreCharacterLeading": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "ignoreCharacterLeading",
          "description": "Ignore leading differences"
        },
        "leadingMin": {
          "type": "string",
          "default": "",
          "x-flattenPath": "characterLeadingMinIgnoranceThreshold",
          "description": "Leading min threshold"
        },
        "leadingMax": {
          "type": "string",
          "default": "",
          "x-flattenPath": "characterLeadingMaxIgnoranceThreshold",
          "description": "Leading max threshold"
        },
        "ignoreCharacterBaselineShift": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "ignoreCharacterBaselineShift",
          "description": "Ignore baseline shift"
        },
        "baselineShiftMin": {
          "type": "string",
          "default": "",
          "x-flattenPath": "characterBaselineShiftMinIgnoranceThreshold",
          "description": "Baseline shift min"
        },
        "baselineShiftMax": {
          "type": "string",
          "default": "",
          "x-flattenPath": "characterBaselineShiftMaxIgnoranceThreshold",
          "description": "Baseline shift max"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules",
          "x-widget": "codeFinderRules",
          "description": "Regex patterns to identify inline codes in translatable text"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move inline codes at segment boundaries to the skeleton (non-translatable)",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules",
          "description": "Rules for simplifying inline code representation"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "x-kind": "OkfIdmlFilterConfig",
  "x-apiVersion": "v6",
  "x-baseVersion": 6,
  "x-introducedInOkapi": "1.46.0",
  "x-baseHash": "e52b969cb7fb",
  "x-compositeHash": "173115ecf640"
}
