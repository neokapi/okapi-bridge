{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TS Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_ts",
    "class": "net.sf.okapi.filters.ts.TsFilter",
    "extensions": [
      ".ts"
    ],
    "mimeTypes": [
      "application/x-ts"
    ],
    "configurations": [
      {
        "configId": "okf_ts",
        "name": "TS",
        "description": "Configuration for Qt TS files.",
        "mimeType": "application/x-ts",
        "extensions": ".ts;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.ts.TsFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "output": {
      "type": "object",
      "title": "Output settings",
      "properties": {
        "escapeGT": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "escapeGT",
          "title": "Escape greater-than in output"
        },
        "decodeByteValues": {
          "type": "boolean",
          "default": false,
          "title": "Convert byte values to raw characters",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "decodeByteValues"
        }
      }
    }
  },
  "additionalProperties": false,
  "x-groups": [
    {
      "id": "inlineCodes",
      "label": "Inline Codes",
      "fields": [
        "inlineCodes"
      ]
    },
    {
      "id": "output",
      "label": "Output settings",
      "fields": [
        "output"
      ]
    }
  ],
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "title": "Inline Codes",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "title": "Enable Inline Code Detection",
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder",
          "x-enables": [
            "rules",
            "mergeAdjacent",
            "moveBoundaryCodes",
            "simplifierRules"
          ]
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "title": "Code Finder Rules",
          "x-flattenPath": "codeFinderRules",
          "x-enabledBy": "enabled"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "title": "Merge Adjacent Codes",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "title": "Move Boundary Codes",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "title": "Simplifier Rules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "title": "Code Finder Rules",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "title": "Patterns",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "title": "Pattern",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "title": "Sample Text",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "title": "Test All Rules Together",
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "title": "Simplifier Rules",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}