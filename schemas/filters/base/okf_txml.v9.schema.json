{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TXML Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_txml",
    "class": "net.sf.okapi.filters.txml.TXMLFilter",
    "extensions": [
      ".txml"
    ],
    "mimeTypes": [
      "text/xml"
    ],
    "configurations": [
      {
        "configId": "okf_txml",
        "name": "TXML",
        "description": "Wordfast Pro TXML documents",
        "mimeType": "text/xml",
        "extensions": ".txml;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.txml.TXMLFilter"
      },
      {
        "configId": "okf_txml-fillEmptyTargets",
        "name": "TXML (Fill empty targets in output)",
        "description": "Wordfast Pro TXML documents with empty targets filled on output.",
        "mimeType": "text/xml",
        "extensions": ".txml;",
        "parametersLocation": "fillEmptyTargets.fprm",
        "parametersRaw": "#v1\nallowEmptyOutputTarget.b=false\n",
        "parameters": {
          "allowEmptyOutputTarget": false
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.txml.TXMLFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "output": {
      "type": "object",
      "title": "Output settings",
      "properties": {
        "allowEmptyOutputTarget": {
          "type": "boolean",
          "default": true,
          "title": "Allow empty target segments in output",
          "x-editor": {
            "widget": "checkbox",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "allowEmptyOutputTarget"
        }
      }
    }
  },
  "additionalProperties": false,
  "x-groups": [
    {
      "id": "inlineCodes",
      "label": "Inline Codes",
      "fields": [
        "inlineCodes"
      ]
    },
    {
      "id": "output",
      "label": "Output settings",
      "fields": [
        "output"
      ]
    }
  ],
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "title": "Inline Codes",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "title": "Enable Inline Code Detection",
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder",
          "x-enables": [
            "rules",
            "mergeAdjacent",
            "moveBoundaryCodes",
            "simplifierRules"
          ]
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "title": "Code Finder Rules",
          "x-flattenPath": "codeFinderRules",
          "x-enabledBy": "enabled"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "title": "Merge Adjacent Codes",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "title": "Move Boundary Codes",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "title": "Simplifier Rules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "title": "Code Finder Rules",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "title": "Patterns",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "title": "Pattern",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "title": "Sample Text",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "title": "Test All Rules Together",
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "title": "Simplifier Rules",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}