{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "XLIFF Filter Filter",
  "description": "Configuration for the Okapi XLIFF Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_xliff",
    "class": "net.sf.okapi.filters.xliff.XLIFFFilter",
    "extensions": [
      ".xlf",
      ".xliff",
      ".mxliff",
      ".mqxliff",
      ".sdlxliff"
    ],
    "mimeTypes": [
      "application/x-xliff+xml"
    ],
    "configurations": [
      {
        "configId": "okf_xliff",
        "name": "XLIFF",
        "description": "Configuration for XML Localisation Interchange File Format (XLIFF) documents.",
        "mimeType": "application/x-xliff+xml",
        "extensions": ".xlf;.xliff;.mxliff;.mqxliff;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.xliff.XLIFFFilter"
      },
      {
        "configId": "okf_xliff-sdl",
        "name": "SDLXLIFF",
        "description": "Configuration for SDL XLIFF documents. Supports SDL specific metadata",
        "mimeType": "application/x-xliff+xml",
        "extensions": ".sdlxliff;",
        "parametersLocation": "sdl.fprm",
        "parametersRaw": "#v1\nuseCustomParser.b=true\nfactoryClass=com.ctc.wstx.stax.WstxInputFactory\nfallbackToID.b=false\nescapeGT.b=false\naddTargetLanguage.b=true\noverrideTargetLanguage.b=false\noutputSegmentationType.i=0\nignoreInputSegmentation.b=false\naddAltTrans.b=false\naddAltTransGMode.b=true\neditAltTrans.b=false\nincludeExtensions.b=true\nincludeIts.b=true\nbalanceCodes.b=true\nallowEmptyTargets.b=false\ntargetStateMode.i=0\ntargetStateValue=needs-translation\nalwaysUseSegSource.b=false\nquoteModeDefined.b=true\nquoteMode.i=0\nuseSdlXliffWriter.b=true\nsdlSegConfValue=Translated\npreserveSpaceByDefault.b=true\nskipNoMrkSegSource.b=true\n",
        "parameters": {
          "useCustomParser": true,
          "factoryClass": "com.ctc.wstx.stax.WstxInputFactory",
          "fallbackToID": false,
          "escapeGT": false,
          "addTargetLanguage": true,
          "overrideTargetLanguage": false,
          "outputSegmentationType": 0,
          "ignoreInputSegmentation": false,
          "addAltTrans": false,
          "addAltTransGMode": true,
          "editAltTrans": false,
          "includeExtensions": true,
          "includeIts": true,
          "balanceCodes": true,
          "allowEmptyTargets": false,
          "targetStateMode": 0,
          "targetStateValue": "needs-translation",
          "alwaysUseSegSource": false,
          "quoteModeDefined": true,
          "quoteMode": 0,
          "useSdlXliffWriter": true,
          "preserveSpaceByDefault": true,
          "useSegsForSdlProps": false,
          "useIwsXliffWriter": false,
          "iwsBlockFinished": true,
          "iwsTransStatusValue": "finished",
          "iwsTransTypeValue": "manual_translation",
          "iwsRemoveTmOrigin": false,
          "iwsBlockLockStatus": false,
          "iwsBlockTmScore": false,
          "iwsBlockTmScoreValue": 100,
          "iwsIncludeMultipleExact": false,
          "iwsBlockMultipleExact": false,
          "inlineCdata": false,
          "skipNoMrkSegSource": true,
          "useCodeFinder": false,
          "subAsTextUnit": false,
          "sdlSegConfValue": "Translated",
          "codeFinderRules.count": 0,
          "codeFinderRules.sample": "",
          "codeFinderRules.useAllRulesWhenTesting": false
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.xliff.XLIFFFilter"
      },
      {
        "configId": "okf_xliff-iws",
        "name": "IWSXLIFF",
        "description": "Configuration for IWS XLIFF documents. Supports IWS specific metadata",
        "mimeType": "application/x-xliff+xml",
        "extensions": ".xlf;",
        "parametersLocation": "iws.fprm",
        "parametersRaw": "#v1\nuseCustomParser.b=true\nfactoryClass=com.ctc.wstx.stax.WstxInputFactory\nfallbackToID.b=false\nescapeGT.b=false\naddTargetLanguage.b=true\noverrideTargetLanguage.b=false\noutputSegmentationType.i=0\nignoreInputSegmentation.b=false\naddAltTrans.b=false\naddAltTransGMode.b=true\neditAltTrans.b=false\nincludeExtensions.b=true\nincludeIts.b=true\nbalanceCodes.b=true\nallowEmptyTargets.b=false\ntargetStateMode.i=0\ntargetStateValue=needs-translation\nalwaysUseSegSource.b=false\nquoteModeDefined.b=true\nquoteMode.i=0\nuseSdlXliffWriter.b=false\npreserveSpaceByDefault.b=true\nuseSegsForSdlProps.b=false\nuseIwsXliffWriter.b=true\niwsBlockFinished.b=true\niwsTransStatusValue=pending\niwsTransTypeValue=manual_translation\niwsRemoveTmOrigin.b=false\niwsBlockLockStatus.b=false\niwsBlockTmScore.b=false\niwsBlockTmScoreValue=100.00\niwsIncludeMultipleExact.b=false\niwsBlockMultipleExact.b=false\ninlineCdata.b=false\nskipNoMrkSegSource.b=true\nuseCodeFinder.b=false\nsdlSegConfValue=Translated\ncodeFinderRules.count.i=0\ncodeFinderRules.sample=\ncodeFinderRules.useAllRulesWhenTesting.b=false\n",
        "parameters": {
          "useCustomParser": true,
          "factoryClass": "com.ctc.wstx.stax.WstxInputFactory",
          "fallbackToID": false,
          "escapeGT": false,
          "addTargetLanguage": true,
          "overrideTargetLanguage": false,
          "outputSegmentationType": 0,
          "ignoreInputSegmentation": false,
          "addAltTrans": false,
          "addAltTransGMode": true,
          "editAltTrans": false,
          "includeExtensions": true,
          "includeIts": true,
          "balanceCodes": true,
          "allowEmptyTargets": false,
          "targetStateMode": 0,
          "targetStateValue": "needs-translation",
          "alwaysUseSegSource": false,
          "quoteModeDefined": true,
          "quoteMode": 0,
          "useSdlXliffWriter": false,
          "preserveSpaceByDefault": true,
          "useSegsForSdlProps": false,
          "useIwsXliffWriter": true,
          "iwsBlockFinished": true,
          "iwsTransStatusValue": "pending",
          "iwsTransTypeValue": "manual_translation",
          "iwsRemoveTmOrigin": false,
          "iwsBlockLockStatus": false,
          "iwsBlockTmScore": false,
          "iwsBlockTmScoreValue": 100,
          "iwsIncludeMultipleExact": false,
          "iwsBlockMultipleExact": false,
          "inlineCdata": false,
          "skipNoMrkSegSource": true,
          "useCodeFinder": false,
          "subAsTextUnit": false,
          "sdlSegConfValue": "Translated",
          "codeFinderRules.count": 0,
          "codeFinderRules.sample": "",
          "codeFinderRules.useAllRulesWhenTesting": false
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.xliff.XLIFFFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "extraction": {
      "type": "object",
      "description": "Control what content is extracted",
      "properties": {
        "preserveSpaceByDefault": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "preserveSpaceByDefault",
          "description": "Preserve whitespace by default"
        },
        "includeExtensions": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "includeExtensions",
          "description": "Include XLIFF extension elements"
        },
        "includeIts": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "includeIts",
          "description": "Include ITS annotations"
        },
        "inlineCdata": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "inlineCdata",
          "description": "Treat CDATA sections as inline"
        },
        "subAsTextUnit": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "subAsTextUnit",
          "description": "Process sub elements as text units"
        },
        "ignoreInputSegmentation": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "ignoreInputSegmentation",
          "description": "Ignore existing segmentation"
        },
        "skipNoMrkSegSource": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "skipNoMrkSegSource",
          "description": "Skip seg-source without mrk elements"
        },
        "fallbackToID": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "fallbackToID",
          "description": "Fall back to trans-unit ID"
        }
      }
    },
    "states": {
      "type": "object",
      "description": "Translation state handling",
      "properties": {
        "targetStateMode": {
          "type": "integer",
          "default": 0,
          "x-flattenPath": "targetStateMode",
          "description": "How to handle target state attribute"
        },
        "targetStateValue": {
          "type": "string",
          "default": "needs-translation",
          "x-flattenPath": "targetStateValue",
          "description": "State value to set on targets"
        },
        "editAltTrans": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "editAltTrans",
          "description": "Edit alt-trans elements"
        },
        "addAltTrans": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "addAltTrans",
          "description": "Add alt-trans for existing translations"
        },
        "addAltTransGMode": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "addAltTransGMode",
          "description": "Alt-trans mode for group-level"
        }
      }
    },
    "output": {
      "type": "object",
      "description": "Output formatting and behavior",
      "properties": {
        "addTargetLanguage": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "addTargetLanguage",
          "description": "Add target-language attribute"
        },
        "overrideTargetLanguage": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "overrideTargetLanguage",
          "description": "Override target language in output"
        },
        "allowEmptyTargets": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "allowEmptyTargets",
          "description": "Allow empty target elements"
        },
        "alwaysUseSegSource": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "alwaysUseSegSource",
          "description": "Always use seg-source"
        },
        "outputSegmentationType": {
          "type": "string",
          "x-flattenPath": "outputSegmentationType",
          "description": "Output segmentation type"
        }
      }
    },
    "subfilters": {
      "type": "object",
      "description": "Sub-filter configuration",
      "properties": {
        "cdataSubfilter": {
          "type": "string",
          "default": "",
          "x-flattenPath": "cdataSubfilter",
          "description": "Sub-filter for CDATA content"
        }
      }
    },
    "parser": {
      "type": "object",
      "description": "Parser settings",
      "properties": {
        "useCustomParser": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "useCustomParser",
          "description": "Use custom parser"
        },
        "factoryClass": {
          "type": "string",
          "default": "com.ctc.wstx.stax.WstxInputFactory",
          "x-flattenPath": "factoryClass",
          "description": "Custom parser factory class"
        }
      }
    },
    "sdl": {
      "type": "object",
      "description": "SDL XLIFF extensions",
      "properties": {
        "useSdlXliffWriter": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "useSdlXliffWriter",
          "description": "Use SDL XLIFF writer"
        },
        "useSegsForSdlProps": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "useSegsForSdlProps",
          "description": "Use segments for SDL properties"
        },
        "sdlSegConfValue": {
          "type": "string",
          "default": "",
          "x-flattenPath": "sdlSegConfValue",
          "description": "SDL segment confidence value"
        },
        "sdlSegLockedValue": {
          "type": "string",
          "default": "",
          "x-flattenPath": "sdlSegLockedValue",
          "description": "SDL segment locked value"
        },
        "sdlSegOriginValue": {
          "type": "string",
          "default": "",
          "x-flattenPath": "sdlSegOriginValue",
          "description": "SDL segment origin value"
        }
      }
    },
    "iws": {
      "type": "object",
      "description": "Idiom WorldServer extensions",
      "properties": {
        "useIwsXliffWriter": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "useIwsXliffWriter",
          "description": "Use IWS XLIFF writer"
        },
        "iwsBlockFinished": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "iwsBlockFinished",
          "description": "IWS block finished state"
        },
        "iwsBlockLockStatus": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "iwsBlockLockStatus",
          "description": "IWS lock status"
        },
        "iwsBlockMultipleExact": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "iwsBlockMultipleExact",
          "description": "IWS multiple exact matches"
        },
        "iwsBlockTmScore": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "iwsBlockTmScore",
          "description": "IWS TM score threshold"
        },
        "iwsBlockTmScoreValue": {
          "type": "string",
          "default": "100.00",
          "x-flattenPath": "iwsBlockTmScoreValue",
          "description": "IWS TM score value"
        },
        "iwsIncludeMultipleExact": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "iwsIncludeMultipleExact",
          "description": "Include multiple exact matches"
        },
        "iwsRemoveTmOrigin": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "iwsRemoveTmOrigin",
          "description": "Remove TM origin"
        },
        "iwsTransStatusValue": {
          "type": "string",
          "default": "finished",
          "x-flattenPath": "iwsTransStatusValue",
          "description": "IWS translation status value"
        },
        "iwsTransTypeValue": {
          "type": "string",
          "default": "manual_translation",
          "x-flattenPath": "iwsTransTypeValue",
          "description": "IWS translation type value"
        }
      }
    },
    "balanceCodes": {
      "type": "boolean",
      "default": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}