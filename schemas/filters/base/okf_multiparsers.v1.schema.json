{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Multi-Parsers Filter Filter",
  "description": "Configuration for the Okapi Multi-Parsers Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_multiparsers",
    "class": "net.sf.okapi.filters.multiparsers.MultiParsersFilter",
    "extensions": [
      ".csv"
    ],
    "mimeTypes": [
      "text/csv"
    ],
    "configurations": [
      {
        "configId": "okf_multiparsers",
        "name": "Multi-Parsers: CSV with Plain-Text",
        "description": "Configuration for CSV files with plain-text on all columns",
        "mimeType": "text/csv",
        "extensions": ".csv;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.multiparsers.MultiParsersFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "extraction": {
      "type": "object",
      "description": "CSV extraction settings",
      "properties": {
        "csvAutoDetectColumnTypes": {
          "type": "boolean",
          "default": false,
          "title": "Use auto-detection (a special row in each input file)",
          "x-widget": "checkbox",
          "x-flattenPath": "csvAutoDetectColumnTypes",
          "description": "Auto-detect column types"
        },
        "csvAutoDetectColumnTypesRow": {
          "type": "integer",
          "default": 2,
          "title": "Row at which the special configuration information is (first=1)",
          "minimum": 1,
          "maximum": 9999999,
          "x-widget": "spin",
          "x-enabledBy": {
            "parameter": "csvAutoDetectColumnTypes",
            "enabledWhenSelected": true
          },
          "x-flattenPath": "csvAutoDetectColumnTypesRow",
          "description": "Row for type detection"
        },
        "csvFormatCols": {
          "type": "string",
          "default": "",
          "title": "Comma-separated list of the colums with non-plain-text content (e.g. '3:okf_markdown', first=0)",
          "x-widget": "text",
          "x-enabledBy": {
            "parameter": "csvAutoDetectColumnTypes",
            "enabledWhenSelected": false
          },
          "x-flattenPath": "csvFormatCols",
          "description": "Format column specifications"
        },
        "csvNoExtractCols": {
          "type": "string",
          "default": "",
          "title": "Comma-separated list of the colums not to extract (first=0)",
          "x-widget": "text",
          "x-enabledBy": {
            "parameter": "csvAutoDetectColumnTypes",
            "enabledWhenSelected": false
          },
          "x-flattenPath": "csvNoExtractCols",
          "description": "Columns to skip"
        },
        "csvStartingRow": {
          "type": "integer",
          "default": 1,
          "title": "Row at which the extraction starts (first=1)",
          "minimum": 1,
          "maximum": 9999999,
          "x-widget": "spin",
          "x-enabledBy": {
            "parameter": "csvAutoDetectColumnTypes",
            "enabledWhenSelected": false
          },
          "x-flattenPath": "csvStartingRow",
          "description": "Starting data row"
        }
      }
    }
  },
  "additionalProperties": false
}