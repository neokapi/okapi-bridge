{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "YAML Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_yaml",
    "class": "net.sf.okapi.filters.yaml.YamlFilter",
    "extensions": [
      ".yml",
      ".yaml"
    ],
    "mimeTypes": [
      "text/x-yaml"
    ],
    "configurations": [
      {
        "configId": "okf_yaml",
        "name": "YAML",
        "description": "YAML files",
        "mimeType": "text/x-yaml",
        "extensions": ".yml;.yaml;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.yaml.YamlFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "extraction": {
      "type": "object",
      "title": "Control what content is extracted for translation",
      "properties": {
        "extractAll": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "extractAllPairs",
          "title": "Extract all key-value pairs"
        },
        "includeIsolatedStrings": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "extractIsolatedStrings",
          "title": "Extract array string values"
        },
        "excludeKeys": {
          "type": "string",
          "default": "",
          "x-flattenPath": "exceptions",
          "title": "Comma-separated keys to exclude"
        }
      }
    },
    "keys": {
      "type": "object",
      "title": "Configure how YAML keys map to text unit identification",
      "properties": {
        "useAsName": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "useKeyAsName",
          "title": "Use YAML key as text unit name"
        },
        "useFullPath": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "useFullKeyPath",
          "title": "Use full path as name"
        }
      }
    },
    "output": {
      "type": "object",
      "title": "Output formatting options",
      "properties": {
        "escapeNonAscii": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "escapeNonAscii",
          "title": "Escape non-ASCII characters"
        },
        "wrap": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "wrap",
          "title": "Line wrapping mode"
        },
        "subFilterProcessLiteralAsBlock": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "subFilterProcessLiteralAsBlock",
          "title": "Process literal blocks with sub-filter"
        }
      }
    }
  },
  "additionalProperties": false,
  "x-groups": [
    {
      "id": "inlineCodes",
      "label": "Inline Codes",
      "fields": [
        "inlineCodes"
      ]
    },
    {
      "id": "extraction",
      "label": "Control what content is extracted for translation",
      "fields": [
        "extraction"
      ]
    },
    {
      "id": "keys",
      "label": "Configure how YAML keys map to text unit identification",
      "fields": [
        "keys"
      ]
    },
    {
      "id": "output",
      "label": "Output formatting options",
      "fields": [
        "output"
      ]
    }
  ],
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "title": "Inline Codes",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "title": "Enable Inline Code Detection",
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder",
          "x-enables": [
            "rules",
            "mergeAdjacent",
            "moveBoundaryCodes",
            "simplifierRules"
          ]
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "title": "Code Finder Rules",
          "x-flattenPath": "codeFinderRules",
          "x-enabledBy": "enabled",
          "x-widget": "codeFinder"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "title": "Merge Adjacent Codes",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "title": "Move Boundary Codes",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "title": "Simplifier Rules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "title": "Code Finder Rules",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "title": "Patterns",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "title": "Pattern",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "title": "Sample Text",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "title": "Test All Rules Together",
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "title": "Simplifier Rules",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}