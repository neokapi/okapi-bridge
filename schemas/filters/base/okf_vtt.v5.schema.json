{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VTT Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_vtt",
    "class": "net.sf.okapi.filters.vtt.VTTFilter",
    "extensions": [
      ".vtt",
      ".srt"
    ],
    "mimeTypes": [
      "text/vtt"
    ],
    "configurations": [
      {
        "configId": "okf_vtt",
        "name": "VTT",
        "description": "VTT Documents",
        "mimeType": "text/vtt",
        "extensions": ".vtt;.srt",
        "parametersLocation": "okf_vtt.fprm",
        "parametersRaw": "#v1\ntimeFormat=HH:mm:ss.SSS\nmaxLinesPerCaption.i=2\nmaxCharsPerLine.i=47\ncjkCharsPerLine.i=18\n",
        "parameters": {
          "timeFormat": "HH:mm:ss.SSS",
          "maxLinesPerCaption": 2,
          "maxCharsPerLine": 47,
          "cjkCharsPerLine": 18
        },
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.vtt.VTTFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "extraction": {
      "type": "object",
      "description": "Extraction settings",
      "properties": {
        "discardCues": {
          "type": "boolean",
          "default": false,
          "title": "Discard existing cue settings",
          "x-editor": {
            "widget": "checkbox",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "discardCues",
          "description": "Discard cue settings"
        },
        "cueSettings": {
          "type": "string",
          "default": "",
          "title": "Replace existing cue settings with text",
          "x-editor": {
            "widget": "text",
            "enabledBy": {
              "parameter": "discardCues",
              "enabledWhenSelected": false
            },
            "layout": {
              "vertical": true
            },
            "text": {
              "allowEmpty": true
            }
          },
          "x-flattenPath": "cueSettings",
          "description": "Cue settings configuration"
        }
      }
    },
    "output": {
      "type": "object",
      "description": "Output settings",
      "properties": {
        "keepTimecodes": {
          "type": "boolean",
          "default": false,
          "title": "Keep timecodes",
          "x-editor": {
            "widget": "checkbox",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "keepTimecodes",
          "description": "Preserve timing information"
        },
        "timeFormat": {
          "type": "string",
          "default": "",
          "title": "Time format",
          "x-editor": {
            "widget": "text",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "timeFormat",
          "description": "Time code format"
        },
        "maxCharsPerLine": {
          "type": "integer",
          "default": 0,
          "title": "Max characters per line",
          "minimum": 1,
          "maximum": 9999999,
          "x-editor": {
            "widget": "spin",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "maxCharsPerLine",
          "description": "Maximum characters per line"
        },
        "maxLinesPerCaption": {
          "type": "integer",
          "default": 0,
          "title": "Max lines per caption",
          "minimum": 1,
          "maximum": 9999999,
          "x-editor": {
            "widget": "spin",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "maxLinesPerCaption",
          "description": "Maximum lines per caption"
        },
        "cjkCharsPerLine": {
          "type": "integer",
          "default": 0,
          "title": "Max characters per line for CJK",
          "minimum": 1,
          "maximum": 9999999,
          "x-editor": {
            "widget": "spin",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "cjkCharsPerLine",
          "description": "CJK characters per line"
        },
        "splitWords": {
          "type": "boolean",
          "default": false,
          "title": "Split words so that they don't go over the char limit",
          "x-editor": {
            "widget": "checkbox",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "splitWords",
          "description": "Split words at line boundaries"
        }
      }
    }
  },
  "additionalProperties": false
}