{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PO Filter Filter",
  "description": "Configuration for the Okapi PO Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_po",
    "class": "net.sf.okapi.filters.po.POFilter",
    "extensions": [
      ".po"
    ],
    "mimeTypes": [
      "application/x-gettext"
    ],
    "configurations": [
      {
        "configId": "okf_po",
        "name": "PO (Standard)",
        "description": "Standard bilingual PO files",
        "mimeType": "application/x-gettext",
        "extensions": ".po;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.po.POFilter"
      },
      {
        "configId": "okf_po-monolingual",
        "name": "PO (Monolingual)",
        "description": "Monolingual PO files (msgid is a real ID, not the source text).",
        "mimeType": "application/x-gettext",
        "extensions": ".po;",
        "parametersLocation": "monolingual.fprm",
        "parametersRaw": "#v1\nbilingualMode.b=false\nmakeID.b=true\nuseLD.b=true\nlocalizeOutside.b=true\nuseCodeFinder.b=true\ncodeFinderRules.count.i=3\ncodeFinderRules.rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]\ncodeFinderRules.rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v\ncodeFinderRules.rule2=\\{\\d.*?\\}\ncodeFinderRules.sample=%s, %d, {1}, \\n, \\r, \\t, etc.\ncodeFinderRules.useAllRulesWhenTesting.b=true\n",
        "parameters": {
          "bilingualMode": false,
          "makeID": true,
          "protectApproved": false,
          "useCodeFinder": true,
          "allowEmptyOutputTarget": false,
          "subfilter": "",
          "useLD": true,
          "localizeOutside": true,
          "codeFinderRules.count": 3,
          "codeFinderRules.rule0": "%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]",
          "codeFinderRules.rule1": "(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v",
          "codeFinderRules.rule2": "\\{\\d.*?\\}",
          "codeFinderRules.sample": "%s, %d, {1}, \\n, \\r, \\t, etc.",
          "codeFinderRules.useAllRulesWhenTesting": true
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.po.POFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "mode": {
      "type": "object",
      "description": "Processing mode",
      "properties": {
        "bilingualMode": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "bilingualMode",
          "description": "Treat as bilingual file"
        },
        "protectApproved": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "protectApproved",
          "description": "Protect approved translations"
        },
        "wrapContent": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "wrapContent",
          "description": "Wrap long content lines"
        }
      }
    },
    "identification": {
      "type": "object",
      "description": "ID and naming",
      "properties": {
        "makeID": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "makeID",
          "description": "Generate text unit IDs"
        },
        "includeMsgContextInNote": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "includeMsgContextInNote",
          "description": "Include msgctxt in notes"
        }
      }
    },
    "output": {
      "type": "object",
      "description": "Output formatting",
      "properties": {
        "outputGeneric": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "outputGeneric",
          "description": "Output in generic format"
        },
        "allowEmptyOutputTarget": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "allowEmptyOutputTarget",
          "description": "Allow empty target output"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}