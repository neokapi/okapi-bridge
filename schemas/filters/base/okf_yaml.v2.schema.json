{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "YAML Filter Filter",
  "description": "Configuration for the Okapi YAML Filter Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_yaml",
    "class": "net.sf.okapi.filters.yaml.YamlFilter",
    "extensions": [
      ".yml",
      ".yaml"
    ],
    "mimeTypes": [
      "text/x-yaml"
    ],
    "configurations": [
      {
        "configId": "okf_yaml",
        "name": "YAML",
        "description": "YAML files",
        "mimeType": "text/x-yaml",
        "extensions": ".yml;.yaml;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.yaml.YamlFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "extraction": {
      "type": "object",
      "description": "Control what content is extracted for translation",
      "properties": {
        "extractAll": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "extractAllPairs",
          "description": "Extract all key-value pairs"
        },
        "includeIsolatedStrings": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "extractIsolatedStrings",
          "description": "Extract array string values"
        },
        "excludeKeys": {
          "type": "string",
          "default": "",
          "x-flattenPath": "exceptions",
          "description": "Comma-separated keys to exclude"
        }
      }
    },
    "keys": {
      "type": "object",
      "description": "Configure how YAML keys map to text unit identification",
      "properties": {
        "useAsName": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "useKeyAsName",
          "description": "Use YAML key as text unit name"
        },
        "useFullPath": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "useFullKeyPath",
          "description": "Use full path as name"
        }
      }
    },
    "output": {
      "type": "object",
      "description": "Output formatting options",
      "properties": {
        "escapeNonAscii": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "escapeNonAscii",
          "description": "Escape non-ASCII characters"
        },
        "wrap": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "wrap",
          "description": "Line wrapping mode"
        },
        "subFilterProcessLiteralAsBlock": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "subFilterProcessLiteralAsBlock",
          "description": "Process literal blocks with sub-filter"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}