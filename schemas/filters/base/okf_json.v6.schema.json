{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Json Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_json",
    "class": "net.sf.okapi.filters.json.JSONFilter",
    "extensions": [
      ".json"
    ],
    "mimeTypes": [
      "application/json"
    ],
    "configurations": [
      {
        "configId": "okf_json",
        "name": "JSON (JavaScript Object Notation)",
        "description": "Configuration for JSON files",
        "mimeType": "application/json",
        "extensions": ".json;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.json.JSONFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "extraction": {
      "type": "object",
      "title": "Control what content is extracted for translation",
      "properties": {
        "extractAll": {
          "type": "boolean",
          "default": true,
          "title": "Extract all key/string pairs",
          "description": "Extract all key-value pairs",
          "x-editor": {
            "widget": "radio"
          },
          "x-options": [
            {
              "value": true,
              "label": "Extract all key/string pairs"
            },
            {
              "value": false,
              "label": "Do not extract key/string pairs"
            }
          ],
          "x-flattenPath": "extractAllPairs"
        },
        "pathRules": {
          "type": "string",
          "default": "",
          "title": "Extraction rules",
          "description": "Regex for JSON paths to extract",
          "x-editor": {
            "widget": "text"
          },
          "x-flattenPath": "extractionRules"
        },
        "includeIsolatedStrings": {
          "type": "boolean",
          "default": false,
          "title": "Extract strings without associated key",
          "description": "Extract array string values without keys",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "extractIsolatedStrings"
        },
        "excludeKeys": {
          "type": "string",
          "default": "",
          "title": "Key exception pattern",
          "description": "Comma-separated keys to exclude from extraction",
          "x-editor": {
            "widget": "text"
          },
          "x-flattenPath": "exceptions"
        },
        "subfilterRules": {
          "type": "string",
          "default": "",
          "title": "Sub-filter rules",
          "description": "Sub-filter rules for embedded content",
          "x-editor": {
            "widget": "text"
          },
          "x-flattenPath": "subfilterRules"
        }
      }
    },
    "keys": {
      "type": "object",
      "title": "Configure how JSON keys map to text unit identification",
      "properties": {
        "useAsName": {
          "type": "boolean",
          "default": true,
          "title": "Use the key as the resname",
          "description": "Use JSON key as text unit name",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "useKeyAsName"
        },
        "useFullPath": {
          "type": "boolean",
          "default": false,
          "title": "Use the full key path",
          "description": "Use full path (/key1/key2) as name",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-enables": [
            "useLeadingSlashOnKeyPath"
          ],
          "x-flattenPath": "useFullKeyPath"
        },
        "leadingSlash": {
          "type": "boolean",
          "default": true,
          "title": "Include leading \"/\" on key path",
          "description": "Include leading slash in paths",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "useLeadingSlashOnKeyPath"
        },
        "useIdStack": {
          "type": "boolean",
          "default": false,
          "title": "Use the full path of IDs for resname and TextUnit Metadata",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "useIdStack",
          "description": "Build IDs from nested key stack"
        },
        "idRules": {
          "type": "string",
          "default": "",
          "title": "ID rules",
          "description": "Regex for keys used as text unit IDs",
          "x-editor": {
            "widget": "text"
          },
          "x-flattenPath": "idRules"
        }
      }
    },
    "metadata": {
      "type": "object",
      "title": "Configure metadata extraction rules",
      "properties": {
        "noteRules": {
          "type": "string",
          "default": "",
          "title": "Note rules",
          "description": "Regex for translator note keys",
          "x-editor": {
            "widget": "text"
          },
          "x-flattenPath": "noteRules"
        },
        "metaRules": {
          "type": "string",
          "default": "",
          "title": "Generic metadata rules",
          "description": "Regex for generic metadata keys",
          "x-editor": {
            "widget": "text"
          },
          "x-flattenPath": "genericMetaRules"
        },
        "maxwidthRules": {
          "type": "string",
          "default": "",
          "title": "Maxwidth rules",
          "description": "Regex for max width constraint keys",
          "x-editor": {
            "widget": "text"
          },
          "x-flattenPath": "maxwidthRules"
        }
      }
    },
    "output": {
      "type": "object",
      "title": "Output formatting options",
      "properties": {
        "escapeSlashes": {
          "type": "boolean",
          "default": true,
          "title": "Escape forward slashes",
          "x-editor": {
            "widget": "checkbox"
          },
          "x-flattenPath": "escapeForwardSlashes",
          "description": "Escape forward slashes in output"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}