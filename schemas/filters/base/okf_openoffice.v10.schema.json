{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenOffice.org Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_openoffice",
    "class": "net.sf.okapi.filters.openoffice.OpenOfficeFilter",
    "extensions": [
      ".odt",
      ".ods",
      ".odg",
      ".odp",
      ".ott",
      ".ots",
      ".otp",
      ".otg",
      ".swc",
      ".swx",
      ".sxd",
      ".sxi"
    ],
    "mimeTypes": [
      "application/x-openoffice"
    ],
    "configurations": [
      {
        "configId": "okf_openoffice",
        "name": "OpenOffice.org Documents",
        "description": "OpenOffice.org ODT, ODS, ODP, ODG, OTT, OTS, OTP, OTG, SWC, SWX, SXD, SXI documents",
        "mimeType": "application/x-openoffice",
        "extensions": ".odt;.ods;.odg;.odp;.ott;.ots;.otp;.otg;.swc;.swx;.sxd;.sxi;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.openoffice.OpenOfficeFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "extraction": {
      "type": "object",
      "title": "Extraction settings",
      "properties": {
        "extractNotes": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "extractNotes",
          "title": "Extract notes/comments"
        },
        "extractMetadata": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "extractMetadata",
          "title": "Extract document metadata"
        },
        "extractReferences": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "extractReferences",
          "title": "Extract cross-references"
        },
        "encodeCharacterEntityReferenceGlyphs": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "encodeCharacterEntityReferenceGlyphs",
          "title": "Encode character entity glyphs"
        }
      }
    }
  },
  "additionalProperties": false,
  "x-groups": [
    {
      "id": "inlineCodes",
      "label": "Inline Codes",
      "fields": [
        "inlineCodes"
      ]
    },
    {
      "id": "extraction",
      "label": "Extraction settings",
      "fields": [
        "extraction"
      ]
    }
  ],
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "title": "Inline Codes",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "title": "Enable Inline Code Detection",
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder",
          "x-enables": [
            "rules",
            "mergeAdjacent",
            "moveBoundaryCodes",
            "simplifierRules"
          ]
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "title": "Code Finder Rules",
          "x-flattenPath": "codeFinderRules",
          "x-enabledBy": "enabled",
          "x-widget": "codeFinderRules"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "title": "Merge Adjacent Codes",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "title": "Move Boundary Codes",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "title": "Simplifier Rules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "title": "Code Finder Rules",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "title": "Patterns",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "title": "Pattern",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "title": "Sample Text",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "title": "Test All Rules Together",
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "title": "Simplifier Rules",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}