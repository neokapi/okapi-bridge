{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SDLPPX and SDLRPX Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_sdlpackage",
    "class": "net.sf.okapi.filters.sdlpackage.SdlPackageFilter",
    "extensions": [
      ".sdlppx",
      ".sdlrpx"
    ],
    "mimeTypes": [
      "application/x-sdlpackage"
    ],
    "configurations": [
      {
        "configId": "okf_sdlpackage",
        "name": "SDL Trados Package Files",
        "description": "SDL Trados 2017 SDLPPX and SDLRPX files",
        "mimeType": "application/x-sdlpackage",
        "extensions": ".sdlppx;.sdlrpx;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.sdlpackage.SdlPackageFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "identification": {
      "type": "object",
      "title": "File identification",
      "properties": {
        "fileNames": {
          "type": "string",
          "default": "*.tmx,*.xlf,*.xlff",
          "title": "File names",
          "description": "Comma-delimited list of file names to be processed (wildcards are allowed) in the same order as configuration ids",
          "x-editor": {
            "widget": "text",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "fileNames"
        },
        "mimeType": {
          "type": "string",
          "default": "application/x-archive",
          "title": "MIME type of the filter's container format",
          "x-editor": {
            "widget": "text",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "mimeType"
        },
        "configIds": {
          "type": "string",
          "default": "okf_tmx,okf_xliff,okf_xliff",
          "title": "Filter configuration ids",
          "description": "Comma-delimited list of configuration ids corresponding to the file names",
          "x-editor": {
            "widget": "text",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "configIds"
        }
      }
    }
  },
  "additionalProperties": false,
  "x-groups": [
    {
      "id": "inlineCodes",
      "label": "Inline Codes",
      "fields": [
        "inlineCodes"
      ]
    },
    {
      "id": "identification",
      "label": "File identification",
      "fields": [
        "identification"
      ]
    }
  ],
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "title": "Inline Codes",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "title": "Enable Inline Code Detection",
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder",
          "x-enables": [
            "rules",
            "mergeAdjacent",
            "moveBoundaryCodes",
            "simplifierRules"
          ]
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "title": "Code Finder Rules",
          "x-flattenPath": "codeFinderRules",
          "x-enabledBy": "enabled",
          "x-widget": "codeFinderRules"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "title": "Merge Adjacent Codes",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "title": "Move Boundary Codes",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "title": "Simplifier Rules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "title": "Code Finder Rules",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "title": "Patterns",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "title": "Pattern",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "title": "Sample Text",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "title": "Test All Rules Together",
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "title": "Simplifier Rules",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}