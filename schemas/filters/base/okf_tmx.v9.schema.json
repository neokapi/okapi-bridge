{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TMX Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_tmx",
    "class": "net.sf.okapi.filters.tmx.TmxFilter",
    "extensions": [
      ".tmx"
    ],
    "mimeTypes": [
      "application/x-tmx+xml"
    ],
    "configurations": [
      {
        "configId": "okf_tmx",
        "name": "TMX",
        "description": "Configuration for Translation Memory eXchange (TMX) documents.",
        "mimeType": "application/x-tmx+xml",
        "extensions": ".tmx;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.tmx.TmxFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "extraction": {
      "type": "object",
      "title": "TMX processing settings",
      "properties": {
        "segType": {
          "type": "integer",
          "default": 2,
          "title": "Creates or not a segment for the extracted <Tu>",
          "x-flattenPath": "segType"
        },
        "processAllTargets": {
          "type": "boolean",
          "default": true,
          "title": "Read all target entries",
          "x-flattenPath": "processAllTargets"
        },
        "exitOnInvalid": {
          "type": "boolean",
          "default": false,
          "title": "Exit when encountering invalid <tu>s (default is to skip invalid <tu>s).",
          "x-flattenPath": "exitOnInvalid"
        },
        "consolidateDpSkeleton": {
          "type": "boolean",
          "default": true,
          "title": "Group all document parts skeleton into one",
          "x-flattenPath": "consolidateDpSkeleton"
        },
        "propValueSep": {
          "type": "string",
          "default": ", ",
          "title": "String used to delimit property values when there are duplicate properties",
          "x-flattenPath": "propValueSep"
        }
      }
    },
    "output": {
      "type": "object",
      "title": "Output settings",
      "properties": {
        "escapeGT": {
          "type": "boolean",
          "default": false,
          "title": "Escape the greater-than characters",
          "x-flattenPath": "escapeGT"
        }
      }
    }
  },
  "additionalProperties": false,
  "x-groups": [
    {
      "id": "inlineCodes",
      "label": "Inline Codes",
      "fields": [
        "inlineCodes"
      ]
    },
    {
      "id": "extraction",
      "label": "TMX processing settings",
      "fields": [
        "extraction"
      ]
    },
    {
      "id": "output",
      "label": "Output settings",
      "fields": [
        "output"
      ]
    }
  ],
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "title": "Inline Codes",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "title": "Enable Inline Code Detection",
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder",
          "x-enables": [
            "rules",
            "mergeAdjacent",
            "moveBoundaryCodes",
            "simplifierRules"
          ]
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "title": "Code Finder Rules",
          "x-flattenPath": "codeFinderRules",
          "x-enabledBy": "enabled",
          "x-widget": "codeFinderRules"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "title": "Merge Adjacent Codes",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "title": "Move Boundary Codes",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "title": "Simplifier Rules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "title": "Code Finder Rules",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "title": "Patterns",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "title": "Pattern",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "title": "Sample Text",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "title": "Test All Rules Together",
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "title": "Simplifier Rules",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}