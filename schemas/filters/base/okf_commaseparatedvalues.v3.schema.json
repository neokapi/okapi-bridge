{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plain Text Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_commaseparatedvalues",
    "class": "net.sf.okapi.filters.table.csv.CommaSeparatedValuesFilter",
    "extensions": [
      ".csv"
    ],
    "mimeTypes": [
      "text/csv"
    ],
    "configurations": [
      {
        "configId": "okf_table_csv",
        "name": "Table (Comma-Separated Values)",
        "description": "Comma-separated values, optional header with field names.",
        "mimeType": "text/csv",
        "extensions": ".csv;",
        "parametersLocation": "okf_table_csv.fprm",
        "parametersRaw": "#v1\nunescapeSource.b=true\ntrimLeading.b=true\ntrimTrailing.b=true\npreserveWS.b=false\nuseCodeFinder.b=false\ncodeFinderRules=#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false\nwrapMode.i=0\ncolumnNamesLineNum.i=1\nvaluesStartLineNum.i=2\ndetectColumnsMode.i=0\nnumColumns.i=1\nsendHeaderMode.i=1\ntrimMode.i=1\nsendColumnsMode.i=2\nsourceIdColumns=\nsourceColumns=\ntargetColumns=\ncommentColumns=\ncommentSourceRefs=\nrecordIdColumn.i=0\nsourceIdSourceRefs=\nsourceIdSuffixes=\ntargetLanguages=\ntargetSourceRefs=\nfieldDelimiter=,\ntextQualifier=\"\nremoveQualifiers.b=true\nparametersClass=net.sf.okapi.filters.table.csv.Parameters\n",
        "parameters": {
          "unescapeSource": true,
          "trimLeading": true,
          "trimTrailing": true,
          "preserveWS": false,
          "useCodeFinder": false,
          "codeFinderRules": "#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false",
          "wrapMode": 0,
          "columnNamesLineNum": 1,
          "valuesStartLineNum": 2,
          "detectColumnsMode": 0,
          "numColumns": 1,
          "sendHeaderMode": 1,
          "trimMode": 1,
          "sendColumnsMode": 2,
          "sourceIdColumns": "",
          "sourceColumns": "",
          "targetColumns": "",
          "commentColumns": "",
          "commentSourceRefs": "",
          "exposeCommentsAsMetadata": false,
          "recordIdColumn": 0,
          "sourceIdSourceRefs": "",
          "sourceIdSuffixes": "",
          "targetLanguages": "",
          "targetSourceRefs": "",
          "fieldDelimiter": ",",
          "textQualifier": "\"",
          "removeQualifiers": true,
          "escapingMode": 1,
          "addQualifiers": false
        },
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.table.csv.CommaSeparatedValuesFilter"
      },
      {
        "configId": "okf_table_catkeys",
        "name": "Haiku CatKeys",
        "description": "Haiku CatKeys resource files",
        "mimeType": "text/csv",
        "parametersLocation": "okf_table_catkeys.fprm",
        "parametersRaw": "#v1\nunescapeSource.b=false\ntrimLeading.b=false\ntrimTrailing.b=false\npreserveWS.b=true\nuseCodeFinder.b=true\ncodeFinderRules=#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false\nwrapMode.i=0\ncolumnNamesLineNum.i=0\nvaluesStartLineNum.i=2\ndetectColumnsMode.i=2\nnumColumns.i=4\nsendHeaderMode.i=0\ntrimMode.i=0\nsendColumnsMode.i=1\nsourceIdColumns=\nsourceColumns=1\ntargetColumns=4\ncommentColumns=3\ncommentSourceRefs=1\nrecordIdColumn.i=0\nsourceIdSourceRefs=\nsourceIdSuffixes=\ntargetLanguages=\ntargetSourceRefs=1\nfieldDelimiter=\t\ntextQualifier=%%%^^^$$$nonenonenone$$$^^^%%%\nremoveQualifiers.b=false\nparametersClass=net.sf.okapi.filters.table.csv.Parameters\n",
        "parameters": {
          "unescapeSource": false,
          "trimLeading": false,
          "trimTrailing": false,
          "preserveWS": true,
          "useCodeFinder": true,
          "codeFinderRules": "#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false",
          "wrapMode": 0,
          "columnNamesLineNum": 0,
          "valuesStartLineNum": 2,
          "detectColumnsMode": 2,
          "numColumns": 4,
          "sendHeaderMode": 0,
          "trimMode": 0,
          "sendColumnsMode": 1,
          "sourceIdColumns": "",
          "sourceColumns": 1,
          "targetColumns": 4,
          "commentColumns": 3,
          "commentSourceRefs": 1,
          "exposeCommentsAsMetadata": false,
          "recordIdColumn": 0,
          "sourceIdSourceRefs": "",
          "sourceIdSuffixes": "",
          "targetLanguages": "",
          "targetSourceRefs": 1,
          "fieldDelimiter": "",
          "textQualifier": "%%%^^^$$$nonenonenone$$$^^^%%%",
          "removeQualifiers": false,
          "escapingMode": 1,
          "addQualifiers": false
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.table.csv.CommaSeparatedValuesFilter"
      },
      {
        "configId": "okf_table_src-tab-trg",
        "name": "Table (Tab-Separated Values)",
        "description": "2-column (source + target), tab separated files.",
        "mimeType": "text/csv",
        "parametersLocation": "okf_table_src-tab-trg.fprm",
        "parametersRaw": "#v1\nunescapeSource.b=true\ntrimLeading.b=true\ntrimTrailing.b=true\npreserveWS.b=false\nuseCodeFinder.b=false\ncodeFinderRules=#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false\nwrapMode.i=0\ncolumnNamesLineNum.i=0\nvaluesStartLineNum.i=1\ndetectColumnsMode.i=0\nnumColumns.i=1\nsendHeaderMode.i=0\ntrimMode.i=1\nsendColumnsMode.i=1\nsourceIdColumns=\nsourceColumns=1\ntargetColumns=2\ncommentColumns=3\ncommentSourceRefs=1\nrecordIdColumn.i=0\nsourceIdSourceRefs=\nsourceIdSuffixes=\ntargetLanguages=\ntargetSourceRefs=1\nfieldDelimiter=\t\ntextQualifier=\"\nremoveQualifiers.b=true\nescapingMode.i=1\nparametersClass=net.sf.okapi.filters.table.csv.Parameters\n",
        "parameters": {
          "unescapeSource": true,
          "trimLeading": true,
          "trimTrailing": true,
          "preserveWS": false,
          "useCodeFinder": false,
          "codeFinderRules": "#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false",
          "wrapMode": 0,
          "columnNamesLineNum": 0,
          "valuesStartLineNum": 1,
          "detectColumnsMode": 0,
          "numColumns": 1,
          "sendHeaderMode": 0,
          "trimMode": 1,
          "sendColumnsMode": 1,
          "sourceIdColumns": "",
          "sourceColumns": 1,
          "targetColumns": 2,
          "commentColumns": 3,
          "commentSourceRefs": 1,
          "exposeCommentsAsMetadata": false,
          "recordIdColumn": 0,
          "sourceIdSourceRefs": "",
          "sourceIdSuffixes": "",
          "targetLanguages": "",
          "targetSourceRefs": 1,
          "fieldDelimiter": "",
          "textQualifier": "\"",
          "removeQualifiers": true,
          "escapingMode": 1,
          "addQualifiers": false
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.table.csv.CommaSeparatedValuesFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "format": {
      "type": "object",
      "description": "CSV format settings",
      "properties": {
        "fieldDelimiter": {
          "type": "string",
          "default": ",",
          "x-flattenPath": "fieldDelimiter",
          "description": "Field delimiter character"
        },
        "textQualifier": {
          "type": "string",
          "default": "\"",
          "x-flattenPath": "textQualifier",
          "description": "Text qualifier character"
        },
        "escapingMode": {
          "type": "integer",
          "default": 1,
          "x-flattenPath": "escapingMode",
          "description": "Escaping mode"
        },
        "addQualifiers": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "addQualifiers",
          "description": "Add text qualifiers to output"
        },
        "removeQualifiers": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "removeQualifiers",
          "description": "Remove text qualifiers from input"
        }
      }
    },
    "columnNamesLineNum": {
      "type": "integer",
      "default": 0
    },
    "valuesStartLineNum": {
      "type": "integer",
      "default": 1
    },
    "detectColumnsMode": {
      "type": "integer",
      "default": 0
    },
    "numColumns": {
      "type": "integer",
      "default": 2
    },
    "sendHeaderMode": {
      "type": "integer",
      "default": 0
    },
    "trimMode": {
      "type": "integer",
      "default": 1
    },
    "sendColumnsMode": {
      "type": "integer",
      "default": 1
    },
    "recordIdColumn": {
      "type": "integer",
      "default": 0
    },
    "exposeCommentsAsMetadata": {
      "type": "boolean",
      "default": false
    },
    "sourceColumns": {
      "type": "string",
      "default": "1"
    },
    "sourceIdColumns": {
      "type": "string",
      "default": ""
    },
    "sourceIdSuffixes": {
      "type": "string",
      "default": ""
    },
    "sourceIdSourceRefs": {
      "type": "string",
      "default": ""
    },
    "targetColumns": {
      "type": "string",
      "default": "2"
    },
    "targetSourceRefs": {
      "type": "string",
      "default": "1"
    },
    "targetLanguages": {
      "type": "string",
      "default": ""
    },
    "commentColumns": {
      "type": "string",
      "default": ""
    },
    "commentSourceRefs": {
      "type": "string",
      "default": ""
    },
    "unescapeSource": {
      "type": "boolean",
      "default": true
    },
    "trimLeading": {
      "type": "boolean",
      "default": true
    },
    "trimTrailing": {
      "type": "boolean",
      "default": true
    },
    "preserveWS": {
      "type": "boolean",
      "default": true
    },
    "wrapMode": {
      "type": "string",
      "default": "NONE",
      "enum": [
        "NONE",
        "SPACES",
        "PLACEHOLDERS"
      ]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}