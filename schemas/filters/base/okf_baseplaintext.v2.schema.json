{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plain Text Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_baseplaintext",
    "class": "net.sf.okapi.filters.plaintext.base.BasePlainTextFilter",
    "extensions": [
      ".txt"
    ],
    "mimeTypes": [
      "text/plain"
    ],
    "configurations": [
      {
        "configId": "okf_plaintext",
        "name": "Plain Text",
        "description": "Plain text files.",
        "mimeType": "text/plain",
        "extensions": ".txt;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.plaintext.base.BasePlainTextFilter"
      },
      {
        "configId": "okf_plaintext_trim_trail",
        "name": "Plain Text (Trim Trail)",
        "description": "Text files; trailing spaces and tabs removed from extracted lines.",
        "mimeType": "text/plain",
        "parametersLocation": "okf_plaintext_trim_trail.fprm",
        "parametersRaw": "#v1\nunescapeSource.b=true\ntrimLeading.b=false\ntrimTrailing.b=true\npreserveWS.b=false\nuseCodeFinder.b=false\ncodeFinderRules=#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false\nwrapMode.i=0\nparametersClass=net.sf.okapi.filters.plaintext.base.Parameters\n",
        "parameters": {
          "unescapeSource": true,
          "trimLeading": false,
          "trimTrailing": true,
          "preserveWS": false,
          "useCodeFinder": false,
          "codeFinderRules": "#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false",
          "wrapMode": 0
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.plaintext.base.BasePlainTextFilter"
      },
      {
        "configId": "okf_plaintext_trim_all",
        "name": "Plain Text (Trim All)",
        "description": "Text files; leading and trailing spaces and tabs removed from extracted lines.",
        "mimeType": "text/plain",
        "parametersLocation": "okf_plaintext_trim_all.fprm",
        "parametersRaw": "#v1\nunescapeSource.b=true\ntrimLeading.b=true\ntrimTrailing.b=true\npreserveWS.b=false\nuseCodeFinder.b=false\ncodeFinderRules=#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false\nwrapMode.i=0\nparametersClass=net.sf.okapi.filters.plaintext.base.Parameters\n",
        "parameters": {
          "unescapeSource": true,
          "trimLeading": true,
          "trimTrailing": true,
          "preserveWS": false,
          "useCodeFinder": false,
          "codeFinderRules": "#v1$0a$count.i=2$0a$rule0=%(([-0+#]?)[-0+#]?)((\\d\\$)?)(([\\d\\*]*)(\\.[\\d\\*]*)?)[dioxXucsfeEgGpn]$0a$rule1=(\\\\r\\\\n)|\\\\a|\\\\b|\\\\f|\\\\n|\\\\r|\\\\t|\\\\v$0a$sample=$0a$useAllRulesWhenTesting.b=false",
          "wrapMode": 0
        },
        "isDefault": false,
        "filterClass": "net.sf.okapi.filters.plaintext.base.BasePlainTextFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "parser": {
      "type": "object",
      "description": "Parser settings",
      "properties": {
        "preserveWS": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "preserveWS",
          "description": "Preserve whitespace"
        },
        "trimLeading": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "trimLeading",
          "description": "Trim leading whitespace"
        },
        "trimTrailing": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "trimTrailing",
          "description": "Trim trailing whitespace"
        },
        "unescapeSource": {
          "type": "boolean",
          "default": true,
          "x-flattenPath": "unescapeSource",
          "description": "Unescape source content"
        },
        "wrapMode": {
          "type": "string",
          "default": "NONE",
          "enum": [
            "NONE",
            "SPACES",
            "PLACEHOLDERS"
          ],
          "x-flattenPath": "wrapMode",
          "description": "Line wrapping mode"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "x-flattenPath": "codeFinderRules"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}