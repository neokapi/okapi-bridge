{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TTX Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_ttx",
    "class": "net.sf.okapi.filters.ttx.TTXFilter",
    "extensions": [
      ".ttx"
    ],
    "mimeTypes": [
      "application/x-ttx+xml"
    ],
    "configurations": [
      {
        "configId": "okf_ttx",
        "name": "TTX",
        "description": "Configuration for Trados TTX documents.",
        "mimeType": "application/x-ttx+xml",
        "extensions": ".ttx;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.ttx.TTXFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes"
    },
    "mode": {
      "type": "object",
      "title": "Processing mode",
      "properties": {
        "segmentMode": {
          "type": "integer",
          "default": 0,
          "title": "Extraction mode",
          "enum": [
            "0",
            "1",
            "2"
          ],
          "x-enumLabels": [
            "Auto-detect existing segments (If found: extract only those, otherwise extract all)",
            "Extract only existing segments",
            "Extract all (existing segments and un-segmented text parts)"
          ],
          "x-editor": {
            "widget": "select",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "segmentMode"
        }
      }
    },
    "output": {
      "type": "object",
      "title": "Output settings",
      "properties": {
        "escapeGT": {
          "type": "boolean",
          "default": false,
          "title": "Escape the greater-than characters in output",
          "x-editor": {
            "widget": "checkbox",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "escapeGT"
        }
      }
    }
  },
  "additionalProperties": false,
  "x-groups": [
    {
      "id": "inlineCodes",
      "label": "Inline Codes",
      "fields": [
        "inlineCodes"
      ]
    },
    {
      "id": "mode",
      "label": "Processing mode",
      "fields": [
        "mode"
      ]
    },
    {
      "id": "output",
      "label": "Output settings",
      "fields": [
        "output"
      ]
    }
  ],
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "title": "Inline Codes",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "title": "Enable Inline Code Detection",
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder",
          "x-enables": [
            "rules",
            "mergeAdjacent",
            "moveBoundaryCodes",
            "simplifierRules"
          ]
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "title": "Code Finder Rules",
          "x-flattenPath": "codeFinderRules",
          "x-enabledBy": "enabled",
          "x-widget": "codeFinder"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "title": "Merge Adjacent Codes",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "title": "Move Boundary Codes",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "title": "Simplifier Rules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "title": "Code Finder Rules",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "title": "Patterns",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "title": "Pattern",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "title": "Sample Text",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "title": "Test All Rules Together",
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "title": "Simplifier Rules",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}