{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DTD Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_dtd",
    "class": "net.sf.okapi.filters.dtd.DTDFilter",
    "extensions": [
      ".dtd",
      ".ent"
    ],
    "mimeTypes": [
      "application/xml+dtd"
    ],
    "configurations": [
      {
        "configId": "okf_dtd",
        "name": "DTD (Document Type Definition)",
        "description": "Configuration for XML DTD documents (entities content)",
        "mimeType": "application/xml+dtd",
        "extensions": ".dtd;.ent;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.dtd.DTDFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "useCodeFinder": {
      "type": "boolean",
      "default": true
    },
    "simplifierRules": {
      "type": "string",
      "description": "Simplifier rules for code type normalization",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "additionalProperties": false
}