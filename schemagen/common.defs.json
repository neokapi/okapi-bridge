{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.dev/schemas/defs/common.defs.json",
  "description": "Shared type definitions for Okapi Bridge filter schemas",
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "title": "Inline Codes",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "title": "Enable Inline Code Detection",
          "description": "Enable pattern-based detection of inline codes",
          "x-flattenPath": "useCodeFinder",
          "x-enables": ["rules", "mergeAdjacent", "moveBoundaryCodes", "simplifierRules"]
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "title": "Code Finder Rules",
          "x-flattenPath": "codeFinderRules",
          "x-enabledBy": "enabled",
          "x-widget": "codeFinderRules"
        },
        "mergeAdjacent": {
          "type": "boolean",
          "title": "Merge Adjacent Codes",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "title": "Move Boundary Codes",
          "description": "Move codes at segment boundaries to the skeleton",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "title": "Simplifier Rules",
          "x-flattenPath": "simplifierRules"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "title": "Code Finder Rules",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "title": "Patterns",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "title": "Pattern",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": ["pattern"]
          }
        },
        "sample": {
          "type": "string",
          "title": "Sample Text",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "title": "Test All Rules Together",
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "whitespace": {
      "type": "object",
      "title": "Whitespace",
      "description": "Whitespace handling",
      "properties": {
        "preserve": {
          "type": "boolean",
          "title": "Preserve Whitespace",
          "description": "Preserve original whitespace",
          "x-flattenPath": "preserveWhitespace"
        },
        "collapse": {
          "type": "boolean",
          "title": "Collapse Whitespace",
          "description": "Collapse multiple whitespace chars into single spaces",
          "x-flattenPath": "collapseWhitespace"
        },
        "trimLeading": {
          "type": "boolean",
          "title": "Trim Leading Whitespace",
          "description": "Remove leading whitespace from segments",
          "x-flattenPath": "trimLeadingWS"
        },
        "trimTrailing": {
          "type": "boolean",
          "title": "Trim Trailing Whitespace",
          "description": "Remove trailing whitespace from segments",
          "x-flattenPath": "trimTrailingWS"
        }
      }
    },
    "simplifierRules": {
      "type": "string",
      "title": "Simplifier Rules",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  }
}
